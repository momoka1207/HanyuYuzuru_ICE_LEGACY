  };

  function translateMilestoneCards() {
    const rows = milestoneCopy[lang()] || milestoneCopy.zh;
    $$("[data-mile-index]").forEach(card => {
      const index = Number(card.dataset.mileIndex);
      const row = rows[index];
      if (!row) return;
      const year = $(".milestone-year", card);
      const title = $("h3, h2", card);
      const text = $("p", card);
      if (year) year.textContent = row[0];
      if (title) title.textContent = row[1];
      if (text) text.textContent = row[2];
    });
  }

  function normalizeCostumeIds() {
    const pairs = [
      ["stableCostumePhase", "costumePhase"],
      ["stableCostumeProgram", "costumeProgram"],
      ["stableCostumeYear", "costumeYear"],
      ["stableCostumeToggle", "costumeToggle"],
      ["stableCostumeCount", "costumeCount"],
      ["stableCostumeGrid", "costumeGrid"],
      ["stableCostumeSide", "costumeTimeline"]
    ];
    pairs.forEach(([from, to]) => {
      const current = document.getElementById(to);
      const stable = document.getElementById(from);
      if (!current && stable) stable.id = to;
    });
    const section = $("#costumes");
    if (section) {
      $(".stable-costume-controls", section)?.classList.add("costume-controls");
      $("#costumeGrid", section)?.classList.add("costume-grid", "costume-grid-v2");
    }
  }

  function repairProgramNames() {
    const clean = text => String(text || "")
      .replace(/From\s+俄罗斯\s+With\s+Love/g, "From Russia With Love")
      .replace(/From\s+ロシア\s+With\s+Love/g, "From Russia With Love")
      .replace(/Hope\s*&\s*Legacy/g, "Hope and Legacy")
      .replace(/\bSEIMEI\b/g, "Seimei")
      .replace(/Otoñal/g, "Otonal")
      .replace(/Sing Sing Sing/g, "Sing, Sing, Sing");
    $$("#costumes option, #costumes h3, #costumes b, #costumes .stable-costume-program").forEach(el => {
      el.textContent = clean(el.textContent);
      if (el.tagName === "OPTION") el.value = clean(el.value);
    });
  }


  function updateProfileBooksLanguage() {
    const section = $("#profileBooks");
    if (!section) return;
    const copy = profileBookCopy[lang()] || profileBookCopy.zh;
    const label = $("#profileBooksLabel", section);
    const title = $("#profileBooksTitle", section);
    const intro = $("#profileBooksIntro", section);
    if (label) label.textContent = copy.label;
    if (title) title.textContent = copy.title;
    if (intro) intro.textContent = copy.intro;
    $$(".profile-book-card", section).forEach((card, index) => {
      const volume = copy.volumes[index];
      if (!volume) return;
      const meta = $(`#profileBookMeta${index}`, card);
      const heading = $(`#profileBookTitle${index}`, card);
      const desc = $(`#profileBookDesc${index}`, card);
      const image = $("img", card);
      if (meta) meta.textContent = volume.meta;
      if (heading) heading.textContent = volume.title;
      if (desc) desc.textContent = volume.desc;
      if (image) image.alt = volume.alt;
    });
  }

  function rebuildOfficialSources(options = {}) {
    const sec = $("#sources");
    if (!sec) return;
    const l = lang();
    const dict = t[l];
    const groups = {
      zh: [
        ["ICE STORY 与职业项目", [["PROLOGUE", "https://prologue-official.jp/"], ["GIFT", "https://gift-official.jp/"], ["RE_PRAY", "https://repray-icestory.jp/"], ["Echoes of Life", "https://echoesoflife.jp/"], ["REALIVE", "https://realive-icestory.jp/"], ["notte stellata", "https://nottestellata.com/"]]],
        ["竞技资料", [["Olympics 选手档案", "https://www.olympics.com/en/athletes/yuzuru-hanyu"], ["ISU 成绩档案", "https://www.isu.org/figure-skating/entries-results/fsk-results"], ["日本滑冰联盟成绩", "https://www.jsfresults.com/"], ["Planet Hanyu 服装图鉴", "https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/"]]]
      ],
      en: [
        ["ICE STORY and Professional Projects", [["PROLOGUE", "https://prologue-official.jp/"], ["GIFT", "https://gift-official.jp/"], ["RE_PRAY", "https://repray-icestory.jp/"], ["Echoes of Life", "https://echoesoflife.jp/"], ["REALIVE", "https://realive-icestory.jp/"], ["notte stellata", "https://nottestellata.com/"]]],
        ["Competition and Costume Archives", [["Olympics athlete profile", "https://www.olympics.com/en/athletes/yuzuru-hanyu"], ["ISU results archive", "https://www.isu.org/figure-skating/entries-results/fsk-results"], ["Japan Skating Federation results", "https://www.jsfresults.com/"], ["Planet Hanyu Costume Archive", "https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/"]]]
      ],
      ja: [
        ["ICE STORY とプロジェクト", [["PROLOGUE", "https://prologue-official.jp/"], ["GIFT", "https://gift-official.jp/"], ["RE_PRAY", "https://repray-icestory.jp/"], ["Echoes of Life", "https://echoesoflife.jp/"], ["REALIVE", "https://realive-icestory.jp/"], ["notte stellata", "https://nottestellata.com/"]]],
        ["競技・衣装アーカイブ", [["Olympics 選手プロフィール", "https://www.olympics.com/en/athletes/yuzuru-hanyu"], ["ISU 成績アーカイブ", "https://www.isu.org/figure-skating/entries-results/fsk-results"], ["日本スケート連盟 成績", "https://www.jsfresults.com/"], ["Planet Hanyu 衣装アーカイブ", "https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/"]]]
      ]
    }[l];
    const existingGroups = $$(".simple-source-group", sec);
    const existingLinks = $$(".simple-source-link", sec);
    const expectedLinks = groups.reduce((sum, group) => sum + group[1].length, 0);
    if (options.inPlace && existingGroups.length === groups.length && existingLinks.length === expectedLinks) {
      const heading = $("h2", sec);
      if (heading) heading.textContent = dict.sourceTitle;
      $(".section-label", sec)?.remove();
      let linkIndex = 0;
      groups.forEach(([title, links], groupIndex) => {
        const groupHeading = $("h3", existingGroups[groupIndex]);
        if (groupHeading) groupHeading.textContent = title;
        links.forEach(([text]) => {
          const label = $("span:first-child", existingLinks[linkIndex++]);
          if (label) label.textContent = text.replace(/\u5929\u672c/g, "日本");
        });
      });
      sec.dataset.stableSourceLang = l;
      return;
    }
    sec.innerHTML = `
      <div class="section-head">
        <div><h2>${esc(dict.sourceTitle)}</h2></div>
      </div>
      <div class="simple-source-list">
        ${groups.map(([title, links]) => `
          <div class="simple-source-group">
            <h3>${esc(title)}</h3>
            <div class="simple-source-links">
              ${links.map(([text, href]) => `<a class="simple-source-link" href="${esc(href)}" target="_blank" rel="noreferrer"><span>${esc(text).replace(/\u5929\u672c/g, "日本")}</span><span>↗</span></a>`).join("")}
            </div>
          </div>
        `).join("")}
      </div>
    `;
    sec.dataset.stableSourceLang = l;
  }

  function rebuildCostumeShell() {
    const sec = $("#costumes");
    if (!sec) return;
    const l = lang();
    const dict = t[l];
    sec.classList.add("section", "wrap");
    sec.innerHTML = `
      <div class="section-head">
        <div>
          <div class="section-label">${esc(dict.costumeLabel)}</div>
          <h2>${esc(dict.costumeTitle)}</h2>
        </div>
        <p class="section-intro">${esc(dict.costumeIntro)}</p>
      </div>
      <div class="final-costume-controls">
        <select id="costumePhase" aria-label="Costume phase"></select>
        <select id="costumeProgram" aria-label="Program"></select>
        <select id="costumeYear" aria-label="Costume year"></select>
      </div>
      <div id="costumeCount" class="archive-count"></div>
      <div class="final-costume-actions"><button id="costumeToggle" class="btn" type="button"></button></div>
      <div id="costumeGrid" class="final-costume-grid"></div>
      <p id="costumeAttributionNote" class="costume-attribution-note">${esc(dict.costumeAttribution)}</p>
    `;
  }

  function ensureCostumeYearSelect() {
    const controls = $("#costumes .costume-controls");
    if (!controls || $("#costumeYear")) return;
    const year = document.createElement("select");
    year.id = "costumeYear";
    year.setAttribute("aria-label", "Costume year");
    const program = $("#costumeProgram");
    controls.insertBefore(year, program?.nextSibling || controls.firstChild);
  }

  function populateCostumeFilters() {
    normalizeCostumeIds();
    ensureCostumeYearSelect();
    const l = lang();
    const dict = t[l];
    const phase = $("#costumePhase");
    if (phase) {
      phase.innerHTML = `
        <option value="all">${esc(dict.phaseAll)}</option>
        <option value="child">${esc(dict.phaseChild)}</option>
        <option value="junior">${esc(dict.phaseJunior)}</option>
        <option value="senior">${esc(dict.phaseSenior)}</option>`;
    }
    const year = $("#costumeYear");
    if (year) {
      const old = year.value || "all";
      const years = [...new Set(costumeRows.flatMap(r => r.years))].sort((a,b) => a-b);
      year.innerHTML = `<option value="all">${esc(dict.yearAll)}</option>${years.map(y => `<option value="${y}">${y}</option>`).join("")}`;
      year.value = years.includes(Number(old)) ? old : "all";
    }
    const program = $("#costumeProgram");
    if (program) {
      const old = program.value || "all";
      const programs = [...new Set(costumeRows.map(r => r.program))].sort((a,b) => a.localeCompare(b));
      program.innerHTML = `<option value="all">${esc(dict.programAll)}</option>${programs.map(p => `<option value="${esc(p)}">${esc(p)}</option>`).join("")}`;
      program.value = programs.includes(old) ? old : "all";
    }
  }

  function filteredCostumes() {
    const phase = $("#costumePhase")?.value || "all";
    const year = $("#costumeYear")?.value || "all";
    const program = $("#costumeProgram")?.value || "all";
    let rows = costumeRows.filter(r =>
      (phase === "all" || r.phase === phase) &&
      (year === "all" || r.years.includes(Number(year))) &&
      (program === "all" || r.program === program)
    );
    if (!rows.length && program !== "all") {
      $("#costumeProgram").value = "all";
      rows = costumeRows.filter(r =>
        (phase === "all" || r.phase === phase) &&
        (year === "all" || r.years.includes(Number(year)))
      );
    }
    return rows;
  }

  function filtersAreDefault() {
    return ($("#costumePhase")?.value || "all") === "all" &&
      ($("#costumeProgram")?.value || "all") === "all" &&
      ($("#costumeYear")?.value || "all") === "all";
  }

  function uniqueCostumeRows(rows) {
    const seen = new Set();
    return rows.filter(row => {
      const key = String(row.image || `${row.program}-${row.season}`).trim().replace(/\?.*$/, "");
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });
  }

  function featuredCostumes(rows) {
    const picks = [
      /seimei/i,
      /ten to chi to/i,
      /haru yo koi|春来|春よ/i,
      /chopin ballade/i,
      /origin/i
    ];
    const used = new Set();
    return picks.map(re => {
      const found = rows.find(row => !used.has(row.id) && (re.test(row.program) || re.test(row.note?.zh || "")));
      if (found) used.add(found.id);
      return found;
    }).filter(Boolean);
  }

  function costumeSourceFor(row) {
    if (row.sourceName) return { name: row.sourceName, url: row.sourceUrl || costumeSourceHome };
    let host = "";
    try { host = new URL(row.image).hostname.replace(/^www\./, ""); } catch (e) {}
    const name = /sponichi/i.test(host) ? "Sponichi / Planet Hanyu" :
      /nikkan|gendai/i.test(host) ? "Nikkan Gendai / Planet Hanyu" :
      /walkerplus/i.test(host) ? "Walkerplus / Planet Hanyu" :
      /hearst|25ans/i.test(host) ? "25ans / Planet Hanyu" :
      /pbs\.twimg|twitter|x\.com/i.test(host) ? "Social media image / Planet Hanyu" :
      /imgur/i.test(host) ? "Imgur mirror / Planet Hanyu" :
      /straitstimes/i.test(host) ? "The Straits Times / Planet Hanyu" :
      /wsj/i.test(host) ? "WSJ / Planet Hanyu" :
      host ? `${host} / Planet Hanyu` : "Planet Hanyu";
    return { name, url: costumeSourceHome };
  }

  function renderCostumes() {
    const prevPhase = $("#costumePhase")?.value || "all";
    const prevProgram = $("#costumeProgram")?.value || "all";
    const prevYear = $("#costumeYear")?.value || "all";
    rebuildCostumeShell();
    normalizeCostumeIds();
    populateCostumeFilters();
    const keepValue = (id, value) => {
      const el = document.getElementById(id);
      if (el && Array.from(el.options).some(o => o.value === value)) el.value = value;
    };
    keepValue("costumePhase", prevPhase);
    keepValue("costumeProgram", prevProgram);
    keepValue("costumeYear", prevYear);
    const l = lang();
    const dict = t[l];
    const rows = uniqueCostumeRows(filteredCostumes());
    const defaultView = filtersAreDefault();
    const shown = defaultView && !costumeExpanded ? featuredCostumes(rows) : rows;
    const count = $("#costumeCount");
    if (count) count.textContent = dict.costumeCount(shown.length, rows.length);
    const toggle = $("#costumeToggle");
    if (toggle) {
      toggle.hidden = !defaultView;
      toggle.textContent = costumeExpanded ? dict.collapse : dict.expand;
      toggle.dataset.expanded = costumeExpanded ? "1" : "0";
    }
    const grid = $("#costumeGrid");
    if (grid) {
      grid.innerHTML = shown.map((row, index) => `
        <article class="stable-costume-card">
          <img decoding="async" src="${esc(row.image)}" alt="${esc(row.program)} costume" loading="lazy" fetchpriority="auto" referrerpolicy="no-referrer">
          <div class="costume-body">
            <div class="season">${esc(row.season)} · ${esc(row.phase)}</div>
            <h3>${esc(row.program)}</h3>
            <p>${esc(row.note[l] || row.note.zh)}</p>
            <div class="costume-years">${esc(row.years.join(" / "))}</div>
            <a class="costume-source-pill" href="${esc(costumeSourceFor(row).url)}" target="_blank" rel="noreferrer">${esc(costumeSourceFor(row).name)} ↗</a>
          </div>
        </article>
      `).join("");
    }
    repairProgramNames();
  }

  function updateCostumeLanguageInPlace() {
    const sec = $("#costumes");
    const grid = $("#costumeGrid");
    if (!sec || !grid) return;
    const l = lang();
    const dict = t[l];
    const values = {
      phase: $("#costumePhase")?.value || "all",
      program: $("#costumeProgram")?.value || "all",
      year: $("#costumeYear")?.value || "all"
    };
    populateCostumeFilters();
    [["#costumePhase", values.phase], ["#costumeProgram", values.program], ["#costumeYear", values.year]].forEach(([selector, value]) => {
      const control = $(selector);
      if (control && Array.from(control.options).some(option => option.value === value)) control.value = value;
    });
    const rows = uniqueCostumeRows(filteredCostumes());
    const defaultView = filtersAreDefault();
    const shown = defaultView && !costumeExpanded ? featuredCostumes(rows) : rows;
    const cards = $$(".stable-costume-card", grid);
    if (cards.length !== shown.length) {
      renderCostumes();
      return;
    }
    const headingLabel = $(".section-head .section-label", sec);
    const heading = $(".section-head h2", sec);
    const intro = $(".section-head .section-intro", sec);
    if (headingLabel) headingLabel.textContent = dict.costumeLabel;
    if (heading) heading.textContent = dict.costumeTitle;
    if (intro) intro.textContent = dict.costumeIntro;
    const attribution = $("#costumeAttributionNote", sec);
    if (attribution) attribution.textContent = dict.costumeAttribution;
    const phaseNames = { child: dict.phaseChild, junior: dict.phaseJunior, senior: dict.phaseSenior };
    cards.forEach((card, index) => {
      const row = shown[index];
      if (!row) return;
      const image = $("img", card);
      const season = $(".season", card);
      const note = $("p", card);
      const years = $(".costume-years", card);
      const source = $(".costume-source-pill", card);
      if (image) image.alt = `${row.program} ${l === "en" ? "costume" : l === "ja" ? "衣装" : "考斯滕"}`;
      if (season) season.textContent = `${row.season} · ${phaseNames[row.phase] || row.phase}`;
      if (note) note.textContent = row.note[l] || row.note.zh;
      if (years) years.textContent = row.years.join(" / ");
      if (source) source.textContent = `${costumeSourceFor(row).name} ↗`;
    });
    const count = $("#costumeCount");
    if (count) count.textContent = dict.costumeCount(shown.length, rows.length);
    const toggle = $("#costumeToggle");
    if (toggle) toggle.textContent = costumeExpanded ? dict.collapse : dict.expand;
    repairProgramNames();
  }

  function getCompetitions() {
    try {
      if (Array.isArray(competitions)) return competitions;
    } catch (e) {}
    return [];
  }

  function localPlace(raw) {
    const l = lang();
    const countryExtra = {
      zh:{Germany:"德国",Netherlands:"荷兰",Bulgaria:"保加利亚",Spain:"西班牙"},
      en:{Germany:"Germany",Netherlands:"Netherlands",Bulgaria:"Bulgaria",Spain:"Spain"},
      ja:{Germany:"ドイツ",Netherlands:"オランダ",Bulgaria:"ブルガリア",Spain:"スペイン"}
    }[l];
    const countryNames = { ...t[l].countryNames, ...countryExtra };
    const countryAliases = {
      "South Korea":"Korea","Korea":"Korea","韩国":"Korea","韓国":"Korea","大韩民国":"Korea","大韓民国":"Korea","대한민국":"Korea",
      "United States":"USA","USA":"USA","美国":"USA","アメリカ":"USA",
      "Netherlands":"Netherlands","荷兰":"Netherlands","オランダ":"Netherlands",
      "Bulgaria":"Bulgaria","保加利亚":"Bulgaria","ブルガリア":"Bulgaria",
      "Germany":"Germany","德国":"Germany","ドイツ":"Germany",
      "Spain":"Spain","西班牙":"Spain","スペイン":"Spain",
      "Japan":"Japan","日本":"Japan","China":"China","中国":"China",
      "Russia":"Russia","俄罗斯":"Russia","ロシア":"Russia",
      "Finland":"Finland","芬兰":"Finland","フィンランド":"Finland",
      "Canada":"Canada","加拿大":"Canada","カナダ":"Canada",
      "France":"France","法国":"France","フランス":"France",

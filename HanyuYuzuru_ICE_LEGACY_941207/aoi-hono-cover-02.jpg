.costume-atlas{padding:22px;margin-bottom:22px;display:grid;grid-template-columns:320px 1fr;gap:20px;overflow:hidden;position:relative}
.costume-atlas:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 78% 28%,rgba(91,210,255,.18),transparent 26%),radial-gradient(circle at 38% 75%,rgba(232,199,121,.12),transparent 30%);pointer-events:none}
.costume-atlas>*{position:relative;z-index:1}.costume-atlas h3{font-size:28px;margin:8px 0 10px}.costume-atlas p{color:var(--muted);line-height:1.7;margin:0}
.program-stars{min-height:180px;display:flex;flex-wrap:wrap;align-content:center;gap:10px}
.program-star{border:1px solid rgba(188,236,255,.22);background:rgba(4,16,29,.72);color:#dceff8;border-radius:999px;padding:9px 13px;font:800 11px Inter,system-ui;cursor:pointer;box-shadow:0 0 0 rgba(85,199,242,0);transition:.2s}
.program-star:hover,.program-star.active{border-color:#7fe7ff;color:#fff;background:rgba(32,111,148,.58);box-shadow:0 0 22px rgba(85,199,242,.28)}
.costume-layout{display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:22px;align-items:start}
.costume-grid-v2{grid-template-columns:repeat(5,minmax(0,1fr));gap:14px}
.costume-card-v2{border:1px solid rgba(188,236,255,.18);border-radius:18px;overflow:hidden;background:linear-gradient(155deg,rgba(10,35,58,.92),rgba(3,12,22,.96));min-height:340px;cursor:pointer;position:relative;box-shadow:0 20px 50px rgba(0,0,0,.18)}
.costume-card-v2:before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(0,0,0,.6));z-index:1;pointer-events:none}
.costume-card-v2 img{width:100%;height:235px;object-fit:cover;object-position:top center;display:block;filter:saturate(.96) contrast(1.02)}
.costume-card-body{position:relative;z-index:2;padding:14px}.costume-card-body .season{font-size:10px;color:var(--gold);letter-spacing:.1em;text-transform:uppercase}.costume-card-body h3{font-size:16px;margin:8px 0 6px;line-height:1.2}.costume-card-body p{font-size:10px;line-height:1.55;color:var(--muted);margin:0}
.costume-badge{display:inline-block;margin-top:9px;border:1px solid rgba(188,236,255,.22);border-radius:999px;padding:4px 8px;color:#bcecff;font-size:9px}
.costume-timeline-panel{padding:20px;position:sticky;top:78px}.costume-timeline-panel h3{font-size:22px;margin:8px 0 14px}.costume-timeline{display:grid;gap:10px;max-height:560px;overflow:auto;padding-right:5px}
.costume-timeline-item{border:1px solid rgba(188,236,255,.16);border-radius:14px;padding:12px;background:rgba(5,18,31,.65)}
.costume-timeline-item span{display:block;color:#5fd8ff;font-size:10px;font-weight:900;letter-spacing:.08em}.costume-timeline-item b{display:block;margin:5px 0 4px;font-size:13px}.costume-timeline-item em{display:block;color:var(--muted);font-size:10px;font-style:normal}
.costume-source-note{font-size:10px;line-height:1.6;color:var(--muted);margin-top:14px}.costume-source-note a{color:var(--ice)}
.costume-empty{border:1px dashed rgba(188,236,255,.24);border-radius:16px;padding:22px;color:var(--muted);line-height:1.7}

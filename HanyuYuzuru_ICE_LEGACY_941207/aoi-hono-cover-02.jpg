  const profileBookCopy = {
    zh: {
      label: "著作与自述",
      title: "《苍炎》自传系列",
      intro: "四卷自传以照片与长篇访谈记录竞技生涯、震灾后的重建、两届冬奥征程，以及转为职业运动员后继续创作 ICE STORY 的过程。",
      volumes: [
        { meta:"第 1 卷 · 2012 · 扶桑社", title:"《苍炎》", alt:"《苍炎》封面", desc:"以照片和长篇访谈回顾从4岁开始滑冰、经历2011年东日本大地震，到首次站上世界锦标赛领奖台前后的成长。" },
        { meta:"第 2 卷 · 2016 · 扶桑社", title:"《苍炎Ⅱ：飞翔篇》", alt:"《苍炎Ⅱ：飞翔篇》封面", desc:"记录2012年至2016年的竞技历程，包括赴多伦多训练、索契冬奥夺冠、伤病与疾病，以及不断刷新世界纪录的过程。" },
        { meta:"第 3 卷 · 2023 · 扶桑社", title:"《苍炎Ⅲ：究竟篇》", alt:"《苍炎Ⅲ：究竟篇》封面", desc:"从2015—2016赛季休赛期写到2018年冬奥卫冕与2020年完成超级全满贯，呈现他对理想滑冰的持续追求。" },
        { meta:"第 4 卷 · 2023 · 扶桑社", title:"《苍炎Ⅳ：无限篇》", alt:"《苍炎Ⅳ：无限篇》封面", desc:"聚焦北京冬奥挑战四周半跳与竞技生涯的终章，并延伸至职业转向后的 PROLOGUE、GIFT 等全新创作。" }
      ]
    },
    en: {
      label: "BOOKS & AUTOBIOGRAPHY",
      title: "Blue Flames Autobiography Series",
      intro: "Across four volumes, photographs and long-form interviews trace his competitive career, rebuilding after the earthquake, two Olympic journeys, and the creation of ICE STORY after turning professional.",
      volumes: [
        { meta:"VOLUME I · 2012 · FUSOSHA", title:"Blue Flames", alt:"Blue Flames volume I cover", desc:"A photographic and interview-based account from beginning skating at four, through the 2011 Great East Japan Earthquake, to his emergence on the World Championships podium." },
        { meta:"VOLUME II · 2016 · FUSOSHA", title:"Blue Flames II: Flight", alt:"Blue Flames volume II cover", desc:"Covers 2012–2016: moving to Toronto, winning the Sochi Olympic title, overcoming injuries and illness, and repeatedly setting new world records." },
        { meta:"VOLUME III · 2023 · FUSOSHA", title:"Blue Flames III: The Ultimate", alt:"Blue Flames volume III cover", desc:"From the 2015–2016 off-season to a second Olympic title in 2018 and completion of the Super Slam in 2020, it follows his continuing pursuit of ideal skating." },
        { meta:"VOLUME IV · 2023 · FUSOSHA", title:"Blue Flames IV: Infinite", alt:"Blue Flames volume IV cover", desc:"Focuses on the quadruple Axel challenge at Beijing 2022, the close of his competitive career, and new creations including PROLOGUE and GIFT after turning professional." }
      ]

"spScore":107.12,"fsRank":2,"fsScore":193.76,"worldRecord":false,"country":"JPN","source":"https://www.isuresults.com/bios/isufs_cr_00010967.htm","sourceOrg":"ISU","verification":"Official source linked","confidence":"High","notes":null},{"id":"C102","season":"2021-2022","year":2021,"age":26,"name":"日本全国锦标赛","nameEn":"2021 JPN Nationals","type":"Japan Nationals","level":"Senior","scope":"Overall","rank":1,"medal":"Gold","score":322.36,"spRank":1,"spScore":111.31,"fsRank":1,"fsScore":211.05,"worldRecord":false,"country":"JPN","source":"https://www.jsfresults.com/non_responsive_toppage.htm","sourceOrg":"JSF","verification":"Official archive linked; some early row PDFs may require manual click-through","confidence":"High","notes":null},{"id":"C103","season":"2021-2022","year":2022,"age":27,"name":"奥运会","nameEn":"2022 Olympics Beijing","type":"Olympic Games","level":"Senior","scope":"Overall","rank":4,"medal":null,"score":283.21,"spRank":8,"spScore":95.15,"fsRank":3,"fsScore":188.06,"worldRecord":false,"country":"JPN","source":"https://results.isu.org/results/season2122/owg2022/","sourceOrg":"ISU","verification":"Official source linked","confidence":"High","notes":null}];
const costumeCatalog=[
  {season:'2011–2012',program:'Romeo + Juliet',kind:'Free Skate',tone:'rgba(63,139,196,.42)',note:'竞技早期的代表性自由滑造型。'},
  {season:'2012–2014',program:'Parisienne Walkways',kind:'Short Program',tone:'rgba(25,115,186,.46)',note:'两届赛季使用的短节目造型体系。'},
  {season:'2013–2014',program:'Romeo and Juliet',kind:'Free Skate',tone:'rgba(210,70,68,.38)',note:'索契冬奥赛季自由滑。'},
  {season:'2014–2018',program:'Ballade No. 1',kind:'Short Program',tone:'rgba(127,180,230,.4)',note:'跨多个赛季演化的标志性蓝色系造型。'},
  {season:'2015–2018',program:'SEIMEI',kind:'Free Skate',tone:'rgba(105,165,118,.42)',note:'融合和风意象的代表性自由滑服装。'},
  {season:'2016–2017',program:'Hope & Legacy',kind:'Free Skate',tone:'rgba(79,170,168,.42)',note:'以自然与生命感为视觉线索。'},
  {season:'2018–2020',program:'Otonal',kind:'Short Program',tone:'rgba(108,164,222,.44)',note:'秋日与冰蓝色调的短节目造型。'},
  {season:'2018–2020',program:'Origin',kind:'Free Skate',tone:'rgba(97,67,151,.48)',note:'黑紫与金色体系的自由滑造型。'},
  {season:'2020–2021',program:'Let Me Entertain You',kind:'Short Program',tone:'rgba(190,72,72,.42)',note:'摇滚风格短节目造型。'},
  {season:'2020–2022',program:'Ten to Chi to',kind:'Free Skate',tone:'rgba(190,200,220,.36)',note:'以日本历史叙事为核心的自由滑服装。'},
  {season:'2021–2022',program:'Rondo Capriccioso',kind:'Short Program',tone:'rgba(75,150,220,.45)',note:'北京冬奥赛季短节目造型。'},
  {season:'Exhibition',program:'Haru yo, Koi',kind:'Exhibition',tone:'rgba(240,150,190,.35)',note:'持续演化的春日樱花意象表演服。'}
];
const profileImage='assets/inline-00-316656306a.jpg';
const competitionImages={};
const competitionPhotoSources={
  C088:{url:'https://isu-skating.com/figure-skating/news/figure-skatings-most-iconic-olympic-moments/',credit:'ISU 官方专题页 · 2018 PyeongChang 现场图 · © Getty Images'}
};
function inferCompetitionLocation(c){const n=c.nameEn||'';if(/PyeongChang/i.test(n))return'韩国 · 平昌';if(/Beijing|COC|Cup of China/i.test(n))return'中国';if(/Sochi/i.test(n))return'俄罗斯 · 索契';if(/COR|Russia/i.test(n))return'俄罗斯';if(/Helsinki|Finland/i.test(n))return'芬兰';if(/Merano/i.test(n))return'意大利';if(/Torun/i.test(n))return'波兰';if(/Croatia|Mladost/i.test(n))return'克罗地亚';if(/Copenhagen/i.test(n))return'丹麦';if(/SC|Skate Canada|Autumn CI/i.test(n))return'加拿大';if(/NHK|JPN|Japan|Toh|Miyagi|National Junior High|World Team Trophy/i.test(n))return'日本';if(c.type==='World Championships'){return({2012:'法国',2013:'加拿大',2014:'日本',2015:'中国',2016:'美国',2017:'芬兰',2019:'日本',2021:'瑞典'})[c.year]||'待补';}if(c.type==='Four Continents Championships'){return({2011:'中国',2013:'日本',2017:'韩国',2020:'韩国'})[c.year]||'待补';}return'待补';}
function careerStage(c){const start=parseInt(String(c.season).slice(0,4),10);return start<2010?'少年／青年组阶段':'成年组阶段'}
competitions.forEach(c=>{c.stage=careerStage(c);c.location=inferCompetitionLocation(c);c.image=competitionImages[c.id]||null});
let competitionLimit=10;
function populateCompetitionFilters(){const years=[...new Set(competitions.map(c=>c.year))].sort((a,b)=>a-b);const stages=['少年／青年组阶段','成年组阶段'];const types=[...new Set(competitions.map(c=>c.type))].sort();const locations=[...new Set(competitions.map(c=>c.location))].sort();for(const [id,vals] of [['compYear',years],['compStage',stages],['compType',types],['compLocation',locations]]){const s=$('#'+id);vals.forEach(v=>s.add(new Option(v,v)))} }
function filteredCompetitions(){const q=$('#compSearch').value.trim().toLowerCase(),year=$('#compYear').value,stage=$('#compStage').value,type=$('#compType').value,location=$('#compLocation').value,medal=$('#compMedal').value;return competitions.filter(c=>(!q||[c.id,c.season,c.nameEn,c.type,c.level,c.location].join(' ').toLowerCase().includes(q))&&(year==='all'||String(c.year)===year)&&(stage==='all'||c.stage===stage)&&(type==='all'||c.type===type)&&(location==='all'||c.location===location)&&(medal==='all'||(medal==='none'?!c.medal:c.medal===medal)));}
function renderCompetitions(reset=false){if(reset)competitionLimit=10;const list=filteredCompetitions();$('#compCount').textContent=`找到 ${list.length} 条记录 · 显示 ${Math.min(list.length,competitionLimit)} 条`;$('#competitionList').innerHTML=list.slice(0,competitionLimit).map(c=>`<article class="competition-row" data-comp-id="${c.id}" tabindex="0"><div class="comp-year">${c.year}</div><div class="comp-name"><b>${c.nameEn}</b><span>${c.season} · ${c.stage} · ${c.level} · ${c.id}${c.worldRecord?' · WR':''}</span></div><div class="comp-type">${c.type}</div><div class="comp-location">${c.location}</div><div class="comp-result"><span class="medal ${c.medal||''}">${c.medal||('Rank '+(c.rank??'—'))}</span>${c.score!=null?`<span class="comp-location">${c.score.toFixed(2)}</span>`:''}</div></article>`).join('');document.querySelectorAll('[data-comp-id]').forEach(row=>{const open=()=>openCompetition(row.dataset.compId);row.addEventListener('click',open);row.addEventListener('keydown',e=>{if(e.key==='Enter')open()})});$('#loadMoreCompetitions').style.display=competitionLimit<list.length?'block':'none';}
function openCompetition(id){const c=competitions.find(x=>x.id===id);$('#modalHero').classList.toggle('no-photo',!c.image);$('#modalImage').src=c.image||'';$('#modalImage').alt=c.nameEn+' 官方现场图';$('#modalOverline').textContent=`COMPETITION ARCHIVE · ${c.year} · ${c.id}`;$('#modalTitle').textContent=c.nameEn;const source=c.source?`<a class="official-link" href="${c.source}" target="_blank" rel="noreferrer">查看官方成绩来源 ↗</a>`:'<span class="status-wait">行级官方来源待补</span>';const photoSource=competitionPhotoSources[c.id];const photoLink=photoSource?`<a class="official-link" href="${photoSource.url}" target="_blank" rel="noreferrer">查看可核验官方现场图 ↗</a><small class="image-credit">${photoSource.credit}</small>`:'';$('#modalBody').innerHTML=`<div class="modal-copy"><div><p>${c.season} 赛季，约 ${c.age} 岁。生涯阶段：${c.stage}；赛事类型：${c.type}；级别：${c.level}；地点：${c.location}。</p><p>${c.image?'已绑定该场官方现场图片。':'目前尚未找到可确认属于该场比赛且可安全内嵌的官方图片，因此不使用替代照片。'}</p>${source}${photoLink}</div><div class="facts"><div class="fact"><span>Overall</span><b>Rank ${c.rank??'—'}${c.medal?' · '+c.medal:''}</b></div><div class="fact"><span>Total score</span><b>${c.score!=null?c.score.toFixed(2):'—'}</b></div><div class="fact"><span>SP</span><b>${c.spRank??'—'} / ${c.spScore??'—'}</b></div><div class="fact"><span>FS</span><b>${c.fsRank??'—'} / ${c.fsScore??'—'}</b></div><div class="fact"><span>Verification</span><b>${c.confidence||'待核对'}</b></div></div></div>`;openModal()}
function renderCostumes(){$('#costumeGrid').innerHTML=costumeCatalog.map(c=>`<article class="costume"><div class="costume-art" style="--tone:${c.tone}"><span>OFFICIAL PHOTO PENDING</span></div><div class="costume-body"><div class="season">${c.season} · ${c.kind}</div><h3>${c.program}</h3><p>${c.note}</p><span class="status-wait">官方图片 / 摄影版权待补</span></div></article>`).join('')}
function updateBirthdayCountdown(){const now=new Date();let year=now.getFullYear();let next=new Date(year,11,7,0,0,0);if(now>=next)next=new Date(++year,11,7,0,0,0);const diff=Math.max(0,next-now),days=Math.floor(diff/86400000),hours=Math.floor(diff%86400000/3600000),minutes=Math.floor(diff%3600000/60000),seconds=Math.floor(diff%60000/1000),l=document.documentElement.dataset.lang||'zh';$('#birthdayYear').textContent=l==='en'?`${year} Birthday`:l==='ja'?`${year}年の誕生日`:`${year} 年生日`;$('#countDays').textContent=String(days).padStart(2,'0');$('#countHours').textContent=String(hours).padStart(2,'0');$('#countMinutes').textContent=String(minutes).padStart(2,'0');$('#countSeconds').textContent=String(seconds).padStart(2,'0')}
function updateProfessionalAnniversaryCountdown(){
  const now=new Date(),l=document.documentElement.dataset.lang||'zh';
  let year=now.getFullYear(),next=new Date(year,6,19,0,0,0);
  if(now>=next)next=new Date(++year,6,19,0,0,0);
  const diff=Math.max(0,next-now),days=Math.floor(diff/86400000),hours=Math.floor(diff%86400000/3600000),minutes=Math.floor(diff%3600000/60000),seconds=Math.floor(diff%60000/1000);
  const labels={
    zh:{next:'距离下一次 7 月 19 日',year:`${year} 年 7 月 19 日`,since:'距离 2022 年 7 月 19 日已经过去',anniversary:'转职纪念日',units:['天','小时','分钟','秒'],day:'天'},
    en:{next:'Until the next July 19',year:`July 19, ${year}`,since:'Time since July 19, 2022',anniversary:'Professional transition anniversary',units:['Days','Hours','Minutes','Seconds'],day:'Days'},
    ja:{next:'次の7月19日まで',year:`${year}年7月19日`,since:'2022年7月19日からの経過日数',anniversary:'プロ転向記念日',units:['日','時間','分','秒'],day:'日'}
  }[l]||null;
  if(!labels)return;
  const put=(id,value)=>{const el=document.getElementById(id);if(el)el.textContent=value};
  put('july19NextTitle',labels.next);put('july19Year',labels.year);put('july19SinceTitle',labels.since);put('july19AnniversaryLabel',labels.anniversary);
  put('july19Days',String(days).padStart(2,'0'));put('july19Hours',String(hours).padStart(2,'0'));put('july19Minutes',String(minutes).padStart(2,'0'));put('july19Seconds',String(seconds).padStart(2,'0'));
  document.querySelectorAll('#july19Countdown .count-unit span').forEach((el,i)=>{el.textContent=labels.units[i]});
  const todayUtc=Date.UTC(now.getFullYear(),now.getMonth(),now.getDate()),startUtc=Date.UTC(2022,6,19),sinceDays=Math.max(0,Math.floor((todayUtc-startUtc)/86400000));
  put('sinceJuly19Days',String(sinceDays));const sinceUnit=document.querySelector('#july19Since .count-unit span');if(sinceUnit)sinceUnit.textContent=labels.day;
}
function setupMuseumV3(){const portrait=$('#profilePortrait');if(portrait){portrait.src=profileImage;portrait.loading='lazy';portrait.decoding='async';portrait.referrerPolicy='no-referrer';}updateBirthdayCountdown();updateProfessionalAnniversaryCountdown();setInterval(updateBirthdayCountdown,1000);setInterval(updateProfessionalAnniversaryCountdown,1000);const originalOpenShow=openShow,originalOpenMilestone=openMilestone;openShow=function(id){$('#modalHero').classList.remove('no-photo');originalOpenShow(id)};openMilestone=function(i){$('#modalHero').classList.remove('no-photo');originalOpenMilestone(i)}}
setupMuseumV3();

drawTrend();renderPosters();renderMilestones();
  </script>


<script id="absolute-final-reset-hero-map-script">
(function(){
  "use strict";
  if (window.__hanyuCompetitionRuntime) return;
  window.__hanyuCompetitionRuntime = true;
  const $=(s,r=document)=>r.querySelector(s), $$=(s,r=document)=>Array.from(r.querySelectorAll(s));
  const exact={C001:'日本',C002:'日本',C003:'芬兰-坦佩雷',C004:'中国-香港',C005:'日本',C006:'日本',C007:'中国-香港',C008:'日本',C009:'日本',C010:'日本',C011:'日本',C012:'克罗地亚-萨格勒布',C013:'日本',C014:'日本',C015:'日本',C016:'日本',C017:'日本',C018:'日本',C019:'日本',C020:'丹麦-哥本哈根',C021:'意大利-梅拉诺',C022:'日本',C023:'日本',C024:'日本',C025:'日本',C026:'日本',C027:'日本',C028:'保加利亚-索菲亚',C029:'日本',C030:'波兰-托伦',C031:'日本',C032:'克罗地亚-萨格勒布',C033:'日本',C034:'日本',C035:'日本',C036:'日本-东京',C037:'日本',C038:'日本',C039:'荷兰-海牙',C040:'日本-名古屋',C041:'日本',C042:'俄罗斯-莫斯科',C043:'日本',C044:'中国-台北',C045:'德国-奥伯斯多夫',C046:'日本',C047:'中国-上海',C048:'俄罗斯-莫斯科',C049:'加拿大-魁北克城',C050:'日本',C051:'法国-尼斯',C052:'芬兰-埃斯波',C053:'美国-肯特',C054:'日本-宫城',C055:'俄罗斯-索契',C056:'日本',C057:'日本-大阪',C058:'加拿大-伦敦（安大略）',C059:'芬兰-埃斯波',C060:'加拿大-圣约翰',C061:'法国-巴黎',C062:'日本-福冈',C063:'日本',C064:'俄罗斯-索契',C065:'俄罗斯-索契',C066:'日本-埼玉',C067:'中国-上海',C068:'日本-大阪',C069:'西班牙-巴塞罗那',C070:'日本',C071:'中国-上海',C072:'日本-东京',C073:'加拿大-巴里',C074:'加拿大-莱斯布里奇',C075:'日本-长野',C076:'西班牙-巴塞罗那',C077:'日本-札幌',C078:'美国-波士顿',C079:'加拿大-蒙特利尔',C080:'加拿大-密西沙加',C081:'日本-札幌',C082:'法国-马赛',C083:'韩国-江陵',C084:'芬兰-赫尔辛基',C085:'日本-东京',C086:'加拿大-蒙特利尔',C087:'俄罗斯-莫斯科',C088:'韩国-平昌',C089:'加拿大-奥克维尔',C090:'芬兰-赫尔辛基',C091:'俄罗斯-莫斯科',C092:'日本-埼玉',C093:'加拿大-奥克维尔',C094:'加拿大-基洛纳',C095:'日本-札幌',C096:'意大利-都灵',C097:'日本',C098:'韩国-首尔',C099:'日本-长野',C100:'瑞典-斯德哥尔摩',C101:'日本-大阪',C102:'日本-埼玉',C103:'中国-北京'};
  const centers={Japan:{lon:138,lat:37},China:{lon:104,lat:35},Korea:{lon:127.8,lat:36.5},Canada:{lon:-106,lat:56},USA:{lon:-98,lat:39},Russia:{lon:60,lat:56},Finland:{lon:26,lat:64},Italy:{lon:12,lat:43},Spain:{lon:-3,lat:40},France:{lon:2,lat:46},Poland:{lon:19,lat:52},Croatia:{lon:16,lat:45.5},Denmark:{lon:10,lat:56},Sweden:{lon:16,lat:62},Germany:{lon:10.4,lat:51.2},Netherlands:{lon:5.3,lat:52.1},Bulgaria:{lon:25.5,lat:42.7}};
  const countryKeyMap={'日本':'Japan','中国':'China','韩国':'Korea','俄罗斯':'Russia','芬兰':'Finland','加拿大':'Canada','美国':'USA','法国':'France','意大利':'Italy','波兰':'Poland','克罗地亚':'Croatia','丹麦':'Denmark','瑞典':'Sweden','德国':'Germany','荷兰':'Netherlands','保加利亚':'Bulgaria','西班牙':'Spain'};
  const countryNames={
    zh:{Japan:'日本',China:'中国',Korea:'韩国',Russia:'俄罗斯',Finland:'芬兰',Canada:'加拿大',USA:'美国',France:'法国',Italy:'意大利',Poland:'波兰',Croatia:'克罗地亚',Denmark:'丹麦',Sweden:'瑞典',Germany:'德国',Netherlands:'荷兰',Bulgaria:'保加利亚',Spain:'西班牙'},
    en:{Japan:'Japan',China:'China',Korea:'South Korea',Russia:'Russia',Finland:'Finland',Canada:'Canada',USA:'United States',France:'France',Italy:'Italy',Poland:'Poland',Croatia:'Croatia',Denmark:'Denmark',Sweden:'Sweden',Germany:'Germany',Netherlands:'Netherlands',Bulgaria:'Bulgaria',Spain:'Spain'},
    ja:{Japan:'日本',China:'中国',Korea:'韓国',Russia:'ロシア',Finland:'フィンランド',Canada:'カナダ',USA:'アメリカ',France:'フランス',Italy:'イタリア',Poland:'ポーランド',Croatia:'クロアチア',Denmark:'デンマーク',Sweden:'スウェーデン',Germany:'ドイツ',Netherlands:'オランダ',Bulgaria:'ブルガリア',Spain:'スペイン'}
  };
  const cityNames={
    '坦佩雷':['坦佩雷','Tampere','タンペレ'],'香港':['香港','Hong Kong','香港'],'萨格勒布':['萨格勒布','Zagreb','ザグレブ'],'哥本哈根':['哥本哈根','Copenhagen','コペンハーゲン'],'梅拉诺':['梅拉诺','Merano','メラーノ'],'索菲亚':['索菲亚','Sofia','ソフィア'],'东京':['东京','Tokyo','東京'],'名古屋':['名古屋','Nagoya','名古屋'],'莫斯科':['莫斯科','Moscow','モスクワ'],'台北':['台北','Taipei','台北'],'奥伯斯多夫':['奥伯斯多夫','Oberstdorf','オーベルストドルフ'],'上海':['上海','Shanghai','上海'],'魁北克城':['魁北克城','Quebec City','ケベック・シティ'],'尼斯':['尼斯','Nice','ニース'],'埃斯波':['埃斯波','Espoo','エスポー'],'肯特':['肯特','Kent','ケント'],'宫城':['宫城','Miyagi','宮城'],'索契':['索契','Sochi','ソチ'],'大阪':['大阪','Osaka','大阪'],'伦敦（安大略）':['伦敦（安大略）','London, Ontario','ロンドン（オンタリオ）'],'圣约翰':['圣约翰','Saint John','セントジョン'],'巴黎':['巴黎','Paris','パリ'],'福冈':['福冈','Fukuoka','福岡'],'埼玉':['埼玉','Saitama','埼玉'],'巴塞罗那':['巴塞罗那','Barcelona','バルセロナ'],'巴里':['巴里','Barrie','バリー'],'莱斯布里奇':['莱斯布里奇','Lethbridge','レスブリッジ'],'长野':['长野','Nagano','長野'],'札幌':['札幌','Sapporo','札幌'],'波士顿':['波士顿','Boston','ボストン'],'蒙特利尔':['蒙特利尔','Montreal','モントリオール'],'密西沙加':['密西沙加','Mississauga','ミシサガ'],'马赛':['马赛','Marseille','マルセイユ'],'江陵':['江陵','Gangneung','江陵'],'赫尔辛基':['赫尔辛基','Helsinki','ヘルシンキ'],'平昌':['平昌','PyeongChang','平昌'],'奥克维尔':['奥克维尔','Oakville','オークビル'],'基洛纳':['基洛纳','Kelowna','ケロウナ'],'都灵':['都灵','Turin','トリノ'],'首尔':['首尔','Seoul','ソウル'],'斯德哥尔摩':['斯德哥尔摩','Stockholm','ストックホルム'],'北京':['北京','Beijing','北京'],'海牙':['海牙','The Hague','ハーグ'],'托伦':['托伦','Torun','トルン']
  };
  const text={
    zh:{count:(a,b)=>`找到 ${a} 条记录 · 显示 ${b} 条`,allCountry:'全部国家 / 地区',rank:'排名',score:'总分',node:'国家节点',badge:n=>`国家聚合 · ${n} 个国家节点`,lit:c=>`已点亮 ${c}`,load:'展开更多比赛'},
    en:{count:(a,b)=>`${a} records found · showing ${b}`,allCountry:'All countries / regions',rank:'Rank',score:'Total score',node:'Country node',badge:n=>`Country atlas · ${n} countries`,lit:c=>`${c} highlighted`,load:'Load more'},
    ja:{count:(a,b)=>`${a} 件 · ${b} 件表示`,allCountry:'すべての国・地域',rank:'順位',score:'総合得点',node:'国別ノード',badge:n=>`国別アトラス · ${n}か国`,lit:c=>`${c}を表示`,load:'さらに表示'}
  };
  const stageNames={
    zh:{'少年／青年组阶段':'少年／青年组阶段','成年组阶段':'成年组阶段'},
    en:{'少年／青年组阶段':'Novice / Junior era','成年组阶段':'Senior era'},
    ja:{'少年／青年组阶段':'ノービス／ジュニア期','成年组阶段':'シニア期'}
  };
  const typeNames={
    zh:{'Domestic / Regional':'国内／地区赛','International Competition':'国际赛事','Japan Novice Nationals':'日本Novice全国赛','Japan Junior Nationals':'日本青年锦标赛','Japan Nationals':'日本全国锦标赛','Junior Grand Prix':'青年大奖赛','Junior Grand Prix Final':'青年大奖赛总决赛','World Junior Championships':'世界青年锦标赛','Grand Prix':'大奖赛','Grand Prix Final':'大奖赛总决赛','Four Continents Championships':'四大洲锦标赛','World Championships':'世界锦标赛','Olympic Games':'冬奥会','Challenger Series':'挑战者系列','World Team Trophy':'世界团体赛','Other Competition':'其他赛事'},
    en:{},
    ja:{'Domestic / Regional':'国内／地域大会','International Competition':'国際大会','Japan Novice Nationals':'全日本ノービス','Japan Junior Nationals':'全日本ジュニア','Japan Nationals':'全日本選手権','Junior Grand Prix':'ジュニアグランプリ','Junior Grand Prix Final':'ジュニアGPファイナル','World Junior Championships':'世界ジュニア選手権','Grand Prix':'グランプリシリーズ','Grand Prix Final':'グランプリファイナル','Four Continents Championships':'四大陸選手権','World Championships':'世界選手権','Olympic Games':'オリンピック','Challenger Series':'チャレンジャーシリーズ','World Team Trophy':'世界国別対抗戦','Other Competition':'その他の大会'}
  };
  const levelNames={zh:{Senior:'成年组',Junior:'青年组',Novice:'少年组'},en:{Senior:'Senior',Junior:'Junior',Novice:'Novice'},ja:{Senior:'シニア',Junior:'ジュニア',Novice:'ノービス'}};
  let limit=10;
  function lang(){const v=document.documentElement.dataset.lang||document.querySelector('#languageSelect')?.value||'zh';return v==='en'||v==='ja'?v:'zh'}
  function applyLoc(){if(typeof competitions==='undefined')return;competitions.forEach(c=>{if(exact[c.id])c.location=exact[c.id]})}
  function rawCountry(raw){return String(raw||'').split('-')[0]}
  function keyOf(raw){return countryKeyMap[rawCountry(raw)]||rawCountry(raw)}
  function cityOf(raw){return String(raw||'').includes('-')?String(raw).split('-').slice(1).join('-'):''}
  function locLabel(raw,l=lang()){const k=keyOf(raw),city=cityOf(raw);const c=countryNames[l][k]||k;if(!city)return c;const arr=cityNames[city];const cityLabel=arr?arr[l==='zh'?0:l==='en'?1:2]:city;return `${c} · ${cityLabel}`}
  function typeLabel(v,l=lang()){return (typeNames[l]&&typeNames[l][v])||v||'—'}
  function stageLabel(v,l=lang()){return (stageNames[l]&&stageNames[l][v])||v||'—'}
  function levelLabel(v,l=lang()){return (levelNames[l]&&levelNames[l][v])||v||'—'}
  function compName(c,l=lang()){return l==='zh'?(c.name||c.nameEn||c.id):(c.nameEn||c.name||c.id)}
  function medalLabel(c,l=lang()){if(c.medal==='Gold')return l==='zh'?'金牌':l==='ja'?'金':'Gold';if(c.medal==='Silver')return l==='zh'?'银牌':l==='ja'?'銀':'Silver';if(c.medal==='Bronze')return l==='zh'?'铜牌':l==='ja'?'銅':'Bronze';return c.rank!=null?(l==='zh'?`第 ${c.rank} 名`:l==='ja'?`${c.rank}位`:`Rank ${c.rank}`):'—'}
  function filtered(){applyLoc();const q=($('#compSearch')?.value||'').trim().toLowerCase(),y=$('#compYear')?.value||'all',st=$('#compStage')?.value||'all',ty=$('#compType')?.value||'all',lo=$('#compLocation')?.value||'all',me=$('#compMedal')?.value||'all';return (competitions||[]).filter(c=>(!q||[c.id,c.season,c.nameEn,c.name,c.type,c.level,c.location,locLabel(c.location,'en'),locLabel(c.location,'ja')].join(' ').toLowerCase().includes(q))&&(y==='all'||String(c.year)===y)&&(st==='all'||c.stage===st)&&(ty==='all'||c.type===ty)&&(lo==='all'||keyOf(c.location)===lo)&&(me==='all'||(me==='none'?!c.medal:c.medal===me)))}
  function byCountry(list){const m=new Map();list.forEach(c=>{const key=keyOf(c.location);if(!centers[key])return;const r=m.get(key)||{key,events:[],cities:new Set()};r.events.push(c);if(cityOf(c.location))r.cities.add(cityOf(c.location));m.set(key,r)});return m}
  function fillSelect(id,items,allText,labeler){const el=$('#'+id);if(!el)return;const current=el.value||'all';el.innerHTML=`<option value="all">${allText}</option>`+items.map(v=>`<option value="${String(v).replace(/"/g,'&quot;')}">${labeler(v)}</option>`).join('');if([...el.options].some(o=>o.value===current))el.value=current}
  function populateFilters(){applyLoc();const l=lang();fillSelect('compYear',[...new Set(competitions.map(c=>c.year))].sort((a,b)=>a-b),l==='zh'?'全部年份':l==='ja'?'すべての年':'All years',v=>v);fillSelect('compStage',[...new Set(competitions.map(c=>c.stage))],l==='zh'?'全部阶段':l==='ja'?'すべての段階':'All stages',v=>stageLabel(v,l));fillSelect('compType',[...new Set(competitions.map(c=>c.type))].sort(),l==='zh'?'全部类型':l==='ja'?'すべての種別':'All types',v=>typeLabel(v,l));fillSelect('compLocation',[...new Set(competitions.map(c=>keyOf(c.location)))].sort(),text[l].allCountry,v=>countryNames[l][v]||v);const medal=$('#compMedal');if(medal){const cur=medal.value||'all';medal.innerHTML=`<option value="all">${l==='zh'?'全部成绩':l==='ja'?'すべての成績':'All results'}</option><option value="Gold">${l==='zh'?'金牌':l==='ja'?'金':'Gold'}</option><option value="Silver">${l==='zh'?'银牌':l==='ja'?'銀':'Silver'}</option><option value="Bronze">${l==='zh'?'铜牌':l==='ja'?'銅':'Bronze'}</option><option value="none">${l==='zh'?'非领奖台／无排名':l==='ja'?'表彰台外／順位なし':'No podium / no rank'}</option>`;if([...medal.options].some(o=>o.value===cur))medal.value=cur}const search=$('#compSearch');if(search)search.placeholder=l==='zh'?'搜索比赛名、赛季、编号……':l==='ja'?'大会名、シーズン、IDで検索…':'Search event, season, or ID…';const more=$('#loadMoreCompetitions');if(more)more.textContent=text[l].load}
  function row(c){const l=lang();return `<article class="competition-row" data-comp-id="${c.id}" tabindex="0"><div class="comp-year">${c.year}</div><div class="comp-name"><b>${compName(c,l)}</b><span>${c.season} · ${stageLabel(c.stage,l)} · ${levelLabel(c.level,l)} · ${c.id}${c.worldRecord?' · WR':''}</span></div><div class="comp-type">${typeLabel(c.type,l)}</div><div class="comp-location">${locLabel(c.location,l)}</div><div class="comp-result"><span class="medal ${c.medal||''}">${medalLabel(c,l)}</span>${c.score!=null?`<span class="comp-location">${Number(c.score).toFixed(2)}</span>`:''}</div></article>`}
  function render(reset=false){if(reset)limit=10;populateFilters();const list=filtered(),n=Math.min(limit,list.length),l=lang();const count=$('#compCount'),box=$('#competitionList');if(count)count.textContent=text[l].count(list.length,n);if(box)box.innerHTML=list.slice(0,n).map(row).join('');$$('#competitionList [data-comp-id]').forEach(el=>{const open=()=>window.openCompetition?.(el.dataset.compId);el.addEventListener('click',open,{once:false});el.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' ')open()})});const more=$('#loadMoreCompetitions');if(more)more.style.display=n<list.length?'block':'none';paintMap(list)}
  function pos(stage,svg,lon,lat){const vb=svg.viewBox.baseVal,sw=stage.clientWidth||1,sh=stage.clientHeight||1,sc=Math.min(sw/vb.width,sh/vb.height),ox=(sw-vb.width*sc)/2,oy=(sh-vb.height*sc)/2,x=(lon+180)/360*vb.width,y=(90-lat)/180*vb.height;return{left:(ox+x*sc)/sw*100,top:(oy+y*sc)/sh*100}}
  function paintMap(currentList){const stage=$('.world-map-stage'),svg=$('.nb-world-map'),pins=$('#competitionMapPins'),strip=$('#competitionMapEvents'),badge=$('#competitionMapBadge');if(!stage||!svg||!pins)return;applyLoc();const all=byCountry(competitions),list=Array.isArray(currentList)?currentList:filtered(),active=byCountry(list),selected=$('#compLocation')?.value||'all',l=lang();pins.innerHTML='';all.forEach(r=>{const shown=active.get(r.key)||r;const p=pos(stage,svg,centers[r.key].lon,centers[r.key].lat);const b=document.createElement('button');b.className='ultimate-country-pin'+(active.has(r.key)||selected===r.key?' active':'');b.style.left=p.left+'%';b.style.top=p.top+'%';b.dataset.finalCountry=r.key;b.setAttribute('aria-label',countryNames[l][r.key]||r.key);b.innerHTML=`<span class="dot"></span><span class="num">${shown.events.length}</span><span class="lab">${countryNames[l][r.key]||r.key}</span>`;pins.appendChild(b)});if(badge)badge.textContent=selected==='all'?text[l].badge(all.size):`${text[l].lit(countryNames[l][selected]||selected)} · ${list.length}`;if(strip){const rows=[...(list.length?active:all).values()].sort((a,b)=>b.events.length-a.events.length);strip.classList.add('country-summary');strip.innerHTML=rows.map(r=>`<button class="map-country-card ${selected===r.key?'active':''}" data-final-country="${r.key}"><span>${text[l].node}</span><b>${countryNames[l][r.key]||r.key} · ${r.events.length}</b><em>${[...r.cities].slice(0,4).map(c=>(cityNames[c]||[c,c,c])[l==='zh'?0:l==='en'?1:2]).join(' / ')}</em></button>`).join('')}}
  function bind(){['compSearch','compYear','compStage','compType','compLocation','compMedal'].forEach(id=>{const el=$('#'+id);if(!el||el.dataset.cleanCompBound)return;el.dataset.cleanCompBound='1';el.addEventListener(id==='compSearch'?'input':'change',e=>{e.stopImmediatePropagation();render(true)},true)});const more=$('#loadMoreCompetitions');if(more&&!more.dataset.cleanCompBound){more.dataset.cleanCompBound='1';more.addEventListener('click',e=>{e.preventDefault();e.stopImmediatePropagation();limit+=10;render(false)},true)}window.addEventListener('resize',()=>paintMap())}
  window.renderCompetitions=render;window.paintCountryMap=paintMap;window.__hanyuCompetitionRefresh=()=>render(false);window.__hanyuCompetitionTypeLabel=(v,l=lang())=>typeLabel(v,l);window.__hanyuCompetitionStageLabel=(v,l=lang())=>stageLabel(v,l);window.__hanyuCompetitionLevelLabel=(v,l=lang())=>levelLabel(v,l);window.__hanyuCompetitionLocationLabel=(v,l=lang())=>locLabel(v,l);
  bind();render(false);
})();
</script>





<script id="final-clean-ice-show-map-script">
(function(){
  "use strict";
  if(window.__hanyuShowRuntime)return;
  window.__hanyuShowRuntime=true;
  const $=(s,r=document)=>r.querySelector(s), $$=(s,r=document)=>Array.from(r.querySelectorAll(s));
  const meta={yokohama:{labels:['横滨','Yokohama','横浜'],x:52.4,y:50.6,pref:'JP14'},tokyo:{labels:['东京','Tokyo','東京'],x:52.7,y:49.6,pref:'JP13'},saitama:{labels:['埼玉','Saitama','埼玉'],x:52.5,y:48.1,pref:'JP11'},chiba:{labels:['千叶／船桥','Chiba / Funabashi','千葉／船橋'],x:55,y:50.9,pref:'JP12'},miyagi:{labels:['宫城','Miyagi','宮城'],x:57.1,y:37,pref:'JP04'},hachinohe:{labels:['八户','Hachinohe','八戸'],x:56.2,y:27.6,pref:'JP02'},saga:{labels:['佐贺','Saga','佐賀'],x:25.5,y:59.6,pref:'JP41'},hiroshima:{labels:['广岛','Hiroshima','広島'],x:33.7,y:54,pref:'JP34'},kanazawa:{labels:['石川／金泽','Ishikawa / Kanazawa','石川／金沢'],x:44.5,y:46.8,pref:'JP17'}};
  const lang=()=>{const v=document.documentElement.dataset.lang||'zh';return v==='en'||v==='ja'?v:'zh'},idx=()=>lang()==='zh'?0:lang()==='en'?1:2;
  const labels={zh:{archive:'演出档案',hint:'点击任意场次进入对应冰演详情',atlas:'日本矢量边界图',map:'职业冰演宇宙 · 日本地图',intro:'完整日本矢量边界图标出 PROLOGUE、GIFT、RE_PRAY、notte stellata、Echoes of Life 等职业冰演抵达过的城市。筛选冰演系列后，对应城市与都道府县会点亮。'},en:{archive:'Performance archive',hint:'Select a performance to open its ice-show details',atlas:'Japan vector boundary atlas',map:'Professional Ice Show Universe · Japan Map',intro:'The full vector map of Japan marks cities reached by PROLOGUE, GIFT, RE_PRAY, notte stellata, Echoes of Life, and other professional shows. Filtering a series highlights the corresponding cities and prefectures.'},ja:{archive:'公演アーカイブ',hint:'公演を選択してアイスショー詳細を表示',atlas:'日本ベクター境界地図',map:'プロアイスショーの世界 · 日本マップ',intro:'日本のベクター境界地図に、PROLOGUE、GIFT、RE_PRAY、notte stellata、Echoes of Life などのプロ公演が訪れた都市を表示します。シリーズを絞り込むと、対応する都市と都道府県が点灯します。'}};
  function venueLabel(raw,l=lang()){let v=String(raw||'');const map={en:{'ぴあアリーナMM':'PIA Arena MM','石川／金泽地区':'Ishikawa / Kanazawa area','石川／金沢地区':'Ishikawa / Kanazawa area','セキスイハイムスーパーアリーナ':'Sekisui Heim Super Arena','さいたまスーパーアリーナ':'Saitama Super Arena'},ja:{'石川／金泽地区':'石川／金沢地域','石川／金沢地区':'石川／金沢地域'},zh:{'石川／金沢地区':'石川／金泽地区'}};return map[l]?.[v]||v}
  function active(){return $('[data-show-filter].active')?.dataset.showFilter||'all'}
  function list(){const f=active();return (typeof shows!=='undefined'?shows:[]).filter(s=>f==='all'||(f==='2026'&&String(s.year).includes('2026'))||s.category===f)}
  function city(s,p){const id=String(s.id||'').toLowerCase(),v=String(p?.[1]||'').toLowerCase();if(id==='gift')return'tokyo';if(id==='notte'||id==='realive')return'miyagi';if(id==='charity')return'kanazawa';if(id==='prologue')return/hachinohe|flat/.test(v)?'hachinohe':'yokohama';if(id==='repray'){if(/saga/.test(v))return'saga';if(/yokohama|pia/.test(v))return'yokohama';if(/sekisui|miyagi/.test(v))return'miyagi';return'saitama'}if(id==='echoes'){if(/hiroshima/.test(v))return'hiroshima';if(/lala|tokyo-bay|funabashi|chiba/.test(v))return'chiba';return'saitama'}return'tokyo'}
  function rows(){const out=[];list().forEach(s=>(s.performances||[]).forEach(p=>out.push({s,p,city:city(s,p)})));return out}
  function renderEvents(items,cityKey){const box=$('#showMapEvents');if(!box)return;const l=lang(),i=idx(),sorted=items.slice().sort((a,b)=>String(a.p[0]).localeCompare(String(b.p[0])));const head=cityKey?`<div class="ice-japan-event city-summary"><span>${labels[l].archive} · ${meta[cityKey].labels[i]} · ${sorted.length}</span><b>${[...new Set(sorted.map(r=>r.s.title))].join(' / ')}</b><em>${labels[l].hint}</em></div>`:'';box.innerHTML=head+sorted.map(r=>`<div class="ice-japan-event" data-clean-show-id="${r.s.id}"><span>${r.p[0]} · ${meta[r.city].labels[i]}</span><b>${r.s.title}</b><em>${venueLabel(r.p[1],l)}</em></div>`).join('');$$('[data-clean-show-id]').forEach(el=>el.addEventListener('click',()=>window.openShow?.(el.dataset.cleanShowId)))}
  function repaint(){const pinBox=$('#showMapPins');if(!pinBox)return;const l=lang(),i=idx(),rs=rows(),groups=new Map();rs.forEach(r=>{const a=groups.get(r.city)||[];a.push(r);groups.set(r.city,a)});pinBox.innerHTML='';$$('.nb-japan-map [id]').forEach(el=>el.classList.remove('active-pref'));groups.forEach((items,key)=>{const m=meta[key];if(!m)return;const b=document.createElement('button');b.className='map-pin active clean-show-pin';b.style.left=m.x+'%';b.style.top=m.y+'%';b.title=`${m.labels[i]} · ${items.length}`;b.innerHTML=`<i></i><b>${m.labels[i]}</b><small>${items.length}</small>`;b.addEventListener('click',e=>{e.preventDefault();renderEvents(items,key)});pinBox.appendChild(b);$('.nb-japan-map #'+m.pref)?.classList.add('active-pref')});renderEvents(rs);const copy=$('.show-map-side');if(copy){$('.section-label',copy)&&($('.section-label',copy).textContent=labels[l].atlas);$('h3',copy)&&($('h3',copy).textContent=labels[l].map);$('p',copy)&&($('p',copy).textContent=labels[l].intro)}}
  function refreshDynamic(){window.__hanyuRefreshDynamicLanguage?.();window.__hanyuActivatePageImages?.()}
  $$('[data-show-filter]').forEach(btn=>{if(btn.dataset.cleanShowBound)return;btn.dataset.cleanShowBound='1';btn.addEventListener('click',e=>{e.preventDefault();e.stopImmediatePropagation();$$('[data-show-filter]').forEach(x=>x.classList.toggle('active',x===btn));renderPosters(btn.dataset.showFilter);repaint();refreshDynamic()},true)});
  $$('[data-mile-filter]').forEach(btn=>{if(btn.dataset.cleanMilestoneBound)return;btn.dataset.cleanMilestoneBound='1';btn.addEventListener('click',e=>{e.preventDefault();e.stopImmediatePropagation();$$('[data-mile-filter]').forEach(x=>x.classList.toggle('active',x===btn));renderMilestones(btn.dataset.mileFilter);refreshDynamic()},true)});
  window.__hanyuRenderShowMap=repaint;repaint();
})();
</script>



<style id="final-show-map-pins-visible-style">
.japan-map-stage{position:relative!important}
#showMapPins{position:absolute!important;inset:0!important;z-index:20!important;pointer-events:none!important}
#showMapPins .map-pin{pointer-events:auto!important}
.ice-japan-event.city-summary{border-color:rgba(78,232,255,.42)!important;background:linear-gradient(135deg,rgba(78,232,255,.10),rgba(255,255,255,.035))!important}
</style>




<script id="unified-language-system">
(function(){
  "use strict";

  const $ = (sel, root = document) => root.querySelector(sel);

  const names = { zh: "羽生结弦", en: "Yuzuru Hanyu", ja: "羽生結弦" };
  const STATIC_I18N = {
    zh: {
      overview: ["生涯轨迹与里程碑", "从仙台到世界，从竞技到 ICE STORY", "这里把生涯总览与关键里程碑合并成一座前厅：先看他如何穿越少年、成年组、冬奥、世界纪录与职业创作，再进入完整比赛档案和职业冰演宇宙。"],
      arc: ["冰上轨迹", "一条不是直线的冰上轨迹", "竞技记录在 2009 年进入高密度阶段；2014 与 2018 的冬奥金牌把名字推向世界中心；2022 年后，数据重心转向由本人主导的个人冰演与叙事型 ICE STORY。这里不再只是一张统计图，而是一条不断拓展表达边界的生命轨道。"],
      steps: ["1994 仙台", "1999 开始滑冰", "2014 / 2018 冬奥", "2022 职业转向", "2026 仍在延展"],
      peak: ["巅峰信号", "竞技峰值与职业峰值并置", "最高总分、世界纪录与职业冰演场次共同构成这座数字展馆的主骨架。", "世界纪录标记", "2024 职业冰演场次", "当前比赛档案"],
      milestone: "关键里程碑",
      profile: ["传奇背后的人", "一个人的时间，如何成为一代人的星光", "从仙台的少年，到两届冬奥冠军，再到以身体、文字、音乐与冰面构筑世界的创作者。这一页记录成绩之外的生命轨迹。", "人物生平", "他的轨迹并不是一条只通向奖牌的直线。它穿过伤病、震灾、世界纪录与万众注视，也穿过一次次重新理解“为何滑冰”的时刻。竞技时代结束以后，冰面没有成为过去——它被扩展成剧场、记忆、祈愿与仍在书写的未来。"],
      producer: "制作人 · momoka1207"
    },
    en: {
      overview: ["Life trajectory & milestones", "From Sendai to the world, from competition to ICE STORY", "Career overview and key milestones share one exhibition hall: from junior and senior competition through the Olympic Games and world records, then onward to professional creation, the complete competition archive and the universe of professional ice shows."],
      arc: ["Arc of the legacy", "An icebound path that was never a straight line", "Competition intensified from 2009. Olympic gold in 2014 and 2018 carried his name to the world stage; after 2022, the focus shifted toward self-produced solo shows and narrative ICE STORY works. This is not merely a chart, but a life trajectory that keeps expanding the boundaries of expression."],
      steps: ["1994 Sendai", "1999 Began skating", "2014 / 2018 Olympics", "2022 Turned professional", "2026 Still evolving"],
      peak: ["Peak signals", "Competitive and professional peaks, side by side", "Highest scores, world records and professional ice-show performances form the backbone of this digital exhibition.", "World-record marks", "2024 professional shows", "Competition archive"],
      milestone: "Key Milestones",
      profile: ["The person behind the legend", "How one life became a light for a generation", "From a boy in Sendai to a two-time Olympic champion and a creator who builds worlds through body, words, music and ice, this page follows the life beyond the results.", "Biography", "His path was never a straight line toward medals alone. It passed through injury, disaster, world records and the gaze of millions, and through repeated questions about why he skates. When the competitive era ended, the ice did not become the past; it expanded into theatre, memory, prayer and a future still being written."],
      producer: "Produced by · momoka1207"

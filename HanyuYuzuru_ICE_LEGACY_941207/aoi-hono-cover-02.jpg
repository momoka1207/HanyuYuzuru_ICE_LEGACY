<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <script id="language-head-init">
  (function(){
    var saved="zh";
    try { saved=localStorage.getItem("hanyuLang") || "zh"; } catch(e) {}
    if (["zh","en","ja"].indexOf(saved) < 0) saved="zh";
    document.documentElement.dataset.lang=saved;
    document.documentElement.lang=saved==="zh" ? "zh-CN" : saved;
  })();
  </script>
  <link rel="preload" as="image" href="assets/inline-00-b3683d2dba.jpg" fetchpriority="high">
  <meta name="description" content="羽生结弦 1994–2026 生涯数据与职业冰演数字展馆">
  <title>羽生结弦 ICE LEGACY｜主页</title>
  <style id="paged-critical-route">
  html{scroll-behavior:auto!important}
  body.paged-page.is-page-leaving{visibility:visible!important}
  body.paged-page .hero,body.paged-page #overview,body.paged-page #profile,body.paged-page #competitions,body.paged-page #shows,body.paged-page #costumes,body.paged-page #sources{display:none!important}
  body.page-home .hero{display:flex!important}
  body.page-home #overview,body.page-profile #profile,body.page-competition #competitions,body.page-shows #shows,body.page-costumes #costumes,body.page-sources #sources{display:block!important}
</style>
  <style>
    :root{--night:#020912;--deep:#071728;--navy:#0b2741;--blue:#287dab;--ice:#bcecff;--white:#f7fcff;--muted:#9db4c6;--gold:#e8c779;--orange:#f1874b;--line:rgba(180,224,246,.17);--glass:rgba(8,28,47,.72)}
    *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--night);color:var(--white);font-family:"Microsoft YaHei","PingFang SC",Arial,sans-serif;overflow-x:hidden}
    body:before{content:"";position:fixed;inset:0;pointer-events:none;background:radial-gradient(circle at 15% 20%,rgba(44,134,181,.18),transparent 34%),radial-gradient(circle at 88% 40%,rgba(121,91,185,.15),transparent 28%),linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);background-size:auto,auto,80px 80px,80px 80px;z-index:-2}
    a{color:inherit}.topbar{height:62px;position:sticky;top:0;z-index:30;display:flex;align-items:center;justify-content:space-between;padding:0 max(20px,calc((100vw - 1280px)/2));background:rgba(2,9,18,.78);backdrop-filter:blur(18px);border-bottom:1px solid var(--line)}.brand{font-weight:800;letter-spacing:.1em}.brand span{color:var(--ice)}nav{display:flex;gap:20px}nav a{text-decoration:none;font-size:12px;color:#b9cad6;transition:.2s}nav a:hover{color:#fff}.source-chip{font-size:10px;border:1px solid rgba(188,236,255,.35);border-radius:99px;padding:7px 10px;color:var(--ice)}
    .hero{min-height:760px;position:relative;display:flex;align-items:center;overflow:hidden;border-bottom:1px solid var(--line)}.hero-bg{position:absolute;inset:0;background:linear-gradient(90deg,rgba(2,9,18,.97) 0%,rgba(2,9,18,.76) 48%,rgba(2,9,18,.3) 100%),url('assets/inline-00-534d0f3814.jpg') center 24%/cover no-repeat;filter:saturate(.8)}.hero-bg:after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,var(--night),transparent 38%),radial-gradient(circle at 73% 43%,transparent 0,rgba(3,9,16,.25) 45%,rgba(2,9,18,.75) 82%)}.orbit{position:absolute;border:1px solid rgba(188,236,255,.12);border-radius:50%;width:560px;height:560px;right:6vw;top:90px;box-shadow:0 0 0 70px rgba(188,236,255,.025),0 0 0 140px rgba(188,236,255,.015);animation:float 8s ease-in-out infinite}@keyframes float{50%{transform:translateY(-12px) rotate(4deg)}}
    .hero-content{position:relative;width:min(1280px,calc(100% - 40px));margin:auto;padding:90px 0}.kicker{font-size:12px;letter-spacing:.35em;text-transform:uppercase;color:var(--ice)}h1{font-size:clamp(54px,8.5vw,118px);line-height:.9;margin:20px 0 18px;letter-spacing:-.055em;max-width:900px;text-shadow:0 18px 70px rgba(0,0,0,.5)}h1 small{display:block;font-size:.23em;letter-spacing:.35em;color:#cdefff;margin-top:22px}.hero-copy{max-width:690px;font-size:16px;line-height:1.9;color:#c4d3dd}.hero-actions{display:flex;gap:12px;margin-top:28px;flex-wrap:wrap}.btn{border:1px solid rgba(188,236,255,.35);background:rgba(188,236,255,.08);color:#fff;border-radius:999px;padding:12px 18px;text-decoration:none;font-size:12px;cursor:pointer;transition:.25s}.btn.primary{background:linear-gradient(135deg,#2b87b6,#5f55a7);border:0}.btn:hover{transform:translateY(-2px);box-shadow:0 10px 35px rgba(37,126,174,.25)}
    .hero-stats{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;position:absolute;left:0;right:0;bottom:0;background:var(--line);border-top:1px solid var(--line)}.hero-stat{padding:18px 24px;background:rgba(3,13,23,.82);backdrop-filter:blur(14px)}.hero-stat b{font-size:26px;display:block}.hero-stat span{font-size:10px;color:var(--muted);letter-spacing:.12em}
    .wrap{width:min(1280px,calc(100% - 40px));margin:auto}.section{padding:92px 0}.section-head{display:flex;justify-content:space-between;gap:30px;align-items:end;margin-bottom:32px}.section-label{font-size:10px;letter-spacing:.28em;color:var(--ice);text-transform:uppercase}.section h2{font-size:clamp(30px,4vw,54px);margin:8px 0 0;letter-spacing:-.04em}.section-intro{max-width:470px;color:var(--muted);line-height:1.8;font-size:13px}.glass{background:linear-gradient(145deg,rgba(12,39,62,.82),rgba(5,20,35,.68));border:1px solid var(--line);border-radius:20px;box-shadow:0 25px 80px rgba(0,0,0,.22);backdrop-filter:blur(14px)}
    .overview-grid{display:grid;grid-template-columns:1.4fr .6fr;gap:18px}.chart-panel{padding:22px}.chart-head{display:flex;align-items:start;justify-content:space-between;gap:20px}.chart-head h3{font-size:16px;margin:0}.chart-head p{font-size:11px;color:var(--muted);margin:5px 0}.legend{display:flex;gap:12px;font-size:10px;color:var(--muted)}.legend span:before{content:"";display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--c);margin-right:5px}.chart{height:360px}.chart svg{width:100%;height:100%;overflow:visible}.axis{stroke:#4a6070}.gridline{stroke:rgba(190,225,241,.1)}.axis-text{fill:#7891a3;font-size:10px}.line{fill:none;stroke-width:3.2;stroke-linecap:round;stroke-linejoin:round;filter:drop-shadow(0 0 7px currentColor)}.dot{stroke:#071728;stroke-width:2;cursor:pointer}
    .insight{padding:24px;display:flex;flex-direction:column;justify-content:space-between;min-height:420px;background:radial-gradient(circle at 80% 10%,rgba(232,199,121,.18),transparent 34%),linear-gradient(150deg,rgba(18,50,74,.88),rgba(6,21,36,.78))}.insight .big{font-size:76px;font-weight:900;color:var(--gold);line-height:1}.insight h3{font-size:24px;margin:12px 0}.insight p{color:#b8c9d5;line-height:1.8;font-size:13px}.mini-list{display:grid;gap:10px}.mini{display:flex;justify-content:space-between;border-top:1px solid var(--line);padding-top:10px;font-size:11px;color:var(--muted)}.mini b{color:#fff;font-size:14px}
    .filters{display:flex;gap:8px;flex-wrap:wrap}.filter{border:1px solid var(--line);background:rgba(255,255,255,.035);color:#b8cad7;padding:8px 13px;border-radius:99px;cursor:pointer;font-size:11px;transition:.2s}.filter.active,.filter:hover{color:#05121f;background:var(--ice);border-color:var(--ice)}
    .poster-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}.poster{grid-column:span 4;min-height:440px;border:1px solid var(--line);border-radius:18px;overflow:hidden;position:relative;cursor:pointer;background:#071728;isolation:isolate;transition:.35s}.poster:nth-child(1),.poster:nth-child(4){grid-column:span 6}.poster:hover{transform:translateY(-7px);border-color:rgba(188,236,255,.45);box-shadow:0 24px 70px rgba(1,8,14,.65)}.poster img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:.7s}.poster:hover img{transform:scale(1.04)}.poster:after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,rgba(2,8,15,.98) 0%,rgba(2,8,15,.72) 37%,rgba(2,8,15,.12) 74%),linear-gradient(120deg,rgba(15,87,126,.16),transparent);z-index:1}.poster-content{position:absolute;z-index:2;left:22px;right:22px;bottom:20px}.poster-meta{display:flex;justify-content:space-between;gap:10px;color:#9eb6c6;font-size:10px;text-transform:uppercase;letter-spacing:.1em}.poster h3{font-size:25px;margin:10px 0 8px}.poster p{font-size:11px;line-height:1.6;color:#b7c8d3;margin:0}.poster .arrow{position:absolute;right:20px;top:20px;z-index:2;width:38px;height:38px;border:1px solid rgba(255,255,255,.28);border-radius:50%;display:grid;place-items:center;background:rgba(0,0,0,.2);backdrop-filter:blur(10px)}
    .milestone-controls{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:22px}.milestone-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.milestone-card{min-height:280px;border:1px solid var(--line);border-radius:16px;overflow:hidden;position:relative;cursor:pointer;background:#091b2b;transition:.3s}.milestone-card:hover{transform:translateY(-5px);border-color:rgba(232,199,121,.45)}.milestone-card img{width:100%;height:150px;object-fit:cover;filter:saturate(.78)}.milestone-body{padding:16px}.milestone-year{font-size:11px;color:var(--gold);letter-spacing:.14em}.milestone-card h3{font-size:16px;margin:7px 0}.milestone-card p{font-size:11px;line-height:1.6;color:var(--muted);margin:0}.empty{grid-column:1/-1;padding:40px;text-align:center;color:var(--muted)}
    .audit{display:grid;grid-template-columns:1fr 1fr;gap:18px}.audit-card{padding:26px}.audit-card h3{margin:0 0 12px}.audit-card p{color:var(--muted);line-height:1.75;font-size:12px}.source-list{display:grid;gap:9px}.source-list a{display:flex;justify-content:space-between;gap:12px;padding:11px 0;border-top:1px solid var(--line);text-decoration:none;font-size:11px;color:#c5d5df}.source-list a:hover{color:var(--ice)}
    footer{border-top:1px solid var(--line);padding:34px 20px;text-align:center;color:#6e8799;font-size:10px}.tooltip{position:fixed;z-index:70;pointer-events:none;background:#f3fbff;color:#071728;border-radius:9px;padding:8px 10px;font-size:10px;box-shadow:0 8px 30px rgba(0,0,0,.4);opacity:0;transition:.12s}
    .modal{position:fixed;inset:0;z-index:60;background:rgba(0,5,10,.82);backdrop-filter:blur(16px);display:none;align-items:center;justify-content:center;padding:25px}.modal.open{display:flex}.modal-card{width:min(1120px,100%);max-height:92vh;overflow:auto;border:1px solid rgba(188,236,255,.24);border-radius:22px;background:#071625;box-shadow:0 40px 140px rgba(0,0,0,.7)}.modal-hero{height:390px;position:relative}.modal-hero img{width:100%;height:100%;object-fit:cover}.modal-hero:after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,#071625 0%,rgba(7,22,37,.28) 68%,rgba(7,22,37,.08))}.close{position:absolute;z-index:3;right:18px;top:18px;width:42px;height:42px;border-radius:50%;border:1px solid rgba(255,255,255,.3);background:rgba(0,0,0,.35);color:#fff;font-size:18px;cursor:pointer}.modal-title{position:absolute;z-index:2;left:30px;right:80px;bottom:24px}.modal-title .overline{font-size:10px;letter-spacing:.18em;color:var(--ice)}.modal-title h2{font-size:clamp(32px,5vw,62px);margin:8px 0}.modal-body{padding:0 30px 34px}.modal-copy{display:grid;grid-template-columns:1.2fr .8fr;gap:34px}.modal-copy p{font-size:13px;color:#b7c8d4;line-height:1.9}.official-link{display:inline-flex;margin-top:8px;text-decoration:none;border-bottom:1px solid var(--ice);padding-bottom:4px;color:var(--ice);font-size:12px}.schedule{margin-top:28px}.schedule h3{font-size:14px}.performance-list{display:grid;grid-template-columns:1fr 1fr;gap:8px}.performance{display:grid;grid-template-columns:76px 1fr;gap:12px;align-items:center;padding:8px;border:1px solid var(--line);border-radius:12px;background:rgba(255,255,255,.025)}.performance img{width:76px;height:54px;object-fit:cover;border-radius:8px}.performance b{font-size:11px}.performance span{display:block;color:var(--muted);font-size:10px;margin-top:4px}.facts{display:grid;gap:10px}.fact{border-top:1px solid var(--line);padding-top:10px}.fact span{display:block;color:var(--muted);font-size:9px;text-transform:uppercase;letter-spacing:.15em}.fact b{display:block;margin-top:5px;font-size:13px}
    @media(max-width:980px){nav{display:none}.hero{min-height:700px}.hero-stats{grid-template-columns:repeat(3,1fr)}.hero-stat:nth-child(n+4){display:none}.overview-grid{grid-template-columns:1fr}.poster,.poster:nth-child(1),.poster:nth-child(4){grid-column:span 6}.milestone-grid{grid-template-columns:repeat(2,1fr)}.audit{grid-template-columns:1fr}}
    @media(max-width:640px){.topbar{padding:0 14px}.source-chip{display:none}.hero-content,.wrap{width:calc(100% - 28px)}.hero{min-height:680px}.hero-bg{background-position:62% 20%}h1{font-size:58px}.hero-copy{font-size:13px}.section{padding:64px 0}.section-head{display:block}.section-intro{margin-top:14px}.hero-stats{grid-template-columns:repeat(2,1fr)}.hero-stat:nth-child(3){display:none}.poster,.poster:nth-child(1),.poster:nth-child(4){grid-column:span 12;min-height:420px}.milestone-grid{grid-template-columns:1fr}.milestone-controls{display:block}.milestone-controls .filters{margin-top:15px}.modal{padding:0}.modal-card{height:100vh;max-height:none;border-radius:0}.modal-hero{height:310px}.modal-body{padding:0 18px 28px}.modal-copy{grid-template-columns:1fr}.performance-list{grid-template-columns:1fr}.chart{height:300px}}
  /* MUSEUM_V3 */
.profile-grid{display:grid;grid-template-columns:.78fr 1.22fr;gap:18px}.portrait-panel{min-height:610px;position:relative;overflow:hidden}.portrait-panel img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}.portrait-panel:after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,#061522 2%,transparent 60%),linear-gradient(100deg,transparent,rgba(3,11,19,.45))}.portrait-caption{position:absolute;z-index:2;left:26px;right:26px;bottom:24px}.portrait-caption h3{font-size:34px;margin:6px 0}.profile-copy{padding:32px}.profile-copy .lead{font-size:19px;line-height:1.9;color:#e0edf4;margin:14px 0 22px}.life-line{display:grid;grid-template-columns:74px 1fr;gap:10px 16px;margin:24px 0}.life-line b{color:var(--gold);font-size:12px;padding-top:3px}.life-line span{color:var(--muted);font-size:12px;line-height:1.65;border-bottom:1px solid var(--line);padding-bottom:10px}.socials{display:flex;gap:9px;flex-wrap:wrap}.socials a{text-decoration:none;border:1px solid var(--line);border-radius:99px;padding:9px 13px;font-size:11px;color:var(--ice)}
.countdown{margin-top:18px;padding:22px;border-radius:16px;background:radial-gradient(circle at 15% 20%,rgba(232,199,121,.22),transparent 35%),rgba(255,255,255,.035);border:1px solid rgba(232,199,121,.25)}.countdown-title{display:flex;justify-content:space-between;color:#d6e4ed;font-size:11px}.countdown-clock{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:16px}.count-unit{padding:12px;text-align:center;background:rgba(2,9,18,.42);border-radius:11px}.count-unit b{font-size:28px;color:var(--gold);display:block}.count-unit span{font-size:9px;color:var(--muted);text-transform:uppercase}
.archive-shell{padding:22px}.archive-controls{display:grid;grid-template-columns:2fr repeat(5,1fr);gap:9px}.archive-controls input,.archive-controls select{width:100%;border:1px solid var(--line);background:#071522;color:#d7e7f0;border-radius:10px;padding:11px 12px;font:inherit;font-size:11px}.archive-controls option{background:#071522}.archive-summary{display:flex;justify-content:space-between;gap:14px;align-items:center;padding:18px 2px 12px;color:var(--muted);font-size:11px}.competition-list{display:grid;gap:7px}.competition-row{display:grid;grid-template-columns:70px minmax(230px,1.7fr) minmax(145px,.8fr) 100px 100px;gap:14px;align-items:center;padding:13px 14px;border:1px solid var(--line);border-radius:12px;background:rgba(255,255,255,.025);cursor:pointer;transition:.2s}.competition-row:hover{background:rgba(77,171,219,.08);border-color:rgba(188,236,255,.32);transform:translateX(3px)}.comp-year{font-weight:800;color:var(--gold)}.comp-name b{display:block;font-size:12px}.comp-name span,.comp-type,.comp-location{display:block;color:var(--muted);font-size:10px;margin-top:4px}.comp-result{text-align:right}.medal{display:inline-block;border-radius:99px;padding:4px 8px;font-size:9px;background:rgba(255,255,255,.06)}.medal.Gold{background:#e8c779;color:#201604}.medal.Silver{background:#ccd6df;color:#12202b}.medal.Bronze{background:#b97a55;color:#fff}.load-more{display:block;margin:18px auto 0}.photo-gap{margin-top:24px;border:1px dashed rgba(188,236,255,.22);border-radius:14px;padding:20px;text-align:center;color:var(--muted);font-size:11px}.modal-hero.no-photo{background:radial-gradient(circle at 20% 20%,rgba(73,165,211,.24),transparent 32%),linear-gradient(135deg,#0d2b45,#050c14)}.modal-hero.no-photo:before{content:"OFFICIAL EVENT IMAGE · TO BE VERIFIED";position:absolute;z-index:1;left:30px;top:42%;letter-spacing:.24em;color:rgba(188,236,255,.35);font-size:12px}.modal-hero.no-photo img{display:none}
.costume-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.costume{min-height:300px;border:1px solid var(--line);border-radius:16px;overflow:hidden;background:linear-gradient(155deg,rgba(28,75,105,.34),rgba(5,16,28,.9));position:relative}.costume-art{height:170px;display:grid;place-items:center;position:relative;background:radial-gradient(circle at 50% 45%,var(--tone,rgba(84,160,208,.28)),transparent 42%)}.costume-art:before{content:"";width:62px;height:132px;border-radius:48% 48% 24% 24%;background:linear-gradient(145deg,rgba(255,255,255,.15),rgba(255,255,255,.015));border:1px solid rgba(255,255,255,.12);filter:drop-shadow(0 0 18px var(--tone,rgba(84,160,208,.45)))}.costume-art span{position:absolute;bottom:12px;font-size:9px;letter-spacing:.15em;color:#819bad}.costume-body{padding:15px}.costume-body .season{font-size:9px;color:var(--gold);letter-spacing:.12em}.costume-body h3{font-size:15px;margin:7px 0}.costume-body p{font-size:10px;line-height:1.55;color:var(--muted);margin:0}.status-wait{display:inline-block;margin-top:10px;padding:4px 7px;border-radius:99px;background:rgba(241,135,75,.12);color:#f1a278;font-size:9px}
.guest-stage{display:grid;grid-template-columns:1.1fr .9fr;gap:18px}.guest-feature{padding:30px;min-height:330px;background:radial-gradient(circle at 80% 20%,rgba(117,78,178,.2),transparent 36%),linear-gradient(145deg,rgba(13,44,68,.9),rgba(5,17,29,.8))}.guest-feature h3{font-size:34px;margin:10px 0}.guest-feature p{max-width:680px;color:var(--muted);line-height:1.8;font-size:12px}.data-needed{padding:28px}.data-needed ul{padding-left:18px;color:var(--muted);line-height:2;font-size:11px}
@media(max-width:980px){.profile-grid,.guest-stage{grid-template-columns:1fr}.portrait-panel{min-height:520px}.archive-controls{grid-template-columns:1fr 1fr}.competition-row{grid-template-columns:60px 1fr 100px}.comp-type,.comp-location{display:none}.costume-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:640px){.archive-controls{grid-template-columns:1fr}.competition-row{grid-template-columns:50px 1fr 72px;gap:8px}.comp-result{font-size:10px}.costume-grid{grid-template-columns:1fr}.profile-copy{padding:22px}.countdown-clock{grid-template-columns:repeat(2,1fr)}}

</style>
<style id="visual-polish-round-2">
.hero-bg{background:linear-gradient(90deg,rgba(2,9,18,.99) 0%,rgba(2,9,18,.93) 30%,rgba(2,9,18,.54) 56%,rgba(2,9,18,.18) 100%),url('assets/inline-00-5a9aeb34ef.jpg') right center/auto 100% no-repeat!important;background-color:#03101c!important;filter:saturate(.92) contrast(1.03)}
.hero-credit,.portrait-credit{position:absolute;z-index:3;color:rgba(201,220,234,.68);font-size:9px;letter-spacing:.04em;text-decoration:none}
.hero-credit{right:22px;bottom:92px}.portrait-credit{right:18px;top:16px;max-width:220px;text-align:right}
.hero-credit:hover,.portrait-credit:hover{color:#fff}
.portrait-panel img{object-position:center 28%}
@media(max-width:640px){.hero-bg{background-position:66% center!important;background-size:auto 100%!important}.hero-credit{right:12px;bottom:70px;max-width:210px;text-align:right}.portrait-credit{top:12px;right:12px}}
</style><style id="childhood-producer-fix">
.producer-credit{position:absolute;z-index:4;right:24px;top:92px;color:var(--gold);font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;text-shadow:0 2px 12px rgba(0,0,0,.75)}
.milestone-card img{object-position:center top}
@media(max-width:640px){.producer-credit{right:12px;top:72px;font-size:9px}}
</style>





<style id="map-archive-enhancement">
.archive-map-deck,.show-map-deck{margin:20px 0 12px;border:1px solid rgba(188,236,255,.18);border-radius:24px;background:radial-gradient(circle at 76% 20%,rgba(86,199,242,.20),transparent 34%),linear-gradient(135deg,rgba(8,24,38,.94),rgba(3,9,17,.98));box-shadow:0 28px 80px rgba(0,0,0,.38),inset 0 0 42px rgba(76,178,235,.08);overflow:hidden;position:relative}
.archive-map-deck:before,.show-map-deck:before{content:"";position:absolute;inset:0;background-image:linear-gradient(rgba(188,236,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(188,236,255,.035) 1px,transparent 1px);background-size:44px 44px;pointer-events:none}
.map-copy{position:relative;z-index:2;display:flex;justify-content:space-between;gap:18px;align-items:flex-end;padding:22px 24px 0}
.map-copy h3{margin:6px 0 4px;font-size:25px;letter-spacing:.02em}.map-copy p{max-width:820px;color:var(--muted);font-size:12px;line-height:1.8;margin:0}
.map-badge{border:1px solid rgba(188,236,255,.24);border-radius:999px;padding:9px 14px;color:#c9f3ff;background:rgba(85,199,242,.08);font-size:11px;white-space:nowrap}
.world-map-stage,.japan-map-stage{position:relative;z-index:1;margin:14px 18px 0;height:470px;border-radius:18px;background:linear-gradient(180deg,#fbfdff,#eef7ff);border:1px solid rgba(188,236,255,.22);overflow:hidden;box-shadow:inset 0 0 0 1px rgba(255,255,255,.42),inset 0 -42px 100px rgba(85,160,210,.10)}
.japan-map-stage{height:520px}
.world-map-stage:after,.japan-map-stage:after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 52% 50%,rgba(85,199,242,.10),transparent 38%);pointer-events:none}
.nb-map-svg{position:absolute;inset:4% 3%;width:94%;height:92%;overflow:visible}
.nb-world-map path,.nb-world-map polygon,.nb-japan-map path,.nb-japan-map polygon{fill:#eff7fd!important;stroke:#72879a!important;stroke-width:.55!important;vector-effect:non-scaling-stroke;transition:fill .2s ease,stroke .2s ease,filter .2s ease}
.nb-japan-map path,.nb-japan-map polygon{stroke:#1f2e39!important;stroke-width:1.4!important;fill:#ffffff!important}
.nb-world-map [id].hot-country{fill:#cfe8fa!important;stroke:#5d9ccc!important}
.nb-world-map [id].active-country{fill:#67c8f1!important;stroke:#0b79b7!important;filter:drop-shadow(0 0 8px rgba(61,176,234,.55))}
.nb-japan-map [id].hot-pref{fill:#d7effd!important;stroke:#1e5e87!important}
.nb-japan-map [id].active-pref{fill:#61cff3!important;stroke:#063c5c!important;filter:drop-shadow(0 0 8px rgba(61,176,234,.62))}
.map-pin{position:absolute;z-index:5;transform:translate(-50%,-50%);border:0;background:transparent;color:#07131c;cursor:pointer;min-width:14px;min-height:14px;padding:0}
.map-pin i{display:block;width:8px;height:8px;border-radius:50%;background:#fff;box-shadow:0 0 0 4px rgba(15,33,48,.13),0 0 16px rgba(15,33,48,.34)}
.map-pin.active i{width:11px;height:11px;background:#45c6f3;box-shadow:0 0 0 7px rgba(69,198,243,.20),0 0 28px rgba(33,154,226,.95),0 0 58px rgba(33,154,226,.40);animation:pulsePin 1.9s ease-in-out infinite}
.map-pin b{position:absolute;left:13px;top:-8px;white-space:nowrap;padding:4px 7px;border-radius:999px;background:rgba(4,14,24,.86);border:1px solid rgba(188,236,255,.24);font-size:9px;letter-spacing:.03em;color:#e9fbff;opacity:0;transform:translateX(-4px);transition:.18s;pointer-events:none}
.map-pin.active b,.map-pin:hover b{opacity:1;transform:translateX(0)}
.map-pin small{position:absolute;right:-7px;top:-11px;width:14px;height:14px;border-radius:50%;display:grid;place-items:center;background:rgba(232,199,121,.92);color:#09131d;font-size:7px;font-weight:900;box-shadow:0 0 0 2px rgba(255,255,255,.9)}
@keyframes pulsePin{0%,100%{filter:brightness(1)}50%{filter:brightness(1.45)}}
.map-event-strip{position:relative;z-index:2;display:grid;grid-template-columns:repeat(3,1fr);gap:9px;padding:14px 18px 18px}
.map-event-card{border:1px solid rgba(188,236,255,.14);border-radius:14px;background:rgba(255,255,255,.035);padding:12px;text-align:left;color:#d8e9f1;cursor:pointer;transition:.18s}
.map-event-card:hover{border-color:rgba(85,199,242,.45);transform:translateY(-2px);background:rgba(85,199,242,.08)}
.map-event-card span{display:block;color:#75d9ff;font-size:10px;letter-spacing:.08em;margin-bottom:6px}.map-event-card b{display:block;font-size:12px}.map-event-card em{display:block;color:var(--muted);font-size:10px;font-style:normal;margin-top:6px}
.map-empty{grid-column:1/-1;color:var(--muted);font-size:12px;padding:14px;border:1px dashed rgba(188,236,255,.16);border-radius:14px;text-align:center}
.archive-actions{display:flex;justify-content:center;gap:12px;margin:18px auto 0}.archive-actions .load-more{margin:0}.btn.subtle{background:rgba(255,255,255,.035);border-color:rgba(188,236,255,.20)}
.cluster-list{display:grid;gap:10px}.cluster-row{border:1px solid rgba(188,236,255,.16);border-radius:14px;background:rgba(255,255,255,.035);padding:13px;cursor:pointer}.cluster-row:hover{border-color:rgba(85,199,242,.42);background:rgba(85,199,242,.08)}
.show-map-layout{display:grid;grid-template-columns:1.08fr .92fr;gap:16px;position:relative;z-index:2;padding:18px}.show-map-side{border:1px solid rgba(188,236,255,.14);border-radius:18px;padding:18px;background:rgba(2,10,18,.45)}
.show-map-side h3{font-size:22px;margin:4px 0 8px}.show-map-side p{color:var(--muted);font-size:12px;line-height:1.75}.show-map-events{display:grid;gap:9px;max-height:360px;overflow:auto;padding-right:4px}.show-map-event{border:1px solid rgba(188,236,255,.13);border-radius:12px;padding:11px;background:rgba(255,255,255,.035);cursor:pointer}.show-map-event:hover{border-color:rgba(241,135,75,.50)}
.show-map-event span{display:block;color:#ffc08e;font-size:10px;letter-spacing:.08em}.show-map-event b{font-size:12px}.show-map-event em{display:block;color:var(--muted);font-size:10px;font-style:normal;margin-top:5px}
.overview-fusion{display:grid;grid-template-columns:1.1fr .9fr;gap:18px;align-items:stretch}
.life-axis-panel{padding:26px;position:relative;overflow:hidden;background:radial-gradient(circle at 82% 22%,rgba(85,199,242,.18),transparent 34%),rgba(255,255,255,.035)}
.life-axis-panel h3{font-size:30px;margin:10px 0 12px}.life-axis-panel p{color:var(--muted);font-size:13px;line-height:1.9;max-width:850px}
.axis-steps{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}.axis-steps span{border:1px solid rgba(188,236,255,.20);border-radius:999px;padding:8px 11px;color:#dff7ff;background:rgba(85,199,242,.06);font-size:11px}
.fusion-stats{min-height:100%;background:radial-gradient(circle at 18% 12%,rgba(232,199,121,.20),transparent 30%),linear-gradient(135deg,rgba(16,50,72,.92),rgba(7,18,31,.95))}
.compact-signal{grid-column:1/-1;position:relative;overflow:hidden}.compact-signal .chart{height:230px}
.chart-panel:before{content:"";position:absolute;inset:-50% -15% auto auto;width:520px;height:520px;border-radius:50%;background:radial-gradient(circle,rgba(85,199,242,.17),transparent 62%);filter:blur(4px);pointer-events:none}
.chart-panel:after{content:"MISSION CONTROL · COMPETITION TO ICE STORY";position:absolute;right:28px;bottom:16px;color:rgba(188,236,255,.10);letter-spacing:.32em;font-size:10px}
.chart .line{filter:drop-shadow(0 0 7px currentColor)}.chart .dot{filter:drop-shadow(0 0 9px currentColor)}
.milestone-integrated-head{display:flex;justify-content:space-between;gap:18px;align-items:end;margin:34px 0 18px}.milestone-integrated-head h3{font-size:34px;margin:6px 0 0}
.overview-milestone .milestone-grid{margin-top:0}.overview-milestone .milestone-card{box-shadow:0 18px 50px rgba(0,0,0,.24)}
@media(max-width:980px){.map-copy,.show-map-layout,.milestone-integrated-head{display:block}.world-map-stage,.japan-map-stage{height:340px}.map-event-strip{grid-template-columns:1fr}.show-map-side{margin-top:14px}.archive-controls{grid-template-columns:1fr 1fr}.overview-fusion{grid-template-columns:1fr}.milestone-controls{margin-top:14px}}
</style>

<style id="final-dark-art-direction">
.hero-bg{
  background:
    linear-gradient(90deg,rgba(1,7,14,.99) 0%,rgba(1,7,14,.96) 31%,rgba(1,7,14,.78) 52%,rgba(1,7,14,.36) 72%,rgba(1,7,14,.92) 100%),
    radial-gradient(circle at 78% 22%,rgba(118,218,255,.18),transparent 27%),
    radial-gradient(circle at 66% 78%,rgba(111,91,255,.12),transparent 28%),
    url("assets/inline-00-5a9aeb34ef.jpg") !important;
  background-repeat:no-repeat!important;
  background-position:center,center,center,88% 50%!important;
  background-size:cover,cover,cover,min(64vw,980px) auto!important;
  filter:saturate(.96) contrast(1.04);
}
.hero-bg:before{content:"";position:absolute;inset:0;background:
  radial-gradient(circle at 74% 19%,rgba(226,248,255,.85) 0 1px,transparent 2px),
  radial-gradient(circle at 82% 42%,rgba(226,248,255,.65) 0 1px,transparent 2px),
  radial-gradient(circle at 63% 33%,rgba(226,248,255,.45) 0 1px,transparent 2px),
  radial-gradient(circle at 91% 69%,rgba(226,248,255,.55) 0 1px,transparent 2px),
  radial-gradient(circle at 57% 71%,rgba(226,248,255,.45) 0 1px,transparent 2px);
  opacity:.55;filter:drop-shadow(0 0 8px rgba(133,221,255,.5));pointer-events:none}
.hero-bg:after{content:"";position:absolute;inset:0;background:
  linear-gradient(90deg,#01070e 0 18%,rgba(1,7,14,0) 42%,rgba(1,7,14,0) 74%,#01070e 100%),
  linear-gradient(180deg,#01070e 0%,rgba(1,7,14,0) 18%,rgba(1,7,14,0) 74%,#01070e 100%);
  pointer-events:none}
.hero .producer-credit{letter-spacing:.14em;text-shadow:0 0 14px rgba(188,236,255,.45)}
.compact-signal{display:none!important}

.archive-map-deck{margin:16px 0 10px!important;border-radius:22px!important;background:radial-gradient(circle at 78% 34%,rgba(43,194,223,.14),transparent 34%),linear-gradient(135deg,rgba(2,10,18,.98),rgba(2,16,27,.94))!important}
.archive-map-deck:before,.show-map-deck:before{background-image:none!important}
.map-copy{padding:18px 20px 0!important}.map-copy h3{font-size:22px!important;margin:4px 0!important}.map-copy p{font-size:11px!important;max-width:720px!important;opacity:.82}
.world-map-stage{height:315px!important;margin:12px 16px 0!important;background:#020a12!important;border-color:rgba(92,214,235,.20)!important;box-shadow:inset 0 0 0 1px rgba(142,237,255,.05),0 0 80px rgba(20,126,164,.08)!important}
.japan-map-stage{height:0!important;display:none!important}
.world-map-stage:after{background:
  radial-gradient(circle at 76% 38%,rgba(58,224,244,.16),transparent 23%),
  radial-gradient(circle at 49% 34%,rgba(58,224,244,.10),transparent 18%),
  radial-gradient(circle at 20% 36%,rgba(58,224,244,.08),transparent 16%)!important}
.nb-map-svg{inset:0!important;width:100%!important;height:100%!important;opacity:.95!important}
.nb-world-map path,.nb-world-map polygon{fill:rgba(5,32,48,.56)!important;stroke:rgba(124,213,232,.18)!important;stroke-width:.45!important;vector-effect:non-scaling-stroke!important}
.nb-world-map path:hover,.nb-world-map polygon:hover{fill:rgba(14,70,91,.72)!important;stroke:rgba(156,238,255,.45)!important}
.nb-world-map [id].hot-country,.nb-world-map [id].active-country{fill:rgba(5,32,48,.56)!important;stroke:rgba(124,213,232,.18)!important;filter:none!important}
.map-pin{color:#dffbff!important;min-width:10px!important;min-height:10px!important}
.map-pin i{width:6px!important;height:6px!important;background:#e9fbff!important;box-shadow:0 0 0 3px rgba(210,244,255,.10),0 0 15px rgba(186,241,255,.75)!important}
.map-pin.active i{width:9px!important;height:9px!important;background:#4ee8ff!important;box-shadow:0 0 0 7px rgba(78,232,255,.20),0 0 28px rgba(78,232,255,.95),0 0 62px rgba(89,117,255,.45)!important}
.map-pin small{right:-8px!important;top:-11px!important;width:12px!important;height:12px!important;font-size:6px!important;background:rgba(232,199,121,.95)!important;box-shadow:0 0 0 1px rgba(3,10,18,.9),0 0 9px rgba(232,199,121,.42)!important}
.map-pin b{font-size:9px!important;background:rgba(2,10,18,.86)!important;border-color:rgba(121,236,255,.34)!important;color:#eaffff!important}
.map-event-strip{grid-template-columns:repeat(5,1fr)!important;padding:10px 16px 16px!important;gap:8px!important}
.map-event-card{padding:9px!important;border-radius:12px!important}.map-event-card span{font-size:9px!important}.map-event-card b{font-size:10px!important}.map-event-card em{font-size:9px!important}

.show-map-deck{background:linear-gradient(135deg,rgba(2,10,18,.98),rgba(4,13,25,.94))!important;border-radius:26px!important}
.ice-universe{position:relative;overflow:hidden;padding:22px;border:1px solid rgba(188,236,255,.18);border-radius:26px;background:radial-gradient(circle at 20% 20%,rgba(69,210,255,.16),transparent 24%),radial-gradient(circle at 78% 38%,rgba(107,86,255,.13),transparent 24%),linear-gradient(135deg,#020912,#061421)}
.ice-universe:before{content:"";position:absolute;inset:0;background-image:radial-gradient(circle,rgba(220,248,255,.68) 0 1px,transparent 1.7px);background-size:38px 38px;opacity:.13;mask-image:linear-gradient(90deg,transparent,black 18%,black 82%,transparent);pointer-events:none}
.ice-universe-head{position:relative;z-index:1;display:flex;justify-content:space-between;gap:16px;align-items:end;margin-bottom:16px}
.ice-universe-head h3{font-size:28px;margin:5px 0 0}.ice-universe-head p{color:var(--muted);font-size:12px;line-height:1.8;max-width:760px;margin:0}
.ice-universe-grid{position:relative;z-index:1;display:grid;grid-template-columns:1.05fr 1fr 1fr;gap:14px}
.ice-story-card{min-height:210px;border:1px solid rgba(188,236,255,.18);border-radius:20px;background:rgba(255,255,255,.035);overflow:hidden;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.34)}
.ice-story-card.feature{grid-row:span 2;min-height:440px}
.ice-story-card img{width:100%;height:145px;object-fit:contain!important;background:radial-gradient(circle at 50% 38%,rgba(188,236,255,.08),#030910 72%);padding:18px;box-sizing:border-box;filter:saturate(.94) contrast(1.04)}
.ice-story-card.feature img{height:310px;padding:20px}
.ice-story-card .story-body{padding:14px 16px 16px}.ice-story-card .story-meta{display:flex;justify-content:space-between;color:#9eeaff;font-size:10px;letter-spacing:.16em;text-transform:uppercase}.ice-story-card h4{margin:8px 0 6px;font-size:22px}.ice-story-card p{margin:0;color:var(--muted);font-size:11px;line-height:1.65}
.poster{background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.018))!important}
.poster img{object-fit:contain!important;background:radial-gradient(circle at 52% 42%,rgba(188,236,255,.10),#020912 72%)!important;padding:24px!important;box-sizing:border-box!important}
.poster-content{background:linear-gradient(180deg,rgba(2,9,18,0),rgba(2,9,18,.92) 34%,rgba(2,9,18,.98))!important}
@media(max-width:980px){.map-event-strip{grid-template-columns:1fr!important}.ice-universe-grid{grid-template-columns:1fr}.ice-story-card.feature{grid-row:auto;min-height:260px}.ice-story-card.feature img{height:180px}.world-map-stage{height:260px!important}}
</style>


<style id="rescue-final-correctness">
.hero-bg{
  background:
    linear-gradient(90deg,rgba(1,7,14,.99) 0%,rgba(1,7,14,.96) 34%,rgba(1,7,14,.60) 61%,rgba(1,7,14,.28) 78%,rgba(1,7,14,.90) 100%),
    radial-gradient(circle at 72% 28%,rgba(255,219,138,.16),transparent 24%),
    radial-gradient(circle at 84% 68%,rgba(101,213,255,.12),transparent 24%),
    url("assets/inline-00-bdb4a67e19.jpg") !important;
  background-repeat:no-repeat!important;
  background-position:center,center,center,82% 48%!important;
  background-size:cover,cover,cover,auto 78%!important;
}
.hero-bg:before{content:"";position:absolute;inset:0;background:
  radial-gradient(circle at 70% 23%,rgba(255,230,166,.75) 0 1px,transparent 2px),
  radial-gradient(circle at 78% 39%,rgba(223,250,255,.7) 0 1px,transparent 2px),
  radial-gradient(circle at 88% 54%,rgba(223,250,255,.5) 0 1px,transparent 2px),
  radial-gradient(circle at 64% 74%,rgba(255,230,166,.45) 0 1px,transparent 2px);
  opacity:.62;filter:drop-shadow(0 0 10px rgba(255,220,150,.5));pointer-events:none}
.hero-bg:after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,#01070e 0 20%,rgba(1,7,14,0) 48%,rgba(1,7,14,0) 75%,#01070e 100%),linear-gradient(180deg,#01070e 0,transparent 18%,transparent 72%,#01070e 100%);pointer-events:none}
.hero-credit{opacity:.78}

.modal-hero{background:#020912!important}
.modal-hero img,#modalImage{object-fit:contain!important;object-position:center center!important;background:#020912!important;padding:10px!important;box-sizing:border-box!important}
.modal-card{max-width:min(1450px,calc(100vw - 70px))!important}
.milestone-card img,.poster img,.ice-story-card img{object-fit:contain!important;object-position:center center!important}

.world-map-stage{height:340px!important;background:radial-gradient(circle at 78% 38%,rgba(49,214,235,.10),transparent 24%),#020a12!important}
.nb-world-map path,.nb-world-map polygon{fill:rgba(5,35,50,.72)!important;stroke:rgba(116,218,236,.23)!important;stroke-width:.42!important}
.map-pin b{font-weight:800!important}
.map-pin small{font-size:6px!important}

.japan-map-stage{display:block!important;height:380px!important;margin:12px 0 0!important;background:radial-gradient(circle at 54% 48%,rgba(49,214,235,.12),transparent 34%),#020a12!important;border:1px solid rgba(92,214,235,.20)!important;border-radius:18px!important}
.rescue-japan-map{inset:5% 16%!important;width:68%!important;height:90%!important}
.rescue-japan-map path,.rescue-japan-map polygon{fill:rgba(5,35,50,.72)!important;stroke:rgba(190,245,255,.55)!important;stroke-width:1.1!important;vector-effect:non-scaling-stroke!important}
.rescue-japan-map [id].hot-pref{fill:rgba(6,58,78,.82)!important;stroke:rgba(135,232,250,.68)!important}
.rescue-japan-map [id].active-pref{fill:rgba(71,220,245,.82)!important;stroke:#dffbff!important;filter:drop-shadow(0 0 8px rgba(71,220,245,.8))}
.ice-japan-panel{margin-top:18px;display:grid;grid-template-columns:1fr .9fr;gap:16px;position:relative;z-index:1}
.ice-japan-copy{border:1px solid rgba(188,236,255,.14);border-radius:18px;background:rgba(255,255,255,.035);padding:18px}
.ice-japan-copy h4{font-size:22px;margin:6px 0 8px}.ice-japan-copy p{color:var(--muted);font-size:12px;line-height:1.75}
.ice-japan-events{display:grid;gap:8px;max-height:360px;overflow:auto}.ice-japan-event{border:1px solid rgba(188,236,255,.14);border-radius:12px;background:rgba(255,255,255,.035);padding:10px;cursor:pointer}.ice-japan-event:hover{border-color:rgba(85,199,242,.45)}
.ice-japan-event span{display:block;color:#9eeaff;font-size:10px;letter-spacing:.08em}.ice-japan-event b{font-size:12px}.ice-japan-event em{display:block;color:var(--muted);font-size:10px;font-style:normal;margin-top:4px}

.poster-grid.show-timeline{display:grid!important;grid-template-columns:1fr!important;gap:10px!important}
.show-timeline-row{border:1px solid rgba(188,236,255,.16);border-radius:16px;background:linear-gradient(90deg,rgba(85,199,242,.08),rgba(255,255,255,.025));padding:14px 16px;display:grid;grid-template-columns:120px 1fr 90px;gap:14px;align-items:center;cursor:pointer}
.show-timeline-row:hover{border-color:rgba(85,199,242,.48);transform:translateY(-1px)}
.show-timeline-row .t-year{color:#9eeaff;letter-spacing:.12em;font-size:12px}.show-timeline-row h3{margin:0;font-size:18px}.show-timeline-row p{margin:5px 0 0;color:var(--muted);font-size:12px;line-height:1.55}.show-timeline-row .t-count{text-align:right;color:#e8c779;font-weight:900}
@media(max-width:980px){.ice-japan-panel{grid-template-columns:1fr}.show-timeline-row{grid-template-columns:1fr}.show-timeline-row .t-count{text-align:left}.rescue-japan-map{inset:4% 4%!important;width:92%!important}}
</style>



<style id="country-map-final-pass">
.hero-bg{
  background:
    linear-gradient(90deg,rgba(1,7,14,.99) 0%,rgba(1,7,14,.96) 32%,rgba(1,7,14,.66) 56%,rgba(1,7,14,.28) 78%,rgba(1,7,14,.82) 100%),
    radial-gradient(circle at 78% 31%,rgba(255,222,139,.16),transparent 22%),
    radial-gradient(circle at 88% 62%,rgba(110,218,255,.13),transparent 24%),
    url("assets/inline-00-b3683d2dba.jpg") !important;
  background-repeat:no-repeat!important;
  background-position:center,center,78% 46%!important;
  background-size:cover,cover,auto 92%!important;
  background-color:#01070e!important;
}
.hero-bg:before{
  content:"";position:absolute;inset:0;pointer-events:none;opacity:.72;
  background:
    radial-gradient(circle at 69% 18%,rgba(255,240,176,.88) 0 1px,transparent 2px),
    radial-gradient(circle at 75% 23%,rgba(220,249,255,.70) 0 1px,transparent 2px),
    radial-gradient(circle at 84% 41%,rgba(255,230,162,.58) 0 1px,transparent 2px),
    radial-gradient(circle at 91% 66%,rgba(220,249,255,.55) 0 1px,transparent 2px),
    radial-gradient(circle at 63% 72%,rgba(255,230,162,.40) 0 1px,transparent 2px);
  filter:drop-shadow(0 0 10px rgba(255,223,151,.52));
}
.hero-bg:after{
  content:"";position:absolute;inset:0;pointer-events:none;
  background:
    linear-gradient(90deg,#01070e 0 19%,rgba(1,7,14,0) 47%,rgba(1,7,14,0) 74%,#01070e 100%),
    linear-gradient(180deg,#01070e 0,transparent 17%,transparent 72%,#01070e 100%);
}
.hero-credit{opacity:.82}

.world-map-stage{height:360px!important;background:radial-gradient(circle at 78% 37%,rgba(46,218,235,.12),transparent 24%),#020a12!important}
.map-copy h3{font-size:26px!important}
.map-country-pin{
  position:absolute;transform:translate(-50%,-50%);border:0;background:transparent;color:#fff;cursor:pointer;z-index:4;
  display:grid;place-items:center;min-width:22px;min-height:22px;
}
.map-country-pin .core{
  width:13px;height:13px;border-radius:999px;background:#f8fdff;box-shadow:0 0 0 7px rgba(222,247,255,.13),0 0 22px rgba(214,248,255,.72);
}
.map-country-pin .count{
  position:absolute;left:11px;top:-17px;min-width:20px;height:20px;border-radius:999px;background:#e7c772;color:#07111a;
  font-size:10px;font-weight:950;display:grid;place-items:center;border:2px solid rgba(255,249,220,.78);
  box-shadow:0 0 16px rgba(231,199,114,.45);
}
.map-country-pin .label{
  position:absolute;left:21px;top:-9px;white-space:nowrap;border:1px solid rgba(143,231,248,.38);background:rgba(2,10,18,.76);
  color:#e8fbff;border-radius:999px;padding:4px 9px;font-size:11px;font-weight:900;letter-spacing:.02em;
  opacity:0;transform:translateX(-4px);transition:.18s ease;box-shadow:0 0 14px rgba(0,0,0,.34);
}
.map-country-pin:hover .label,.map-country-pin.active .label{opacity:1;transform:translateX(0)}
.map-country-pin.active .core{background:#62e9ff;box-shadow:0 0 0 12px rgba(98,233,255,.18),0 0 28px rgba(98,233,255,.9)}
.map-country-pin.active .count{background:#aeefff}
.country-city-list,.country-event-list{display:grid;gap:10px}
.country-city-row,.country-event-row{
  border:1px solid rgba(188,236,255,.16);border-radius:14px;background:rgba(255,255,255,.035);padding:12px 14px;cursor:pointer;
}
.country-city-row:hover,.country-event-row:hover{border-color:rgba(98,233,255,.50);background:rgba(98,233,255,.06)}
.country-city-row b,.country-event-row b{display:block;color:#f6fbff;font-size:15px}
.country-city-row span,.country-event-row span{display:block;color:#9fb2c3;font-size:12px;margin-top:4px}
.country-event-row em{display:block;color:#e7c772;font-style:normal;font-size:12px;margin-top:5px}
.map-event-strip.country-summary{grid-template-columns:repeat(4,minmax(0,1fr))!important}
.map-country-card{
  border:1px solid rgba(188,236,255,.14);border-radius:16px;background:linear-gradient(180deg,rgba(98,233,255,.075),rgba(255,255,255,.025));
  padding:14px;text-align:left;color:inherit;cursor:pointer;min-height:90px;
}
.map-country-card:hover{border-color:rgba(98,233,255,.45);transform:translateY(-1px)}
.map-country-card span{display:block;color:#9eeaff;font-size:11px;letter-spacing:.08em}.map-country-card b{display:block;font-size:18px;margin:6px 0}.map-country-card em{font-style:normal;color:#9fb2c3;font-size:12px}
@media(max-width:980px){.map-event-strip.country-summary{grid-template-columns:1fr!important}.hero-bg{background-position:center,center,68% 48%!important;background-size:cover,cover,auto 78%!important}}
</style>


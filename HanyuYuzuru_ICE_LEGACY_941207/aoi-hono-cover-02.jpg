    { phase:"senior", years:[2021,2022], season:"2021-2022", program:"Ten to Chi to", image:"https://pbs.twimg.com/media/FHicTQDaQAAO06k?format=jpg&name=small", note:{ zh:"《天与地》2021-2022 版本，腰带细节调整。", en:"Ten to Chi to 2021-2022 version with adjusted belt details.", ja:"天と地と 2021-2022 版。帯のディテールが調整された。" } },
    { phase:"senior", years:[2021,2022], season:"2021-2022", program:"Introduction and Rondo Capriccioso", image:"https://pbs.twimg.com/media/FHXl1zDakAI6ue7?format=jpg&name=4096x4096", note:{ zh:"Rondo 另一张图鉴/赛季版本。", en:"Another Rondo season archive version.", ja:"ロンドの別アーカイブ版。" } }
  ].map((row, index) => ({ ...row, id: `stable-costume-${index}` }));

  const supplementalCostumes = [
    { phase:"senior", years:[2018,2019], season:"2018-2019 / 2019", program:"Haru Yo Koi (EX)", image:"assets/remote-61d6be5d8b32.jpg", note:{ zh:"《春来》表演滑衣装，樱花与春日意象版本。", en:"Haru Yo Koi exhibition costume, shaped by spring and cherry-blossom imagery.", ja:"『春よ、来い』のエキシビション衣装。春と桜のイメージをまとった版。" }, sourceName:"Nikkan Gendai / Planet Hanyu", sourceUrl:"https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/" },
    { phase:"senior", years:[2018,2019], season:"2018-2019", program:"Origin", image:"https://i.pinimg.com/originals/eb/ab/bc/ebabbcaef5c03d2163805de561ba8d06.jpg", note:{ zh:"Origin 2.0 紫色版本，2019-2020 赛季设计调整。", en:"Origin 2.0 purple version, the 2019-2020 redesign.", ja:"Origin 2.0 紫版。2019-2020シーズンの再設計版。" }, sourceName:"Planet Hanyu / Pinterest mirror", sourceUrl:"https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/" },
    { phase:"senior", years:[2020,2021], season:"2020-2021", program:"Let Me Entertain You", image:"assets/remote-72dc62dcad4a.jpg", note:{ zh:"Let Me Entertain You 竞技黑色版本的另一张现场图。", en:"Additional competition image for the black Let Me Entertain You costume.", ja:"Let Me Entertain You 黒の競技衣装の別カット。" }, sourceName:"Sponichi / Planet Hanyu", sourceUrl:"https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/" },
    { phase:"senior", years:[2020,2021], season:"2020-2021", program:"Ten to Chi to", image:"assets/remote-cde36644b8f9.jpg", note:{ zh:"《天与地》2020-2021 版本背面细节，深蓝腰带。", en:"Ten to Chi to 2020-2021 back-detail image with the dark blue belt.", ja:"天と地と 2020-2021 版の背面ディテール。濃紺の帯。" }, sourceName:"Sponichi / Planet Hanyu", sourceUrl:"https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/" }
  ].map((row, index) => ({ ...row, id: `stable-costume-extra-${index}` }));
  supplementalCostumes.forEach(row => {
    if (!costumeRows.some(existing => existing.image === row.image)) costumeRows.push(row);
  });

  let costumeExpanded = false;
  const costumeSourceHome = "https://planethanyu.com/wiki/yuzuru-hanyu/yuzuru-hanyu-costumes/";

  const showDescriptions = {
    prologue: {
      title: "PROLOGUE",
      zh: "职业转向后的首个单人冰演，以竞技生涯回望与新旅程开端为核心。",
      en: "His first solo ice show after turning professional, framed as a look back at competition and the start of a new journey.",
      ja: "プロ転向後初の単独アイスショー。競技人生を振り返り、新たな旅の始まりを示す公演。"
    },
    gift: {
      title: "GIFT",
      zh: "东京巨蛋单人冰演，把叙事、音乐、影像与滑冰合为一体。",
      en: "A solo Tokyo Dome ice show combining narrative, music, visuals, and skating.",
      ja: "東京ドームで行われた単独アイスショー。物語、音楽、映像、スケートを一体化した公演。"
    },
    repray: {
      title: "RE_PRAY",
      zh: "ICE STORY 第二章，以游戏、选择和祈愿为线索展开。",
      en: "The second ICE STORY chapter, built around games, choices, and prayer.",
      ja: "ICE STORY 第2弾。ゲーム、選択、祈りを軸に展開する公演。"
    },
    echoes: {
      title: "Echoes of Life TOUR",
      zh: "ICE STORY 第三部，以“生命与人生之间”为核心，凝聚二十五年滑冰生涯的身体表达与情感经验。",
      en: "The third ICE STORY chapter, centered on life and human experience through twenty-five years of skating.",
      ja: "ICE STORY 第3弾。25年のスケート人生を通じ、生命と人生のあいだを身体表現で描く公演。"
    },
    notte: {
      title: "notte stellata",
      zh: "以 3.11 记忆与希望为主题的纪念演出系列。",
      en: "A commemorative show series shaped by remembrance of March 11 and hope.",
      ja: "3月11日の記憶と希望をテーマにした記念公演シリーズ。"
    },
    noto: {
      title: "Noto Charity Performance",
      zh: "为能登半岛地震灾区举办的复兴支援慈善演出。",
      en: "A charity performance supporting recovery after the Noto Peninsula earthquake.",
      ja: "能登半島地震の被災地復興を支援するチャリティー公演。"
    },
    realive: {
      title: { zh: "羽生结弦 ICE STORY 第四部", en: "Yuzuru Hanyu ICE STORY 4th", ja: "羽生結弦 ICE STORY 第四部" },
      zh: "ICE STORY 第四部，围绕现实、再生与继续前行展开。",
      en: "The fourth ICE STORY chapter, focused on reality, renewal, and continuing forward.",
      ja: "ICE STORY 第4弾。現実、再生、そして前へ進むことを軸にした公演。"
    }
  };

  function esc(v) {
    return String(v ?? "").replace(/[&<>"']/g, c => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
  }

  function injectStyle() {
    $("#final-user-request-style")?.remove();
    const style = document.createElement("style");
    style.id = "final-user-request-style";
    style.textContent = `
      .final-hidden{display:none!important}
      .photo-gap,.costume-source-note{display:none!important}
      .topbar{gap:22px!important}
      .topbar nav{margin-left:auto!important;margin-right:18px!important}
      .topbar-tools{margin-left:0!important}
      .lang-switch select option[value="ja"]{font-family:Inter,system-ui,sans-serif}
      #costumeYear{background:rgba(5,16,28,.86);border:1px solid rgba(188,236,255,.28);color:#eaf8ff;border-radius:14px;padding:12px 14px;min-width:132px}
      .stable-costume-card{overflow:hidden;border-radius:18px;border:1px solid rgba(188,236,255,.24);background:rgba(5,16,28,.76)}
      .stable-costume-card img{width:100%;height:255px;object-fit:cover;display:block;background:#061320}
      .stable-costume-card .costume-body{padding:16px}
      .stable-costume-card .season{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#9feaff;margin-bottom:8px}
      .stable-costume-card h3{font-size:18px;line-height:1.25;margin:0 0 8px;color:#fff}
      .stable-costume-card p{margin:0;color:#b7cad8;line-height:1.65;font-size:13px}
      .stable-costume-card .costume-years{margin-top:12px;color:#8bdfff;font-size:12px}
      .stable-costume-card .costume-source-pill{display:inline-flex;align-items:center;gap:6px;margin-top:12px;color:#9eeaff;font-size:11px;text-decoration:none;border-bottom:1px solid rgba(158,234,255,.35)}
      .stable-costume-card .costume-source-pill:hover{border-bottom-color:rgba(158,234,255,.85)}
      .final-costume-controls{display:grid;grid-template-columns:repeat(3,minmax(180px,1fr));gap:14px;margin:22px 0 28px;padding:18px;border:1px solid rgba(143,220,255,.24);border-radius:18px;background:rgba(7,24,38,.78)}
      .final-costume-controls select{width:100%;background:rgba(2,13,24,.92);border:1px solid rgba(188,236,255,.3);color:#eaf8ff;border-radius:12px;padding:14px 16px;font:700 15px Inter,system-ui;outline:none}
      .final-costume-actions{display:flex;justify-content:flex-end;margin:-12px 0 24px}
      .final-costume-actions .btn{min-width:132px}
      .final-costume-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:18px}
      #sources .section-head{margin-bottom:18px}
      #sources .section-intro,#sources .final-source-kicker,#sources .section-head p,#sources .section-head .section-label{display:none!important}
      #sources .official-grid.source-list{display:grid!important;grid-template-columns:1fr!important;gap:6px!important;max-width:none!important;margin-top:20px!important}
      #sources .source-card.glass{display:grid!important;grid-template-columns:minmax(360px,430px) repeat(3,minmax(180px,1fr))!important;gap:12px 38px!important;align-items:start!important;padding:16px 0!important;border:0!important;border-top:1px solid rgba(188,236,255,.18)!important;border-radius:0!important;background:transparent!important;box-shadow:none!important}
      #sources .source-card.glass:last-child{border-bottom:1px solid rgba(188,236,255,.18)!important}
      #sources .source-card.glass h3{grid-column:1!important;grid-row:1 / span 3!important;margin:1px 0 0!important;color:#9eeaff!important;font-size:22px!important;line-height:1.28!important;letter-spacing:.08em!important;text-transform:none!important;max-width:none!important}
      #sources .source-card.glass a{display:flex!important;align-items:center!important;justify-content:space-between!important;padding:2px 0 8px!important;border:0!important;border-bottom:1px solid rgba(188,236,255,.12)!important;border-radius:0!important;background:transparent!important;color:#eaf8ff!important;text-decoration:none!important;font-weight:800!important;min-height:auto!important;box-shadow:none!important}
      #sources .source-card.glass a:hover{color:#9eeaff!important;border-bottom-color:rgba(126,232,255,.55)!important}
      .simple-source-list{max-width:none;margin-top:20px;display:grid;gap:6px}
      .simple-source-group{display:grid;grid-template-columns:minmax(360px,430px) minmax(0,1fr);gap:12px 40px;padding:16px 0;border-top:1px solid rgba(188,236,255,.18)}
      .simple-source-group:last-child{border-bottom:1px solid rgba(188,236,255,.18)}
      .simple-source-group h3{margin:1px 0 0;color:#9eeaff;font-size:12px;letter-spacing:.18em;text-transform:uppercase}
      .simple-source-links{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px 30px}
      .simple-source-link{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:2px 0 8px;border-bottom:1px solid rgba(188,236,255,.12);color:#eaf8ff;text-decoration:none;font-weight:800;background:transparent!important}
      .simple-source-link span:last-child{color:#9eeaff}
      .simple-source-link:hover{color:#9eeaff;border-bottom-color:rgba(126,232,255,.55)}
      .final-country-atlas{border:1px solid rgba(143,220,255,.24);border-radius:22px;background:linear-gradient(135deg,rgba(8,28,44,.82),rgba(3,13,24,.86));padding:22px;margin-top:18px}
      .final-country-atlas-head{display:flex;align-items:end;justify-content:space-between;gap:18px;margin-bottom:18px}
      .final-country-atlas-head h3{margin:0;color:#fff;font-size:28px}
      .final-country-atlas-head p{margin:0;color:#a9bdcb;max-width:620px;line-height:1.6}
      .final-world-map{position:relative;min-height:370px;border:1px solid rgba(188,236,255,.2);border-radius:18px;background:#020a12;overflow:hidden;margin-bottom:16px}
      .final-world-map .world-map-stage{height:370px!important;margin:0!important;border:0!important;border-radius:18px!important;background:#020a12!important}
      .final-map-pins{position:absolute;inset:0;z-index:10;pointer-events:none}
      .final-map-pin{position:absolute;transform:translate(-50%,-50%);border:0;background:transparent;color:#eaf8ff;cursor:pointer;pointer-events:auto;display:grid;place-items:center;min-width:28px;min-height:28px}
      .final-map-pin .dot{width:9px;height:9px;border-radius:999px;background:#e9fbff;box-shadow:0 0 0 5px rgba(210,244,255,.12),0 0 20px rgba(186,241,255,.8)}
      .final-map-pin .num{position:absolute;left:14px;top:-4px;min-width:18px;height:18px;padding:0 5px;border-radius:999px;background:#e8c779;color:#06111d;font-size:10px;font-weight:900;display:grid;place-items:center}
      .final-map-pin .lab{position:absolute;left:28px;top:16px;white-space:nowrap;font-size:11px;font-weight:900;color:#dffbff;background:rgba(3,13,24,.78);border:1px solid rgba(188,236,255,.2);border-radius:999px;padding:4px 8px;opacity:0;transform:translateX(-4px);transition:.16s ease}
      .final-map-pin:hover .lab{opacity:1;transform:translateX(0)}
      .final-country-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px}
      .final-country-card{min-height:96px;text-align:left;border:1px solid rgba(188,236,255,.18);border-radius:16px;background:rgba(2,13,24,.82);color:#eaf8ff;padding:16px;cursor:pointer}
      .final-country-card:hover{border-color:rgba(126,232,255,.68);transform:translateY(-1px);box-shadow:0 12px 28px rgba(0,0,0,.22)}
      .final-country-card span{display:block;color:#9eeaff;font-size:11px;letter-spacing:.16em;text-transform:uppercase}
      .final-country-card b{display:block;font-size:24px;margin:8px 0 4px;color:#fff}
      .final-country-card em{font-style:normal;color:#9fb2c3;font-size:12px}
      .ultimate-country-pin *, .map-country-pin *, .map-country-card *, .country-card *{pointer-events:none!important}
      .stable-competition-list{display:grid;gap:10px;margin-top:14px;max-height:48vh;overflow:auto;padding-right:4px}
      .stable-competition-row{border:1px solid rgba(188,236,255,.18);border-radius:14px;padding:12px 14px;background:rgba(6,19,31,.82)}
      .stable-competition-row b{display:block;color:#fff;font-size:15px;margin-bottom:5px}
      .stable-competition-row span{display:block;color:#b8cad6;font-size:12px;line-height:1.5}
      .stable-modal-facts{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-top:16px}
      .stable-modal-facts .fact{border:1px solid rgba(188,236,255,.18);border-radius:14px;padding:12px;background:rgba(255,255,255,.04)}
      .stable-modal-facts .fact span{display:block;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#9feaff;margin-bottom:6px}
      .stable-modal-facts .fact b{font-size:16px;color:#fff}
      .costume-attribution-note{margin:20px 0 0;padding-top:14px;border-top:1px solid rgba(188,236,255,.14);color:#7891a3;font-size:10px;line-height:1.7;letter-spacing:.01em}
      .modal.competition-list-modal .modal-card{max-width:1180px}
      .modal.competition-list-modal .modal-hero{height:auto!important;min-height:184px!important;display:block!important;background:linear-gradient(135deg,rgba(7,22,35,.98),rgba(2,8,14,.98))!important}
      .modal.competition-list-modal .modal-hero:before{display:none!important}
      .modal.competition-list-modal .modal-hero:after{background:linear-gradient(180deg,rgba(8,26,41,.08),rgba(7,22,37,.88))!important}
      .modal.competition-list-modal .modal-title{position:relative!important;left:auto!important;right:auto!important;bottom:auto!important;padding:54px 92px 28px 32px!important;min-width:0!important}
      .modal.competition-list-modal .modal-title .overline{font-size:11px!important;line-height:1.35!important;letter-spacing:.2em!important}
      .modal.competition-list-modal .modal-title h2,.modal.competition-list-modal #modalTitle{margin:10px 0 0!important;font-size:clamp(30px,3.2vw,52px)!important;line-height:1.06!important;max-width:100%!important;overflow-wrap:anywhere!important;word-break:normal!important}
      .modal.competition-list-modal .modal-body{padding-top:22px!important}
      footer{display:flex!important;align-items:flex-end!important;justify-content:space-between!important;gap:32px!important;padding:28px max(20px,calc((100vw - 1180px)/2))!important;text-align:left!important}
      .footer-contact{display:grid;gap:2px;color:#7891a3;font-size:9px;line-height:1.55}
      .footer-contact strong{color:#9ab2c2;font-size:9px;font-weight:700;letter-spacing:.04em}
      .footer-contact span,.footer-meta{white-space:nowrap}
      .footer-meta{color:#657f91;font-size:9px;line-height:1.55;text-align:right}
      .modal-hero.no-photo{height:170px!important;min-height:170px!important;display:flex!important;align-items:center!important;justify-content:center!important;background:linear-gradient(135deg,rgba(7,22,35,.96),rgba(2,8,14,.96))!important}
      .modal-hero.no-photo img{display:none!important}
      .modal-hero.no-photo:before{content:attr(data-no-photo);color:#8da5b6;letter-spacing:.22em;text-transform:uppercase;font-size:12px}
      .modal.milestone-detail .modal-card{display:grid;grid-template-rows:minmax(230px,36vh) minmax(0,1fr)}
      .modal.milestone-detail .modal-hero{height:auto!important;min-height:230px!important}
      .modal.milestone-detail .modal-hero img{width:100%!important;height:100%!important;object-fit:contain!important;object-position:center!important;background:#020a12!important}
      .modal.milestone-detail .modal-body{overflow:auto;padding-top:24px}
      .final-milestone-details{display:grid;gap:14px}
      .final-milestone-lead{font-size:16px;line-height:1.8;color:#d6e8f2;margin:0}
      .final-milestone-facts{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px}
      .final-milestone-facts div{border:1px solid rgba(188,236,255,.18);border-radius:14px;padding:12px;background:rgba(255,255,255,.04)}
      .final-milestone-facts span{display:block;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#9feaff;margin-bottom:6px}
      .final-milestone-facts b{color:#fff;font-size:15px}
      .final-milestone-links{display:flex;gap:12px;flex-wrap:wrap}
      .final-milestone-links a{color:#9eeaff;text-decoration:none;border-bottom:1px solid rgba(158,234,255,.45)}

      .profile-books{margin-top:28px;padding-top:26px;border-top:1px solid rgba(188,236,255,.18)}
      .profile-books-head{display:grid;grid-template-columns:minmax(280px,.8fr) minmax(320px,1.2fr);gap:34px;align-items:end;margin-bottom:18px}
      .profile-books-head h3{margin:7px 0 0;color:#fff;font-size:clamp(25px,3vw,40px);line-height:1.12}
      .profile-books-head p{margin:0;color:#9eb4c3;line-height:1.75;font-size:13px;max-width:720px}
      .profile-books-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px}
      .profile-book-card{display:grid;grid-template-rows:auto 1fr;overflow:hidden;border-radius:18px;background:linear-gradient(145deg,rgba(8,26,41,.9),rgba(3,13,24,.92));border:1px solid rgba(188,236,255,.18);min-width:0}
      .profile-book-cover{height:310px;padding:18px;display:grid;place-items:center;background:radial-gradient(circle at 50% 28%,rgba(83,196,239,.16),transparent 54%),rgba(1,9,17,.78)}
      .profile-book-cover img{width:100%;height:100%;object-fit:contain;display:block;filter:drop-shadow(0 18px 22px rgba(0,0,0,.38))}
      .profile-book-copy{padding:17px 17px 20px;display:flex;flex-direction:column}
      .profile-book-meta{color:#8edff7;font-size:9px;font-weight:800;letter-spacing:.11em;text-transform:uppercase;line-height:1.5}
      .profile-book-card h4{margin:8px 0 9px;color:#fff;font-size:18px;line-height:1.3}
      .profile-book-card p{margin:0;color:#aebfcb;font-size:12px;line-height:1.72}
      .modal.competition-list-modal .modal-hero{min-height:148px!important}
      .modal.competition-list-modal .modal-title{padding:38px 90px 24px 32px!important}
      .modal.competition-list-modal .modal-title h2,.modal.competition-list-modal #modalTitle{font-size:clamp(28px,2.45vw,42px)!important;line-height:1.12!important;overflow-wrap:normal!important;word-break:keep-all!important}
      @media(max-width:1100px){.profile-books-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
      @media(max-width:900px){#sources .source-card.glass,.simple-source-group{grid-template-columns:1fr!important}.simple-source-links{grid-template-columns:1fr}.final-costume-controls{grid-template-columns:1fr}.profile-books-head{grid-template-columns:1fr}}
      @media(max-width:700px){.profile-books-grid{grid-template-columns:1fr}.profile-book-cover{height:340px}.stable-costume-card img{height:210px}.stable-competition-list{max-height:54vh}.modal.competition-list-modal .modal-title{padding:46px 58px 20px 16px!important}.modal.competition-list-modal .modal-title h2,.modal.competition-list-modal #modalTitle{font-size:clamp(25px,8vw,34px)!important}footer{display:grid!important;gap:14px!important;padding:22px 18px!important}.footer-meta{text-align:left}.footer-contact span,.footer-meta{white-space:normal}}
    `;
    document.head.appendChild(style);
  }

  function syncLanguageControls(l) {
    const select = $("#languageSelect");
    if (select) {
      const labels = { zh: "中文", en: "English", ja: "日本語" };
      Array.from(select.options).forEach(opt => {
        const key = validLang(opt.value || opt.textContent);
        opt.value = key;
        opt.textContent = labels[key] || opt.textContent.replace(/Japan語/g, "日本語");
      });
    }
    if (select && select.value !== l) select.value = l;
    document.documentElement.lang = l === "ja" ? "ja" : l === "en" ? "en" : "zh-CN";
    document.documentElement.dataset.lang = l;
  }

  function replaceLooseText() {
    return;
    const l = lang();
    const replacements = [
      [/羽生結弦|羽生结弦|Yuzuru Hanyu/g, names[l]],
      [/YUZURU HANYU/g, names[l].toUpperCase()],
      [/\u5929\u672c/g, "日本"],
      [/制作过程说明/g, ""],
      [/给自己看的备注/g, ""],
      [/Fantasy on Ice 官方网站|FOI 官方入口|Fantasy on Ice|FOI/g, ""]
    ];
    if (l === "zh") {
      replacements.push(
        [/職業\s*Ice Shows日本地图|职业\s*Ice Shows日本地图|日本\s*ICE SHOW ATLAS/g, "职业冰演日本地图"],
        [/Ice Shows/g, "冰演"],
        [/Yokohama/g, "横滨"],
        [/Hachinohe/g, "八户"],
        [/Sendai/g, "仙台"],
        [/Saitama/g, "埼玉"],
        [/Saga/g, "佐贺"],
        [/Miyagi/g, "宫城"],
        [/Tokyo/g, "东京"],
        [/Hiroshima/g, "广岛"],
        [/Chiba/g, "千叶"],
        [/Nagoya/g, "名古屋"],
        [/Rifu/g, "利府"],
        [/ぴあアリーナMM/g, "PIA Arena MM"],
        [/セキスイハイムスーパーアリーナ/g, "Sekisui Heim Super Arena"],
        [/さいたまスーパーアリーナ/g, "Saitama Super Arena"],
        [/SAGAアリーナ/g, "SAGA Arena"],
        [/真駒内セキスイハイムアイスアリーナ/g, "Makomanai Sekisui Heim Ice Arena"],
        [/広島グリーンアリーナ/g, "Hiroshima Green Arena"],
        [/日本スケート連盟\s*成績/g, "日本滑冰联盟成绩"]
      );
    }
    if (l === "en") {
      replacements.push(
        [/制作人-大西瓜/g, "Producer: momoka1207"],
        [/从仙台出发，穿过少年组、成年组、Olympics与Professional Ice Shows，把一段冰上人生展开成可以漫游的展馆。/g, "From Sendai through junior, senior, Olympic, and professional stages, this exhibition turns one skating life into a space you can explore."],
        [/竞技记录在 2009 年进入高密度阶段；2014 与 2018 的Olympics金牌把名字推向世界中心；2022 年后，数据重心转向由本人主导的个人冰演与叙事型 ICE STORY。这里不再只是一张统计图，而是一条不断拓展表达边界的生命轨道。/g, "The competition record becomes dense from 2009 onward; the 2014 and 2018 Olympic titles brought his name to the center of the sport; after 2022, the focus shifts to self-produced professional ice shows and narrative ICE STORY works. This is not only a chart, but the orbit of a life that keeps expanding expression on ice."],
        [/最高总分、世界纪录与Professional Ice Shows场次共同构成这座数字展馆的主骨架。/g, "Top scores, world records, and professional show dates form the main structure of this digital exhibition."],
        [/比赛记录与Professional Ice Shows场次/g, "Competition records and professional ice shows"],
        [/一个人的时间，如何成为一代人的星光/g, "How One Life Became a Light for a Generation"],
        [/从仙台的少年，到两届Olympics冠军，再到以身体、文字、音乐与冰面构筑世界的创作者。这一页记录成绩之外的生命轨迹。/g, "From a child in Sendai to a two-time Olympic champion, then to a creator building worlds through body, words, music, and ice. This page follows the life beyond the results."],
        [/他的轨迹并不是一条只通向奖牌的直线。它穿过伤病、震灾、世界纪录与万众注视，也穿过一次次重新理解“为何滑冰”的时刻。竞技时代结束以后，冰面没有成为过去——它被扩展成剧场、记忆、祈愿与仍在书写的未来。/g, "His path was never a straight line toward medals alone. It passed through injury, disaster, world records, and public attention, as well as repeated moments of asking why he skates. After competition, the ice did not become the past; it expanded into theatre, memory, prayer, and a future still being written."],
        [/Yuzuru Hanyu · 职业运动员 \/ 创作者/g, "Yuzuru Hanyu · Professional Athlete / Creator"],
        [/出生于Miyagi县仙台市。/g, "Born in Sendai, Miyagi."],
        [/开始学习花样滑冰。/g, "Started learning figure skating."],
        [/现有Competition Archive的起点。/g, "Starting point of the current competition archive."],
        [/连续两届获得Olympics会男子单人滑金牌。/g, "Won consecutive Olympic men's singles gold medals."],
        [/结束竞技生涯，转为职业运动员。/g, "Ended his competitive career and turned professional."],
        [/以 PROLOGUE、GIFT、RE_PRAY、Echoes of Life、REALIVE 等作品拓展 ICE STORY。/g, "Expanded ICE STORY through works including PROLOGUE, GIFT, RE_PRAY, Echoes of Life, and REALIVE."],
        [/点击记录查看分项成绩、来源和图片状态/g, "Click a record for scores, sources, and image status"],
        [/ICE STORY 视觉宇宙/g, "ICE STORY Visual Universe"],
        [/点击海报进入详情，查看官方主视觉、介绍摘要与每一场演出天期。/g, "Open a poster for the official visual, summary, and each show date."],
        [/光点标出演出城市，筛选不同系列后对应城市点亮；右侧同步列出日期与场馆。/g, "Light points mark show cities; filtering a series highlights its cities, while the right side lists the dates and venues."],
        [/光点标出演出城市，筛选不同系列后对应城市点亮；右侧同步列出天期与Shows馆。/g, "Light points mark show cities; filtering a series highlights its cities, while the right side lists the dates and venues."],
        [/距离下一次 12 月 7 天/g, "Days until the next December 7"],
        [/2026\s*年生日/g, "2026 Birthday"],
        [/世界纪录标记/g, "World-record markers"],
        [/2024 Professional Ice ShowsShows次/g, "2024 Professional ice show dates"],
        [/Professional Ice Shows场次/g, "Professional ice show dates"],
        [/Professional Ice ShowsShows次/g, "Professional ice show dates"],
        [/当前Competition Archive/g, "Current Competition Archive"],
        [/1994 仙台/g, "1994 Sendai"],
        [/1999 开始滑冰/g, "1999 Started Skating"],
        [/2022 职业转向/g, "2022 Turned Professional"],
        [/出生于Miyagi县Sendai市。/g, "Born in Sendai, Miyagi."],
        [/Yuzuru Hanyu ICE STORY 第四部/g, "Yuzuru Hanyu ICE STORY 4th"],
        [/石川／金泽/g, "Ishikawa / Kanazawa"],
        [/Chiba／船桥/g, "Chiba / Funabashi"],
        [/千叶／船桥/g, "Chiba / Funabashi"],
        [/比赛/g, "Competitions"],
        [/仙台/g, "Sendai"],
        [/宫城/g, "Miyagi"],
        [/横滨/g, "Yokohama"],
        [/八户/g, "Hachinohe"],
        [/埼玉/g, "Saitama"],
        [/佐贺/g, "Saga"],
        [/东京/g, "Tokyo"],
        [/广岛/g, "Hiroshima"],
        [/千叶/g, "Chiba"],
        [/名古屋/g, "Nagoya"],
        [/利府/g, "Rifu"],
        [/ぴあアリーナMM/g, "PIA Arena MM"],
        [/セキスイハイムスーパーアリーナ/g, "Sekisui Heim Super Arena"],
        [/さいたまスーパーアリーナ/g, "Saitama Super Arena"],
        [/日本スケート連盟\s*成績/g, "Japan Skating Federation results"]
      );
    }
    const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent || /^(SCRIPT|STYLE|NOSCRIPT|TEXTAREA)$/i.test(parent.tagName)) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }
    });
    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);
    nodes.forEach(node => {
      let value = node.nodeValue;
      replacements.forEach(([from, to]) => value = value.replace(from, to));
      node.nodeValue = value;
    });
  }

  function hardCleanVisibleText() {
    return;
    replaceLooseText();
    fixDynamicLanguageLabels();
    $$(".photo-gap,.costume-source-note").forEach(el => el.remove());
    $$("section, article, div, p").forEach(el => {
      if (el.querySelector?.("a")) return;
      const text = (el.innerText || el.textContent || "").replace(/\s+/g, " ").trim();
      if (text.length < 240 && (/逐场官方现场图/.test(text) || /Planet Hanyu\s*考斯滕图鉴\s*2004[—-]2022\s*竞技考斯滕图片来源/.test(text))) el.remove();
    });
    $$("#sources .section-head p, #sources .section-intro, #sources .final-source-kicker").forEach(el => el.remove());
    $$("#sources *, #modal *, #shows *, #competitions *, #competitionMapDeck *, body *").forEach(el => {
      if (/^(SCRIPT|STYLE|TEXTAREA|INPUT|SELECT|OPTION)$/i.test(el.tagName)) return;
      if (el.childElementCount > 0) return;
      if ((el.textContent || "").includes("\u5929\u672c")) el.textContent = el.textContent.replace(/\u5929\u672c/g, "日本");
    });
    if (lang() === "en") {
      $$("#shows *, #profile *, #overview *, #modal *, body *").forEach(el => {
        if (/^(SCRIPT|STYLE|TEXTAREA|INPUT|SELECT|OPTION)$/i.test(el.tagName)) return;
        if (el.childElementCount > 0) return;
        let value = el.textContent || "";
        value = value
          .replace(/2026\s*年生日/g, "2026 Birthday")
          .replace(/^场$/g, "Shows")
          .replace(/光点标出演出城市，筛选不同系列后对应城市点亮；右侧同步列出天期与场馆。/g, "Light points mark show cities; filtering a series highlights its cities, while the right side lists the dates and venues.")
          .replace(/Ishikawa \/ Kanazawa地区/g, "Ishikawa / Kanazawa area")
          .replace(/Chiba \/ Funabashi地区/g, "Chiba / Funabashi area");
        el.textContent = value;
      });
      return;
    }
    if (lang() !== "zh") return;
    $$("#shows *, #sources *, #competitions *, #competitionMapDeck *, #modal *").forEach(el => {
      if (/^(SCRIPT|STYLE|TEXTAREA|INPUT|SELECT|OPTION)$/i.test(el.tagName)) return;
      if (el.childElementCount > 0) return;
      let value = el.textContent || "";
      value = value
        .replace(/\u5929\u672c/g, "日本")
        .replace(/Yokohama/g, "横滨")
        .replace(/Hachinohe/g, "八户")
        .replace(/ぴあアリーナMM/g, "PIA Arena MM")
        .replace(/セキスイハイムスーパーアリーナ/g, "Sekisui Heim Super Arena")
        .replace(/さいたまスーパーアリーナ/g, "Saitama Super Arena");
      el.textContent = value;
    });
  }

  function fixDynamicLanguageLabels() {
    const l = lang();
    const now = new Date();
    const year = now.getFullYear() >= 2026 ? now.getFullYear() : 2026;
    const birthdayYear = $("#birthdayYear");
    if (birthdayYear) birthdayYear.textContent = l === "en" ? `${year} Birthday` : l === "ja" ? `${year}年の誕生日` : `${year} 年生日`;

    const birthdayTitle = $("#profile .countdown:not(.july19-countdown):not(.july19-since) .countdown-title span:first-child");
    if (birthdayTitle) birthdayTitle.textContent = l === "en" ? "Until next December 7" : l === "ja" ? "次の12月7日まで" : "距离下一次 12 月 7 日";

    const birthdayUnits = {
      zh:["天","小时","分钟","秒"],
      en:["Days","Hours","Minutes","Seconds"],
      ja:["日","時間","分","秒"]
    }[l];
    $$("#profile .countdown:not(.july19-countdown):not(.july19-since) .count-unit span").forEach((el,i)=>{ if (birthdayUnits[i]) el.textContent=birthdayUnits[i]; });

    let professionalYear = now.getFullYear();
    let nextProfessional = new Date(professionalYear, 6, 19, 0, 0, 0);
    if (now >= nextProfessional) professionalYear += 1;
    const professionalCopy = {
      zh:{next:"距离下一次 7 月 19 日",year:`${professionalYear} 年 7 月 19 日`,since:"距离 2022 年 7 月 19 日已经过去",anniversary:"转职纪念日",units:["天","小时","分钟","秒"],day:"天"},
      en:{next:"Until the next July 19",year:`July 19, ${professionalYear}`,since:"Time since July 19, 2022",anniversary:"Professional Transition Anniversary",units:["Days","Hours","Minutes","Seconds"],day:"Days"},
      ja:{next:"次の7月19日まで",year:`${professionalYear}年7月19日`,since:"2022年7月19日からの経過日数",anniversary:"プロ転向記念日",units:["日","時間","分","秒"],day:"日"}
    }[l];
    const setText=(selector,value)=>{ const el=$(selector); if(el) el.textContent=value; };
    setText("#july19NextTitle", professionalCopy.next);
    setText("#july19Year", professionalCopy.year);
    setText("#july19SinceTitle", professionalCopy.since);
    setText("#july19AnniversaryLabel", professionalCopy.anniversary);
    $$("#july19Countdown .count-unit span").forEach((el,i)=>{ if(professionalCopy.units[i]) el.textContent=professionalCopy.units[i]; });
    setText("#july19Since .count-unit span", professionalCopy.day);
  }

  function translateResidualProfileLabels() {
    const l = lang();
    const maps = {
      en:{
        "极致·数据档案":"ULTIMATE · DATA ARCHIVE","极致 · 数据档案":"ULTIMATE · DATA ARCHIVE","终极·数据档案":"ULTIMATE · DATA ARCHIVE","终极 · 数据档案":"ULTIMATE · DATA ARCHIVE",
        "奥运会金牌":"Olympic Gold Medals","冬奥会金牌":"Winter Olympic Gold Medals","冬奥单人金牌":"Olympic Singles Gold Medals","奥运会冠军":"Olympic Champion",
        "跳跃":"Jumps","经典节目":"Signature Programs","冰演场次":"Ice Show Performances","职业冰演场次":"Professional Ice Show Performances",
        "比赛记录":"Competition Records","冠军次数":"Titles","领奖台次数":"Podiums","世界纪录":"World Records","数据档案":"Data Archive"
      },
      ja:{
        "极致·数据档案":"究極・データアーカイブ","极致 · 数据档案":"究極・データアーカイブ","终极·数据档案":"究極・データアーカイブ","终极 · 数据档案":"究極・データアーカイブ",
        "奥运会金牌":"オリンピック金メダル","冬奥会金牌":"冬季五輪金メダル","冬奥单人金牌":"五輪男子シングル金メダル","奥运会冠军":"オリンピック王者",
        "跳跃":"ジャンプ","经典节目":"代表プログラム","冰演场次":"アイスショー公演数","职业冰演场次":"プロアイスショー公演数",
        "比赛记录":"競技記録","冠军次数":"優勝回数","领奖台次数":"表彰台回数","世界纪录":"世界記録","数据档案":"データアーカイブ"
      },
      zh:{}
    };
    const map = maps[l] || {};
    $$("#profile *, .hero-stat span, .fusion-stats span, .fusion-stats h3, .fusion-stats p").forEach(el=>{
      if (/^(SCRIPT|STYLE|OPTION|SELECT|INPUT|TEXTAREA)$/i.test(el.tagName) || el.childElementCount) return;
      const raw=(el.textContent||"").trim();
      if (map[raw]) el.textContent=map[raw];
    });
  }

  function installFinalCleaner() {
    return;
  }

  function removeUnwantedBlocks() {
    return;
    $$(".photo-gap,.costume-source-note").forEach(el => el.remove());
    $$("a").forEach(a => {
      const text = (a.textContent || "").trim();
      const href = a.href || "";
      if (/fantasy-on-ice|Fantasy on Ice|\bFOI\b/i.test(text + " " + href)) a.remove();
    });
    $$("section, article, details, aside, .glass, .audit-card").forEach(el => {
      const text = (el.innerText || el.textContent || "").trim();
      if (!text) return;
      if (/制作过程说明|给自己看的备注/i.test(text)) el.remove();
      if (/Fantasy on Ice|\bFOI\b/i.test(text) && !el.closest("#sources")) el.remove();
      if (text.length < 240 && /逐场官方现场图/.test(text)) el.remove();
      if (text.length < 240 && !el.querySelector?.("a") && /Planet Hanyu\s*考斯滕图鉴\s*2004[—-]2022\s*竞技考斯滕图片来源/.test(text)) el.remove();
    });
  }

  function renderFooter(l) {
    const footer = $("footer");
    if (!footer) return;
    const copy = {
      zh:{title:"管理员联系方式",x:"X：@Momoka_941207",red:"小红书：HY941207_66",meta:"羽生结弦 · ICE LEGACY 数字展览 · 数据范围 1994—2026"},
      en:{title:"Administrator Contact",x:"X: @Momoka_941207",red:"Red Book: HY941207_66",meta:"Yuzuru Hanyu · ICE LEGACY DIGITAL EXHIBITION · DATA RANGE 1994—2026"},
      ja:{title:"管理者連絡先",x:"X：@Momoka_941207",red:"小紅書：HY941207_66",meta:"羽生結弦 · ICE LEGACY デジタル展示 · データ範囲 1994—2026"}
    }[l];
    footer.innerHTML = `<div class="footer-contact"><strong>${esc(copy.title)}</strong><span>${esc(copy.x)}</span><span>${esc(copy.red)}</span></div><div class="footer-meta">${esc(copy.meta)}</div>`;
  }

  function syncHeroAndStaticText() {
    const l = lang();
    const dict = t[l];
    document.title = `${names[l]} Dashboard`;
    const h1 = $(".hero h1");
    if (h1) {
      const small = $("small", h1);
      const nameNode = Array.from(h1.childNodes).find(node => node.nodeType === Node.TEXT_NODE);
      if (nameNode) nameNode.nodeValue = names[l];
      else h1.insertBefore(document.createTextNode(names[l]), h1.firstChild);
      if (small) small.textContent = dict.heroSmall;
    }
    const heroCopy = $(".hero-copy");
    if (heroCopy) heroCopy.textContent = dict.heroCopy;
    const actions = $$(".hero-actions .btn");
    if (actions[0]) actions[0].textContent = dict.heroPrimary;
    if (actions[1]) actions[1].textContent = dict.heroSecondary;
    $$(".hero-stat span").forEach((span, i) => { if (dict.stats[i]) span.textContent = dict.stats[i]; });
    const profileTitle = $("#profile h2, #profile h1");
    if (profileTitle && /羽生|Yuzuru/.test(profileTitle.textContent)) profileTitle.textContent = names[l];
    const profileSubtitle = $$("#profile *").find(el => el.children.length === 0 && /YUZURU HANYU|羽生/.test(el.textContent || ""));
    if (profileSubtitle) {
      profileSubtitle.textContent = l === "en" ? "YUZURU HANYU · PROFESSIONAL ATHLETE / CREATOR" : `${names[l]} · ${l === "ja" ? "プロアスリート / クリエイター" : "职业运动员 / 创作者"}`;
    }
    renderFooter(l);

    const comp = $("#competitions .section-head");
    if (comp) {
      $(".section-label", comp) && ($(".section-label", comp).textContent = dict.compLabel);
      $("h2", comp) && ($("h2", comp).textContent = dict.compTitle);
      $(".section-intro", comp) && ($(".section-intro", comp).textContent = dict.compIntro);
    }
    const map = $("#competitionMapDeck .map-copy");
    if (map) {
      $("h3", map) && ($("h3", map).textContent = dict.mapTitle);
      $("p", map) && ($("p", map).textContent = dict.mapIntro);
    }
    const shows = $("#shows .section-head");
    if (shows) {
      $("h2", shows) && ($("h2", shows).textContent = dict.showTitle);
      $(".section-intro", shows) && ($(".section-intro", shows).textContent = dict.showIntro);
    }
    const costumes = $("#costumes .section-head");
    if (costumes) {
      $("[data-i18n='costumeLabel']", costumes) && ($("[data-i18n='costumeLabel']", costumes).textContent = dict.costumeLabel);
      $("[data-i18n='costumeTitle']", costumes) && ($("[data-i18n='costumeTitle']", costumes).textContent = dict.costumeTitle);
      $("[data-i18n='costumeIntro']", costumes) && ($("[data-i18n='costumeIntro']", costumes).textContent = dict.costumeIntro);
    }
    const note = $(".costume-source-note span");
    if (note) note.textContent = dict.sourceNote;
    translateFilters();
    translateShowCards();
    translateMilestoneCards();
  }

  function translateFilters() {
    const l = lang();
    const dict = t[l];
    const setOption = (sel, value, text) => {
      const opt = $(`${sel} option[value="${value}"]`);
      if (opt) opt.textContent = text;
    };
    $("#compSearch")?.setAttribute("placeholder", dict.search);
    setOption("#compYear", "all", dict.allYears);
    setOption("#compStage", "all", dict.allStages);
    setOption("#compType", "all", dict.allTypes);
    setOption("#compLocation", "all", dict.allPlaces);
    setOption("#compMedal", "all", dict.allResults);
    setOption("#compMedal", "Gold", dict.gold);
    setOption("#compMedal", "Silver", dict.silver);
    setOption("#compMedal", "Bronze", dict.bronze);
    setOption("#compMedal", "none", dict.noMedal);
    $("#loadMoreCompetitions") && ($("#loadMoreCompetitions").textContent = dict.loadMore);
  }

  function translateShowCards() {
    const l = lang();
    const cards = $$("#shows article, #shows .show-card, #shows .poster-card");
    cards.forEach(card => {
      const raw = (card.innerText || "").toLowerCase();
      let key = "";
      if (/prologue/.test(raw)) key = "prologue";
      else if (/\bgift\b/.test(raw)) key = "gift";
      else if (/re[_-]?pray|repray/.test(raw)) key = "repray";
      else if (/echoes/.test(raw)) key = "echoes";
      else if (/notte/.test(raw)) key = "notte";
      else if (/noto/.test(raw)) key = "noto";
      else if (/realive|4th|第四部|第4弾|第4部/.test(raw)) key = "realive";
      if (!key) return;
      const data = showDescriptions[key];
      const title = $("h3, h2, .poster-title, .show-title", card);
      if (title) title.textContent = typeof data.title === "object" ? data.title[l] : data.title;
      const paragraphs = $$("p", card).filter(p => p.textContent.trim().length > 10);
      if (paragraphs[0]) paragraphs[0].textContent = data[l];
      const count = $(".story-meta span:last-child, .poster-meta span:last-child", card);
      if (count) {
        const number = (count.textContent.match(/\d+/) || [""])[0];
        count.textContent = l === "en" ? `${number} shows` : l === "ja" ? `${number} 公演` : `${number} 场`;
      }
      const image = $("img", card);
      if (image) image.alt = `${typeof data.title === "object" ? data.title[l] : data.title} ${l === "en" ? "official visual" : l === "ja" ? "公式ビジュアル" : "官方主视觉"}`;
    });
  }

  const milestoneCopy = {
    zh: [

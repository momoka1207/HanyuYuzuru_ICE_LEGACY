      "上海":"Shanghai","Shanghai":"Shanghai",
      "魁北克城":"Quebec City","ケベック・シティ":"Quebec City","Quebec City":"Quebec City",
      "尼斯":"Nice","ニース":"Nice","Nice":"Nice",
      "埃斯波":"Espoo","エスポー":"Espoo","Espoo":"Espoo",
      "肯特":"Kent","ケント":"Kent","Kent":"Kent",
      "宫城":"Miyagi","宮城":"Miyagi","Miyagi":"Miyagi",
      "索契":"Sochi","ソチ":"Sochi","Sochi":"Sochi",
      "大阪":"Osaka","Osaka":"Osaka",
      "伦敦（安大略）":"London, Ontario","倫敦（安大略）":"London, Ontario","ロンドン（オンタリオ州）":"London, Ontario","London, Ontario":"London, Ontario",
      "圣约翰":"Saint John","聖約翰":"Saint John","セントジョン":"Saint John","Saint John":"Saint John",
      "巴黎":"Paris","パリ":"Paris","Paris":"Paris",
      "福冈":"Fukuoka","福岡":"Fukuoka","Fukuoka":"Fukuoka",
      "埼玉":"Saitama","さいたま":"Saitama","Saitama":"Saitama",
      "巴塞罗那":"Barcelona","バルセロナ":"Barcelona","Barcelona":"Barcelona",
      "巴里":"Barrie","バリー":"Barrie","Barrie":"Barrie",
      "莱斯布里奇":"Lethbridge","レスブリッジ":"Lethbridge","Lethbridge":"Lethbridge",
      "长野":"Nagano","長野":"Nagano","Nagano":"Nagano",
      "札幌":"Sapporo","Sapporo":"Sapporo",
      "波士顿":"Boston","ボストン":"Boston","Boston":"Boston",
      "蒙特利尔":"Montreal","モントリオール":"Montreal","Montreal":"Montreal",
      "密西沙加":"Mississauga","ミシサガ":"Mississauga","Mississauga":"Mississauga",
      "马赛":"Marseille","マルセイユ":"Marseille","Marseille":"Marseille",
      "江陵":"Gangneung","강릉":"Gangneung","Gangneung":"Gangneung",
      "赫尔辛基":"Helsinki","ヘルシンキ":"Helsinki","Helsinki":"Helsinki",
      "平昌":"PyeongChang","평창":"PyeongChang","Pyeongchang":"PyeongChang","PyeongChang":"PyeongChang",
      "奥克维尔":"Oakville","オークビル":"Oakville","Oakville":"Oakville",
      "基洛纳":"Kelowna","ケロウナ":"Kelowna","Kelowna":"Kelowna",
      "都灵":"Turin","トリノ":"Turin","Turin":"Turin",
      "首尔":"Seoul","首爾":"Seoul","ソウル":"Seoul","서울":"Seoul","Seoul":"Seoul",
      "斯德哥尔摩":"Stockholm","ストックホルム":"Stockholm","Stockholm":"Stockholm",
      "北京":"Beijing","Beijing":"Beijing",
      "海牙":"The Hague","ハーグ":"The Hague","The Hague":"The Hague"
    };
    const cityNames = {
      zh:{"Tampere":"坦佩雷","Hong Kong":"香港","Zagreb":"萨格勒布","Copenhagen":"哥本哈根","Merano":"梅拉诺","Sofia":"索菲亚","Tokyo":"东京","Nagoya":"名古屋","Moscow":"莫斯科","Taipei":"台北","Oberstdorf":"奥伯斯多夫","Shanghai":"上海","Quebec City":"魁北克城","Nice":"尼斯","Espoo":"埃斯波","Kent":"肯特","Miyagi":"宫城","Sochi":"索契","Osaka":"大阪","London, Ontario":"伦敦（安大略）","Saint John":"圣约翰","Paris":"巴黎","Fukuoka":"福冈","Saitama":"埼玉","Barcelona":"巴塞罗那","Barrie":"巴里","Lethbridge":"莱斯布里奇","Nagano":"长野","Sapporo":"札幌","Boston":"波士顿","Montreal":"蒙特利尔","Mississauga":"密西沙加","Marseille":"马赛","Gangneung":"江陵","Helsinki":"赫尔辛基","PyeongChang":"平昌","Oakville":"奥克维尔","Kelowna":"基洛纳","Turin":"都灵","Seoul":"首尔","Stockholm":"斯德哥尔摩","Beijing":"北京","The Hague":"海牙"},
      en:{"Tampere":"Tampere","Hong Kong":"Hong Kong","Zagreb":"Zagreb","Copenhagen":"Copenhagen","Merano":"Merano","Sofia":"Sofia","Tokyo":"Tokyo","Nagoya":"Nagoya","Moscow":"Moscow","Taipei":"Taipei","Oberstdorf":"Oberstdorf","Shanghai":"Shanghai","Quebec City":"Quebec City","Nice":"Nice","Espoo":"Espoo","Kent":"Kent","Miyagi":"Miyagi","Sochi":"Sochi","Osaka":"Osaka","London, Ontario":"London, Ontario","Saint John":"Saint John","Paris":"Paris","Fukuoka":"Fukuoka","Saitama":"Saitama","Barcelona":"Barcelona","Barrie":"Barrie","Lethbridge":"Lethbridge","Nagano":"Nagano","Sapporo":"Sapporo","Boston":"Boston","Montreal":"Montreal","Mississauga":"Mississauga","Marseille":"Marseille","Gangneung":"Gangneung","Helsinki":"Helsinki","PyeongChang":"PyeongChang","Oakville":"Oakville","Kelowna":"Kelowna","Turin":"Turin","Seoul":"Seoul","Stockholm":"Stockholm","Beijing":"Beijing","The Hague":"The Hague"},
      ja:{"Tampere":"タンペレ","Hong Kong":"香港","Zagreb":"ザグレブ","Copenhagen":"コペンハーゲン","Merano":"メラーノ","Sofia":"ソフィア","Tokyo":"東京","Nagoya":"名古屋","Moscow":"モスクワ","Taipei":"台北","Oberstdorf":"オーベルストドルフ","Shanghai":"上海","Quebec City":"ケベック・シティ","Nice":"ニース","Espoo":"エスポー","Kent":"ケント","Miyagi":"宮城","Sochi":"ソチ","Osaka":"大阪","London, Ontario":"ロンドン（オンタリオ州）","Saint John":"セントジョン","Paris":"パリ","Fukuoka":"福岡","Saitama":"さいたま","Barcelona":"バルセロナ","Barrie":"バリー","Lethbridge":"レスブリッジ","Nagano":"長野","Sapporo":"札幌","Boston":"ボストン","Montreal":"モントリオール","Mississauga":"ミシサガ","Marseille":"マルセイユ","Gangneung":"江陵","Helsinki":"ヘルシンキ","PyeongChang":"平昌","Oakville":"オークビル","Kelowna":"ケロウナ","Turin":"トリノ","Seoul":"ソウル","Stockholm":"ストックホルム","Beijing":"北京","The Hague":"ハーグ"}
    }[l];
    const translatePart = value => {
      const part = String(value || "").trim().replace(/\u5929\u672c/g, "日本");
      const countryKey = countryAliases[part];
      if (countryKey) return countryNames[countryKey] || part;
      const cityKey = cityAliases[part];
      if (cityKey) return cityNames[cityKey] || part;
      return part;
    };
    const normalized = String(raw || "")
      .replace(/\u5929\u672c/g, "日本")
      .replace(/대한민국|大韓民国|大韩民国/g, "Korea")
      .replace(/강릉/g, "Gangneung")
      .replace(/평창/g, "PyeongChang")
      .replace(/서울/g, "Seoul");
    return normalized
      .split(/\s*(?:[-–—]|·|／|\/)\s*/)
      .map(translatePart)
      .filter(Boolean)
      .join(" · ");
  }

  function competitionName(c) {
    if (lang() === "zh") return c.name || c.nameEn || c.id;
    return c.nameEn || c.name || c.id;
  }

  function medalText(c) {
    const l = lang();
    const dict = t[l];
    if (!c.medal) return c.rank != null ? (l === "zh" ? `第 ${c.rank} 名` : l === "ja" ? `${c.rank}位` : `Rank ${c.rank}`) : "—";
    if (c.medal === "Gold") return dict.gold;
    if (c.medal === "Silver") return dict.silver;
    if (c.medal === "Bronze") return dict.bronze;
    return c.medal;
  }

  function openStableModal(title, overline, bodyHtml, noPhoto = true) {
    const dict = t[lang()];
    const modal = $("#modal");
    modal?.classList.remove("milestone-detail", "competition-list-modal", "competition-detail-modal", "show-detail-modal");
    modal?.classList.add("open", "show", "active");
    $("#modalHero")?.classList.toggle("no-photo", noPhoto);
    $("#modalHero")?.setAttribute("data-no-photo", dict.noPhoto);
    if ($("#modalImage")) {
      $("#modalImage").src = "";
      $("#modalImage").alt = "";
    }
    $("#modalOverline") && ($("#modalOverline").textContent = overline);
    $("#modalTitle") && ($("#modalTitle").textContent = title);
    $("#modalBody") && ($("#modalBody").innerHTML = bodyHtml);
    document.body.classList.add("modal-open");
  }

  function localizeVerification(value) {
    const raw=String(value||"—");
    const l=lang();
    if (l==="en") return raw
      .replace(/^High$/i,"High")
      .replace(/^Medium\s*-\s*needs row-level official confirmation$/i,"Medium · Row-level official confirmation needed")
      .replace(/^Official source linked$/i,"Official source linked")
      .replace(/^Official archive linked; some early row PDFs may require manual click-through$/i,"Official archive linked · Some early PDFs require manual access");
    if (l==="ja") return raw
      .replace(/^High$/i,"高")
      .replace(/^Medium\s*-\s*needs row-level official confirmation$/i,"中 · 個別の公式確認が必要")
      .replace(/^Official source linked$/i,"公式出典あり")
      .replace(/^Official archive linked; some early row PDFs may require manual click-through$/i,"公式アーカイブあり · 初期資料の一部は手動確認が必要");
    return raw
      .replace(/^High$/i,"高")
      .replace(/^Medium\s*-\s*needs row-level official confirmation$/i,"中等 · 需逐条官方核验")
      .replace(/^Official source linked$/i,"已附官方来源")
      .replace(/^Official archive linked; some early row PDFs may require manual click-through$/i,"已附官方档案 · 部分早期资料需手动打开");
  }

  function openStableCompetition(id) {
    const c = getCompetitions().find(row => row.id === id);
    if (!c) return;
    const dict = t[lang()];
    const place = localPlace(c.location || c.country || "");
    const source = c.source ? `<a class="official-link" href="${esc(c.source)}" target="_blank" rel="noreferrer">${esc(dict.source)} ↗</a>` : `<span class="status-wait">${esc(dict.pending)}</span>`;
    const body = `
      <div class="modal-copy">
        <div>
          <p>${esc(dict.season)}: ${esc(c.season || "—")} · ${esc(dict.type)}: ${esc(window.__hanyuCompetitionTypeLabel?.(c.type, lang()) || c.type || "—")} · ${esc(dict.place)}: ${esc(place || "—")}</p>
          ${source}
        </div>
        <div class="stable-modal-facts">
          <div class="fact"><span>${esc(dict.rank)}</span><b>${esc(medalText(c))}</b></div>
          <div class="fact"><span>${esc(dict.score)}</span><b>${esc(c.score != null ? Number(c.score).toFixed(2) : "—")}</b></div>
          <div class="fact"><span>SP</span><b>${esc(c.spRank ?? "—")} / ${esc(c.spScore ?? "—")}</b></div>
          <div class="fact"><span>FS</span><b>${esc(c.fsRank ?? "—")} / ${esc(c.fsScore ?? "—")}</b></div>
          <div class="fact"><span>${esc(dict.verification)}</span><b>${esc(localizeVerification(c.confidence || c.verification || "—"))}</b></div>
        </div>
      </div>`;
    openStableModal(competitionName(c), `${dict.archiveOverline} · ${c.year || "—"} · ${c.id}`, body, !c.image);
    $("#modal")?.classList.add("competition-detail-modal");
    const modal = $("#modal");
    if (modal) {
      modal.dataset.languageCompetitionId = c.id;
      delete modal.dataset.languageCountryKey;
    }
  }

  function countryKeyFromText(text) {
    const s = String(text || "").replace(/\s+/g, " ");
    const pairs = [
      ["China", /中国|China|Beijing|Shanghai|Cup of China/i],
      ["Japan", /日本|Japan|JPN|NHK|Saitama|Sendai|Miyagi|Toh/i],
      ["Korea", /韩国|韓国|Korea|PyeongChang|Seoul/i],
      ["Russia", /俄罗斯|ロシア|Russia|Sochi|Moscow/i],
      ["Finland", /芬兰|フィンランド|Finland|Helsinki/i],
      ["Canada", /加拿大|カナダ|Canada|Toronto|Autumn/i],
      ["USA", /美国|アメリカ|United States|USA|Boston|Skate America/i],
      ["France", /法国|フランス|France|Nice|Paris/i],
      ["Italy", /意大利|イタリア|Italy|Merano/i],
      ["Poland", /波兰|ポーランド|Poland|Torun/i],
      ["Croatia", /克罗地亚|クロアチア|Croatia|Mladost/i],
      ["Denmark", /丹麦|デンマーク|Denmark|Copenhagen/i],
      ["Sweden", /瑞典|スウェーデン|Sweden|Stockholm/i],
      ["Germany", /德国|ドイツ|Germany|Oberstdorf/i],
      ["Netherlands", /荷兰|オランダ|Netherlands|The Hague|Hague/i],
      ["Bulgaria", /保加利亚|ブルガリア|Bulgaria|Sofia/i],
      ["Spain", /西班牙|スペイン|Spain|Barcelona/i]
    ];
    return (pairs.find(([, re]) => re.test(s)) || [null])[0];
  }

  function competitionMatchesCountry(c, key) {
    const blob = [c.location, c.name, c.nameEn, c.type].join(" ");
    return countryKeyFromText(blob) === key;
  }

  function countryKeyForCompetition(c) {
    return countryKeyFromText([c.location, c.name, c.nameEn, c.type].join(" ")) || "Japan";
  }

  const finalCountryPositions = {
    Japan:[84,42], China:[75,46], Korea:[80,43], Russia:[62,28], Finland:[52,25],
    Canada:[21,30], USA:[20,43], France:[48,39], Italy:[51,43], Poland:[53,36],
    Croatia:[52,42], Denmark:[50,32], Sweden:[51,26]
  };

  function openStableCompetitionList(keyOrRows, label) {
    const all = getCompetitions();
    let rows = Array.isArray(keyOrRows) ? keyOrRows : all.filter(c => competitionMatchesCountry(c, keyOrRows));
    if (!rows.length) rows = all;
    rows = rows.slice().sort((a,b) => (a.year || 0) - (b.year || 0) || String(a.id).localeCompare(String(b.id)));
    const dict = t[lang()];
    const titleLabel = label || localPlace(dict.countryNames[keyOrRows] || keyOrRows || dict.compTitle);
    const body = `<div class="stable-competition-list">${rows.map(c => `
      <article class="stable-competition-row" data-stable-comp-id="${esc(c.id)}">
        <b>${esc(c.year || "")} · ${esc(competitionName(c))}</b>
        <span>${esc(c.season || "—")} · ${esc(localPlace(c.location || c.country || "—"))} · ${esc(window.__hanyuCompetitionTypeLabel?.(c.type, lang()) || c.type || "—")}</span>
        <span>${esc(t[lang()].rank)}: ${esc(medalText(c))} · ${esc(t[lang()].score)}: ${esc(c.score != null ? Number(c.score).toFixed(2) : "—")} · ${esc(c.id)}</span>
      </article>
    `).join("")}</div>`;
    const listOverline = { zh:"全部比赛记录", en:"COMPLETE COMPETITION RECORDS", ja:"全競技記録" }[lang()];
    openStableModal(`${titleLabel} (${rows.length})`, listOverline, body, true);
    $("#modal")?.classList.add("competition-list-modal");
    const modal = $("#modal");
    if (modal) {
      delete modal.dataset.languageCompetitionId;
      if (!Array.isArray(keyOrRows)) modal.dataset.languageCountryKey = String(keyOrRows || "");
    }
  }

  function delayedOpenCountry(key, label) {
    openStableCompetitionList(key, label);
  }

  window.__finalCountryOpen = function(key) {
    delayedOpenCountry(key, localPlace(t[lang()].countryNames[key] || key));
  };

  function mapCountryFromLegacyRow(row) {
    const txt = row?.country || row?.name || row?.label || "";
    return countryKeyFromText(txt) || countryKeyFromText(JSON.stringify(row || {}));
  }

  function rebuildCountryAtlas() {
    const deck = $("#competitionMapDeck");
    const rows = getCompetitions();
    if (!deck || !rows.length) return;
    const l = lang();
    const dict = t[l];
    const title = $(".map-copy h3", deck);
    const intro = $(".map-copy p", deck);
    if (title) title.textContent = dict.mapTitle;
    if (intro) intro.textContent = dict.mapIntro;
  }

  function handleCountryClick(e) {
    const directTarget = e.currentTarget && e.currentTarget !== document && e.currentTarget !== window ? e.currentTarget : null;
    const target = directTarget || e.target?.closest?.(".map-event-card, .map-country-card, .country-card, .map-pin, .map-country-pin, .ultimate-country-pin, [data-country], [data-map-country], [data-ucountry], [data-country-card], [data-final-country]");
    if (!target || target.closest("#shows")) return;
    const rawKey = target?.dataset?.finalCountry || target?.dataset?.country || target?.dataset?.mapCountry || target?.dataset?.ucountry || target?.dataset?.countryCard || target?.innerText || target?.getAttribute?.("aria-label") || target?.title;
    const key = countryKeyFromText(rawKey) || rawKey;
    if (!key) return;
    e.preventDefault();
    e.stopImmediatePropagation();
    delayedOpenCountry(key, localPlace(t[lang()].countryNames[key] || key));
  }

  function bindCountryClicks() {
    $$(".map-event-card, .map-country-card, .country-card, .map-pin, .map-country-pin, .ultimate-country-pin, [data-country], [data-map-country], [data-ucountry], [data-country-card]").forEach(el => {
      if (el.closest("#shows")) return;
      let target = el;
      if (el.dataset.finalCountryCloned !== "1" && el.parentNode) {
        target = el.cloneNode(true);
        target.dataset.finalCountryCloned = "1";
        el.parentNode.replaceChild(target, el);
      }
      if (target.dataset.finalCountryBound === "1") return;
      target.dataset.finalCountryBound = "1";
      target.addEventListener("click", handleCountryClick, true);
      target.onclick = handleCountryClick;
      target.style.cursor = "pointer";
    });
  }

  function enhanceMilestoneModal(card) {
    const modal = $("#modal");
    if (!modal || !card) return;
    modal.classList.add("milestone-detail");
    const yearLine = $(".milestone-year", card)?.textContent?.trim() || $("#modalOverline")?.textContent?.trim() || "";
    const title = $("h3, h2", card)?.textContent?.trim() || $("#modalTitle")?.textContent?.trim() || "";
    const summary = $("p", card)?.textContent?.trim() || $("#modalBody p")?.textContent?.trim() || "";
    const milestoneLinkLabels = {
      zh:{image:"查看图片来源与授权 ↗",event:"查看事件来源 ↗",source:"查看来源 ↗"},
      en:{image:"Image Source & License ↗",event:"Event Source ↗",source:"View Source ↗"},
      ja:{image:"画像出典・ライセンス ↗",event:"イベント出典 ↗",source:"出典を見る ↗"}
    }[lang()];
    const existingLinks = $$("#modalBody a").map((a,index) => {
      const raw=a.textContent.replace(/\s+/g," ").trim();
      const label=/图片|image|画像/i.test(raw)?milestoneLinkLabels.image:/事件|event|イベント/i.test(raw)?milestoneLinkLabels.event:(index===0?milestoneLinkLabels.image:milestoneLinkLabels.source);
      return `<a href="${esc(a.href)}" target="_blank" rel="noreferrer">${esc(label)}</a>`;
    }).join("");
    const category = (yearLine.split("·")[1] || yearLine.split("·")[0] || "").trim();
    const year = (yearLine.split("·")[0] || "").replace(/MILESTONE/g, "").trim();
    if ($("#modalTitle")) $("#modalTitle").textContent = title;
    if ($("#modalOverline")) $("#modalOverline").textContent = `MILESTONE · ${yearLine}`;
    if ($("#modalImage")) $("#modalImage").alt = `${title} ${lang() === "en" ? "official image" : lang() === "ja" ? "公式画像" : "官方图片"}`;
    $("#modalBody") && ($("#modalBody").innerHTML = `
      <div class="final-milestone-details">
        <p class="final-milestone-lead">${esc(summary || title)}</p>
        <div class="final-milestone-facts">
          <div><span>${lang() === "en" ? "Year / Date" : lang() === "ja" ? "年 / 日付" : "年份 / 日期"}</span><b>${esc(year || "—")}</b></div>
          <div><span>${lang() === "en" ? "Category" : lang() === "ja" ? "分類" : "分类"}</span><b>${esc(category || "—")}</b></div>
          <div><span>${lang() === "en" ? "Verification" : lang() === "ja" ? "確認" : "核验"}</span><b>${lang() === "en" ? "Source linked" : lang() === "ja" ? "出典リンクあり" : "已附来源"}</b></div>
        </div>
        ${summary ? `<div><h3>${lang() === "en" ? "Details" : lang() === "ja" ? "詳細" : "详细信息"}</h3><p class="final-milestone-lead">${esc(summary)}</p></div>` : ""}
        <div class="final-milestone-links">${existingLinks || ""}</div>
      </div>
    `);
    hardCleanVisibleText();
  }

  function bindMilestoneDetails() {
    $$("[data-mile-index]").forEach(el => {
      let card = el;
      if (el.dataset.finalMilestoneCloned !== "1" && el.parentNode) {
        card = el.cloneNode(true);
        card.dataset.finalMilestoneCloned = "1";
        el.parentNode.replaceChild(card, el);
      }
      if (card.dataset.finalMilestoneBound === "1") return;
      card.dataset.finalMilestoneBound = "1";
      const open = evt => {
        evt.preventDefault();
        evt.stopImmediatePropagation();
        $("#modal")?.classList.remove("milestone-detail");
        const index = Number(card.dataset.mileIndex);
        const fallbackTitle = $("h3, h2", card)?.textContent?.trim() || "Milestone";
        const fallbackLine = $(".milestone-year", card)?.textContent?.trim() || "MILESTONE";
        const fallbackSummary = $("p", card)?.textContent?.trim() || "";
        try {
          if (typeof window.openMilestone === "function") window.openMilestone(index);
          else openStableModal(fallbackTitle, fallbackLine, `<p>${esc(fallbackSummary)}</p>`, false);
        } catch (e) {}
        enhanceMilestoneModal(card);
        const modal = $("#modal");
        if (modal) {
          modal.dataset.languageMilestoneIndex = String(index);
          delete modal.dataset.languageCompetitionId;
          delete modal.dataset.languageCountryKey;
        }
      };
      card.addEventListener("click", open, true);
      card.addEventListener("keydown", e => {
        if (e.key === "Enter" || e.key === " ") open(e);
      }, true);
      card.style.cursor = "pointer";
    });
  }

  function stabilizeCompetitionsText() {
    const rows = getCompetitions();
    const dict = t[lang()];
    const filteredCount = $("#competitionList") ? $$("#competitionList .competition-row").length : 0;
    if ($("#compCount") && rows.length) {
      const countText = $("#compCount").textContent || "";
      const n = Number((countText.match(/\d+/) || [rows.length])[0]) || rows.length;
      $("#compCount").textContent = dict.count(n, filteredCount || Math.min(n, 10));
    }
    $$("#competitionList .comp-location, #compLocation option, .map-event-card, .country-card, .map-country-card").forEach(el => {
      if (el.childElementCount > 0 && el.tagName !== "OPTION") return;
      el.textContent = localPlace(el.textContent);
    });
  }

  function hookEvents() {
    document.addEventListener("click", e => {
      const compRow = e.target.closest("[data-comp-id], [data-stable-comp-id]");
      if (compRow) {
        $("#modal")?.classList.remove("milestone-detail");
        e.preventDefault();
        e.stopImmediatePropagation();
        openStableCompetition(compRow.dataset.compId || compRow.dataset.stableCompId);
        return;
      }
      const mapTarget = e.target.closest(".map-event-card, .map-country-card, .country-card, .map-pin, .map-country-pin, .ultimate-country-pin, [data-country], [data-map-country], [data-ucountry], [data-country-card], [data-final-country]");
      if (mapTarget && !mapTarget.closest("#competitionList") && !mapTarget.closest("#shows")) {
        e.preventDefault();
        e.stopImmediatePropagation();
        handleCountryClick(e);
      }
    }, true);
    document.addEventListener("change", e => {
      if (["costumePhase", "costumeYear", "costumeProgram"].includes(e.target?.id)) {
        e.preventDefault();
        e.stopImmediatePropagation();
        renderCostumes();
      }
    }, true);
    document.addEventListener("click", e => {
      if (e.target?.id === "costumeToggle") {
        e.preventDefault();
        e.stopImmediatePropagation();
        costumeExpanded = !costumeExpanded;
        renderCostumes();
      }
    }, true);
    try {
      window.openShow = openStableShow;
      openShow = openStableShow;
    } catch (e) {}
    try {
      window.openCompetition = openStableCompetition;
      openCompetition = openStableCompetition;
    } catch (e) {}
    try {
      window.openCountry = row => {
        const key = mapCountryFromLegacyRow(row);
        openStableCompetitionList(key || getCompetitions(), key ? localPlace(t[lang()].countryNames[key] || key) : t[lang()].compTitle);
      };
      openCountry = window.openCountry;
    } catch (e) {}
    window.__openStableCompetitionList = openStableCompetitionList;
  }

  function applyNavigationTranslations(l) {
    const labels = {
      zh: ["生涯总览／里程碑", "个人主页", "比赛档案", "职业冰演", "考斯滕", "官方网站"],
      en: ["Career Overview / Milestones", "Profile", "Competition Archive", "Professional Ice Shows", "Costumes", "Official Sources"],
      ja: ["キャリア概要／マイルストーン", "プロフィール", "競技記録", "プロアイスショー", "衣装", "公式情報"]
    }[l];
    $$(".topbar nav a[data-paged-link]").forEach((a, i) => {
      if (labels[i]) a.textContent = labels[i];
    });
  }

  function applyCuratedStaticTranslations(l) {
    const s = STATIC_I18N[l];
    const set = (selector, value) => { const el = $(selector); if (el && value != null) el.textContent = value; };
    set("#overview .section-head .section-label", s.overview[0]);
    set("#overview .section-head h2", s.overview[1]);
    set("#overview .section-head .section-intro", s.overview[2]);
    set("#overview .life-axis-panel .section-label", s.arc[0]);
    set("#overview .life-axis-panel h3", s.arc[1]);
    set("#overview .life-axis-panel p", s.arc[2]);
    $$("#overview .axis-steps span").forEach((el, i) => { if (s.steps[i]) el.textContent = s.steps[i]; });
    set("#overview .fusion-stats .section-label", s.peak[0]);
    set("#overview .fusion-stats h3", s.peak[1]);
    set("#overview .fusion-stats p", s.peak[2]);
    $$("#overview .fusion-stats .mini span").forEach((el, i) => { if (s.peak[i + 3]) el.textContent = s.peak[i + 3]; });
    const archiveValue = $$("#overview .fusion-stats .mini b")[2];
    if (archiveValue) archiveValue.textContent = l === "en" ? "102 records" : l === "ja" ? "102件" : "102 条";
    set("#overview .milestone-integrated-head h3", s.milestone);
    const milestoneCount = $("#milestoneCount");
    if (milestoneCount) {
      const shown = $$("#milestoneGrid [data-mile-index]").length;
      const total = (milestoneCopy[l] || milestoneCopy.zh).length;
      milestoneCount.textContent = l === "en" ? `Showing ${shown} / ${total} milestones` : l === "ja" ? `${shown} / ${total} 件を表示` : `显示 ${shown} / ${total} 个节点`;
    }
    set("#profile .section-head .section-label", s.profile[0]);
    set("#profile .section-head h2", s.profile[1]);
    set("#profile .section-head .section-intro", s.profile[2]);
    set("#profile .profile-copy .section-label", s.profile[3]);
    set("#profile .profile-copy .lead", s.profile[4]);
    const profileTimeline = {
      zh:["出生于宫城县仙台市。","开始学习花样滑冰。","现有比赛档案的起点。","连续两届获得冬奥会男子单人滑金牌。","结束竞技生涯，转为职业运动员。","以 PROLOGUE、GIFT、RE_PRAY、Echoes of Life、REALIVE 等作品拓展 ICE STORY。"],
      en:["Born in Sendai, Miyagi Prefecture.","Began learning figure skating.","Starting point of the current competition archive.","Won consecutive Olympic men's singles gold medals.","Ended his competitive career and became a professional athlete.","Expanded ICE STORY through PROLOGUE, GIFT, RE_PRAY, Echoes of Life, REALIVE, and other works."],
      ja:["宮城県仙台市に生まれる。","フィギュアスケートを始める。","現在の競技アーカイブの起点。","オリンピック男子シングルで2大会連続金メダル。","競技生活を終え、プロアスリートへ転向。","PROLOGUE、GIFT、RE_PRAY、Echoes of Life、REALIVE などを通じて ICE STORY を展開。"]
    }[l];
    $$("#profile .life-line span").forEach((el,i)=>{if(profileTimeline[i])el.textContent=profileTimeline[i]});
    set("#profile .portrait-caption h3", names[l]);
    set("#profile .portrait-caption > div[style]", l==="en"?"YUZURU HANYU · PROFESSIONAL ATHLETE / CREATOR":l==="ja"?"羽生結弦 · プロアスリート / クリエイター":"羽生结弦 · 职业运动员 / 创作者");
    const portrait=$("#profilePortrait");if(portrait)portrait.alt=l==="en"?"Yuzuru Hanyu in the SEIMEI costume":l==="ja"?"SEIMEI 衣装の羽生結弦":"身穿《SEIMEI》考斯滕的羽生结弦";
    const units={zh:["天","小时","分钟","秒"],en:["Days","Hours","Minutes","Seconds"],ja:["日","時間","分","秒"]}[l];
    $$("#profile .count-unit span").forEach((el,i)=>{if(units[i])el.textContent=units[i]});
    const chartCopy={zh:["年度活动信号","比赛记录与职业冰演场次","比赛","职业冰演"],en:["Annual Activity Signal","Competition records and professional ice-show performances","Competition","Professional Ice Shows"],ja:["年間活動シグナル","競技記録とプロアイスショー公演数","競技","プロアイスショー"]}[l];
    set("#overview .chart-head h3",chartCopy[0]);set("#overview .chart-head p",chartCopy[1]);$$("#overview .legend span").forEach((el,i)=>{if(chartCopy[i+2])el.textContent=chartCopy[i+2]});
    set("#competitionMapDeck .map-copy .section-label",l==="en"?"WORLD VECTOR BOUNDARY ATLAS":l==="ja"?"世界ベクター境界地図":"世界矢量边界图");
    set("#shows .section-head .section-label",l==="en"?"PROFESSIONAL ICE SHOW UNIVERSE":l==="ja"?"プロアイスショーの世界":"职业冰演宇宙");
    $("#sources .section-head .section-label")?.remove();
    renderFooter(l);
    set(".producer-credit", s.producer);

    const milestoneFilters = {
      zh: ["全部", "人生", "竞技", "纪录", "职业"],
      en: ["All", "Life", "Competition", "Records", "Professional"],
      ja: ["すべて", "人生", "競技", "記録", "プロ"]
    }[l];
    $$("#milestoneFilters button").forEach((el, i) => {
      if (milestoneFilters[i]) el.textContent = milestoneFilters[i];
    });

    const showFilters = {
      zh: ["全部 36 场", "个人叙事", "纪念／慈善", "2026 最新"],
      en: ["All 36 shows", "Solo narratives", "Commemorative / Charity", "Latest 2026"],
      ja: ["全36公演", "個人の物語", "記念／チャリティー", "2026 最新"]
    }[l];
    $$("#showFilters button").forEach((el, i) => {
      if (showFilters[i]) el.textContent = showFilters[i];
    });

    set(".archive-summary span:last-child", {
      zh: "点击记录查看分项成绩、来源和图片状态",
      en: "Select a record to view segment scores, sources and image status",
      ja: "記録を選択して種目別得点、出典、画像状況を表示"
    }[l]);
  }

  function getShows() {
    try { if (Array.isArray(shows)) return shows; } catch (e) {}
    return [];
  }

  function showDataKey(s) {
    const id=String(s?.id||"").toLowerCase();
    if(id==="repray")return "repray";
    if(id==="charity")return "noto";
    return id;
  }

  function localShowPlace(raw,l=lang()) {
    let v=String(raw||"");
    const maps={
      en:{"横滨":"Yokohama","横浜":"Yokohama","八户":"Hachinohe","八戸":"Hachinohe","东京":"Tokyo","東京":"Tokyo","宫城":"Miyagi","宮城":"Miyagi","埼玉":"Saitama","佐贺":"Saga","佐賀":"Saga","石川／金泽":"Ishikawa / Kanazawa","石川／金沢":"Ishikawa / Kanazawa","广岛":"Hiroshima","広島":"Hiroshima","千叶／船桥":"Chiba / Funabashi","千葉／船橋":"Chiba / Funabashi","ぴあアリーナMM":"PIA Arena MM","石川／金泽地区":"Ishikawa / Kanazawa area"},
      ja:{"横滨":"横浜","八户":"八戸","东京":"東京","宫城":"宮城","佐贺":"佐賀","石川／金泽":"石川／金沢","广岛":"広島","千叶／船桥":"千葉／船橋","石川／金泽地区":"石川／金沢地域"},
      zh:{"横浜":"横滨","八戸":"八户","東京":"东京","宮城":"宫城","佐賀":"佐贺","石川／金沢":"石川／金泽","広島":"广岛","千葉／船橋":"千叶／船桥"}
    };
    Object.entries(maps[l]||{}).sort((a,b)=>b[0].length-a[0].length).forEach(([a,b])=>v=v.replaceAll(a,b));
    return v;
  }

  function openStableShow(id) {
    const s=getShows().find(row=>row.id===id);if(!s)return;
    const l=lang(),key=showDataKey(s),copy=showDescriptions[key],intro=copy?.[l]||s.intro||"";
    const labels={
      zh:{over:"职业冰演",official:"访问官方页面",role:"身份",roleValue:"创作／主演",performances:"演出场次",image:"图片来源",imageValue:"系列官网公开主视觉",archive:"演出档案",current:n=>`当前收录 ${n} 场`,unit:"场"},
      en:{over:"PROFESSIONAL ICE SHOW",official:"Visit Official Site",role:"Role",roleValue:"Creator / Lead Performer",performances:"Performances",image:"Image Source",imageValue:"Official series visual",archive:"Performance Archive",current:n=>`${n} performances listed`,unit:"shows"},
      ja:{over:"プロアイスショー",official:"公式サイトを見る",role:"役割",roleValue:"企画・主演",performances:"公演数",image:"画像出典",imageValue:"シリーズ公式メインビジュアル",archive:"公演アーカイブ",current:n=>`${n}公演を収録`,unit:"公演"}
    }[l];
    const schedule=(s.performances||[]).map(p=>`<div class="performance"><img decoding="async" loading="lazy" src="${esc(s.image)}" alt="${esc(s.title)}"><div><b>${esc(p[0])} · ${esc(localShowPlace(p[2],l))}</b><span>${esc(localShowPlace(p[1],l))}</span></div></div>`).join("");
    const body=`<div class="modal-copy"><div><p>${esc(intro)}</p><a class="official-link" href="${esc(s.url)}" target="_blank" rel="noreferrer">${esc(labels.official)} ↗</a></div><div class="facts"><div class="fact"><span>${esc(labels.role)}</span><b>${esc(labels.roleValue)}</b></div><div class="fact"><span>${esc(labels.performances)}</span><b>${esc(s.count)} ${esc(labels.unit)}</b></div><div class="fact"><span>${esc(labels.image)}</span><b>${esc(labels.imageValue)}</b></div></div></div><div class="schedule"><h3>${esc(labels.archive)} · ${esc(labels.current((s.performances||[]).length))}</h3><div class="performance-list">${schedule}</div></div>`;
    openStableModal(s.title,`${labels.over} · ${s.year} · ${s.count} ${labels.unit}`,body,false);
    $("#modal")?.classList.add("show-detail-modal");
    const image=$("#modalImage");if(image){image.src=s.image;image.alt=`${s.title} ${l==="en"?"official visual":l==="ja"?"公式ビジュアル":"官方主视觉"}`;}
    const modal=$("#modal");if(modal){modal.dataset.languageShowId=id;delete modal.dataset.languageCompetitionId;delete modal.dataset.languageCountryKey;delete modal.dataset.languageMilestoneIndex;}
  }

  function updateOpenModalLanguage() {
    const modal = $("#modal");
    if (!modal || !modal.classList.contains("open")) return;
    const compId = modal.dataset.languageCompetitionId;
    const countryKey = modal.dataset.languageCountryKey;
    const milestoneIndex = modal.dataset.languageMilestoneIndex;
    const showId = modal.dataset.languageShowId;
    if (showId) openStableShow(showId);
    else if (compId) openStableCompetition(compId);
    else if (countryKey) openStableCompetitionList(countryKey, localPlace(t[currentLang].countryNames[countryKey] || countryKey));
    else if (milestoneIndex != null && milestoneIndex !== "") {
      const card = $(`[data-mile-index="${milestoneIndex}"]`);
      if (card && typeof window.openMilestone === "function") {
        window.openMilestone(Number(milestoneIndex));
        enhanceMilestoneModal(card);
        modal.dataset.languageMilestoneIndex = milestoneIndex;
      }
    }
  }

  function applyLanguage(l, options = {}) {
    syncLanguageControls(l);
    applyNavigationTranslations(l);
    syncHeroAndStaticText();
    applyCuratedStaticTranslations(l);
    if (typeof drawTrend === "function") drawTrend();
    rebuildCountryAtlas();
    rebuildOfficialSources({ inPlace: !options.initial });
    if (options.initial) renderCostumes();
    else updateCostumeLanguageInPlace();
    repairProgramNames();
    if (typeof window.__hanyuCompetitionRefresh === "function") window.__hanyuCompetitionRefresh();
    if (typeof window.__hanyuRenderShowMap === "function") window.__hanyuRenderShowMap();
    stabilizeCompetitionsText();
    fixDynamicLanguageLabels();
    translateResidualProfileLabels();
    updateProfileBooksLanguage();
    window.__hanyuActivatePageImages?.();
    if (!options.initial) updateOpenModalLanguage();
    const pageKey = (document.body.className.match(/(?:^|\s)page-([a-z]+)(?:\s|$)/) || [])[1] || "home";
    window.__hanyuSetPage?.(pageKey, { push: false, scroll: false });
  }

  function setLanguage(nextLang, options = {}) {
    nextLang = validLang(nextLang);
    if (isApplyingLanguage) return;
    if (!options.force && nextLang === currentLang) {
      syncLanguageControls(nextLang);
      return;
    }
    const scrollX = window.scrollX;
    const scrollY = window.scrollY;
    isApplyingLanguage = true;
    try {
      currentLang = nextLang;
      try { localStorage.setItem(LANGUAGE_STORAGE_KEY, currentLang); } catch (e) {}
      applyLanguage(currentLang, options);
    } finally {
      isApplyingLanguage = false;
      if (window.scrollX !== scrollX || window.scrollY !== scrollY) window.scrollTo(scrollX, scrollY);
    }
  }

  window.setLanguage = setLanguage;
  window.__hanyuGetLanguage = () => currentLang;
  window.__hanyuRefreshDynamicLanguage = () => {
    translateShowCards();
    translateMilestoneCards();
    bindMilestoneDetails();
    stabilizeCompetitionsText();
    fixDynamicLanguageLabels();
  };

  function ensureLanguageControl() {
    if ($("#languageSelect")) return;
    const header = $(".topbar");
    if (!header) return;
    let tools = $(".topbar-tools", header);
    if (!tools) {
      tools = document.createElement("div");
      tools.className = "topbar-tools";
      header.appendChild(tools);
    }
    const wrap = document.createElement("label");
    wrap.className = "lang-switch";
    const caption = document.createElement("span");
    caption.textContent = "LANGUAGE";
    const select = document.createElement("select");
    select.id = "languageSelect";
    select.setAttribute("aria-label", "Language");
    [["zh", "中文"], ["en", "English"], ["ja", "日本語"]].forEach(([value, label]) => {
      const option = document.createElement("option");
      option.value = value;
      option.textContent = label;
      select.appendChild(option);
    });
    wrap.append(caption, select);
    tools.appendChild(wrap);
  }

  function bindLanguageControlOnce() {
    ensureLanguageControl();
    const oldSelect = $("#languageSelect");
    if (!oldSelect) return;
    const select = oldSelect.dataset.languageBound === "true" ? oldSelect : oldSelect.cloneNode(true);
    if (select !== oldSelect) oldSelect.replaceWith(select);
    if (select.dataset.languageBound === "true") return;
    select.dataset.languageBound = "true";
    select.addEventListener("change", handleLanguageChange);
  }

  function handleLanguageChange(event) {
    setLanguage(event.target.value);
  }

  function runInitialEnhancements() {
    injectStyle();
    normalizeCostumeIds();
    bindCountryClicks();
    bindMilestoneDetails();
  }

  function init() {
    bindLanguageControlOnce();
    hookEvents();
    runInitialEnhancements();
    setLanguage(currentLang, { force: true, initial: true });
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
  else init();
})();
</script>

<script id="paged-routing-hotfix">
(function(){
  "use strict";
  if(window.__hanyuPageRuntime)return;
  window.__hanyuPageRuntime=true;
  const pages={home:'index.html',profile:'profile.html',competition:'competition.html',shows:'shows.html',costumes:'costumes.html',sources:'sources.html'};
  const selectors={home:'.hero,#overview',profile:'#profile',competition:'#competitions',shows:'#shows',costumes:'#costumes',sources:'#sources'};
  const titleSuffix={zh:{home:'生涯总览',profile:'个人主页',competition:'比赛档案',shows:'职业冰演',costumes:'考斯滕',sources:'官方网站'},en:{home:'Career Overview',profile:'Profile',competition:'Competition Archive',shows:'Professional Ice Shows',costumes:'Costumes',sources:'Official Sources'},ja:{home:'キャリア概要',profile:'プロフィール',competition:'競技記録',shows:'プロアイスショー',costumes:'衣装',sources:'公式情報'}};
  function current(){return (document.body.className.match(/page-([a-z]+)/)||[])[1]||'home'}
  function activateImages(){const key=current(),root=document.querySelector(selectors[key]);if(!root)return;if(key==='profile'){const p=document.querySelector('#profilePortrait');if(p&&!p.getAttribute('src')&&typeof profileImage!=='undefined')p.src=profileImage}const imgs=[...root.querySelectorAll('img[src]')];const priorityCount=key==='home'?4:key==='shows'||key==='costumes'?5:2;imgs.forEach((img,i)=>{img.decoding='async';img.referrerPolicy='no-referrer';img.loading=i<priorityCount?'eager':'lazy';img.fetchPriority=i<priorityCount?'high':'auto'})}
  function setPage(key,{push=true,scroll=true}={}){if(!pages[key])key='home';Object.keys(pages).forEach(k=>document.body.classList.toggle('page-'+k,k===key));document.body.classList.add('paged-page');document.querySelectorAll('.topbar nav a[data-paged-link]').forEach(a=>{if(a.dataset.pagedLink===key)a.setAttribute('data-active-page','1');else a.removeAttribute('data-active-page')});if(push&&location.protocol!=='about:'&&location.protocol!=='data:'){history.pushState({page:key},'',pages[key])}const l=document.documentElement.dataset.lang||'zh';document.title=`${l==='ja'?'羽生結弦':l==='en'?'Yuzuru Hanyu':'羽生结弦'} ICE LEGACY｜${titleSuffix[l]?.[key]||titleSuffix.en[key]}`;activateImages();if(scroll)window.scrollTo({top:0,left:0,behavior:'auto'})}
  document.addEventListener('click',e=>{const a=e.target.closest('a[href]');if(!a||e.defaultPrevented||e.button!==0||e.metaKey||e.ctrlKey||e.shiftKey||e.altKey||a.target==='_blank'||a.hasAttribute('download'))return;const raw=(a.getAttribute('href')||'').split('#')[0].split('?')[0].replace(/^.*\//,'');const key=a.dataset.pagedLink||Object.entries(pages).find(([,filename])=>filename===raw)?.[0];if(!key)return;e.preventDefault();e.stopImmediatePropagation();setPage(key)},true);
  window.addEventListener('popstate',e=>setPage(e.state?.page||Object.entries(pages).find(([,v])=>location.pathname.endsWith(v))?.[0]||'home',{push:false,scroll:false}));
  window.__hanyuSetPage=setPage;window.__hanyuActivatePageImages=activateImages;setPage(current(),{push:false,scroll:false});
})();
</script>
<style id="lightweight-final-polish-style">
  .official-show-jump{display:inline-flex;align-items:center;justify-content:center;width:max-content;max-width:100%;margin:0 0 18px;padding:12px 18px;border:1px solid rgba(137,232,255,.62);border-radius:999px;color:#061018!important;background:linear-gradient(135deg,#9beeff,#f1d376);font-weight:900;text-decoration:none;box-shadow:0 12px 34px rgba(65,203,231,.22)}
  .july19-countdown,.july19-since{margin-top:14px}.july19-since .countdown-clock.single{grid-template-columns:minmax(160px,280px)}
  .final-country-list{display:grid;gap:12px}.final-country-row{display:grid;grid-template-columns:92px 1fr 140px 96px;gap:18px;align-items:center;padding:16px 18px;border:1px solid rgba(144,218,238,.24);border-radius:18px;background:rgba(8,22,35,.62);cursor:pointer}.final-country-row:hover{border-color:rgba(144,218,238,.72);transform:translateY(-1px)}.final-country-row b{color:#f5f8fb}.final-country-row span,.final-country-row em{color:#aebdcc;font-style:normal}.final-country-row .year{font-size:24px;color:#f1d376;font-weight:900}.final-country-row .medal{justify-self:end;display:inline-flex;padding:6px 12px;border-radius:999px;background:rgba(241,211,118,.18);color:#f1d376;font-weight:900}.show-official-panel{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(220px,.9fr);gap:18px;margin-bottom:22px}.show-official-panel .facts{display:grid;gap:10px}.show-official-panel p{margin:0;color:#b9c7d5;line-height:1.75}.show-schedule-list{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.show-schedule-list .performance{min-width:0}.show-schedule-list .performance img{width:88px;height:58px;object-fit:cover;flex:0 0 auto}
  @media(max-width:760px){html,body{max-width:100%;overflow-x:hidden}.topbar{height:auto!important;min-height:58px!important;padding:10px 12px!important;gap:10px!important;align-items:flex-start!important;flex-wrap:wrap!important}.brand{font-size:12px!important;letter-spacing:.08em!important}.topbar nav{display:flex!important;overflow-x:auto!important;white-space:nowrap!important;gap:12px!important;width:100%!important;order:3!important;padding-bottom:4px!important}.topbar nav a{font-size:13px!important;flex:0 0 auto}.topbar-tools,.language-switch{margin-left:0!important}.wrap{width:calc(100% - 24px)!important}.hero{min-height:620px!important;padding:88px 14px 24px!important}.hero h1,h1{font-size:clamp(42px,15vw,72px)!important;line-height:1.02!important;max-width:100%!important;word-break:keep-all!important}.section{padding:52px 0!important}.section-head,.profile-grid,.overview-grid,.show-map-layout,.audit,.guest-stage,.show-official-panel{grid-template-columns:1fr!important}.archive-controls,.costume-filters{grid-template-columns:1fr!important}.competition-row,.final-country-row{grid-template-columns:1fr!important;gap:6px!important}.final-country-row .medal{justify-self:start}.modal{padding:10px!important;align-items:flex-start!important;overflow:auto!important}.modal-card{width:100%!important;max-height:none!important;border-radius:16px!important}.modal-title h2,#modalTitle{font-size:clamp(30px,10vw,46px)!important;line-height:1.08!important;word-break:break-word!important}.modal-copy,.performance-list,.show-schedule-list,.map-event-strip,.costume-grid,.costume-grid-v2,.official-grid{grid-template-columns:1fr!important}.world-map-stage,.japan-map-stage{height:360px!important}.countdown-clock{grid-template-columns:repeat(2,minmax(0,1fr))!important}.july19-since .countdown-clock.single{grid-template-columns:1fr!important}.poster-grid,.timeline-grid,.milestone-grid{grid-template-columns:1fr!important}.profile-portrait,.milestone-card img,.poster img{max-width:100%;height:auto}}
</style>
<style id="mobile-costume-crop-and-flicker-fix">
  @media(max-width:760px){
    html{scroll-behavior:auto!important}
    #costumes .stable-costume-card img,
    #costumes .costume-card-v2>img,
    #costumes .costume-card-v3 .costume-image-shell img{
      height:300px!important;
      width:100%!important;
      object-fit:contain!important;
      object-position:center top!important;
      background:#061320!important;
      padding:0!important;
    }
    #costumes .costume-card-v3 .costume-image-shell{height:300px!important;background:#061320!important}
    #costumes .stable-costume-grid,#costumes .final-costume-grid{grid-template-columns:1fr!important;gap:18px!important}
  }
</style>
<style id="mobile-hero-image-final-fix">
  @media(max-width:760px){
    .hero-bg{
      background:
        linear-gradient(90deg,rgba(1,7,14,.98) 0%,rgba(1,7,14,.93) 34%,rgba(1,7,14,.72) 55%,rgba(1,7,14,.40) 100%),
        url('assets/inline-00-5a9aeb34ef.jpg') 82% 42%/auto 76% no-repeat!important;
      background-color:#01070e!important;
      filter:saturate(.9) contrast(1.02)!important;
      opacity:1!important;
    }
    .hero-bg:before{display:none!important}
    .hero-bg:after{
      background:linear-gradient(180deg,#01070e 0%,rgba(1,7,14,.06) 20%,rgba(1,7,14,.18) 70%,#01070e 100%)!important;
    }
  }
</style>

<style id="upload-paged-final">
/* Upload-safe final layer. This same stylesheet is inlined into every page. */
.hero-bg {
  background:
    linear-gradient(90deg,#01070e 0%,rgba(1,7,14,.97) 19%,rgba(1,7,14,.82) 36%,rgba(1,7,14,.35) 58%,rgba(1,7,14,.06) 78%,rgba(1,7,14,.02) 100%),
    url("assets/inline-00-b3683d2dba.jpg") calc(94vw - 935px) 52% / auto 115% no-repeat !important;
  background-color:#01070e !important;
  filter:saturate(.94) contrast(1.02) !important;
}

.producer-credit { text-transform:none !important; }

html[lang^="zh"] body.page-home .hero h1 {
  font-family:"Songti SC","STSong","Noto Serif SC","Source Han Serif SC","SimSun",serif !important;
  letter-spacing:0 !important;
}

html[lang^="en"] body.page-home .hero h1 {
  font-family:Baskerville,"Iowan Old Style","Palatino Linotype","Times New Roman",serif !important;
  letter-spacing:0 !important;
}

html[lang^="ja"] body.page-home .hero h1 {
  font-family:"Yu Mincho","Hiragino Mincho ProN","Noto Serif JP","MS PMincho",serif !important;
  letter-spacing:0 !important;
}

@media (max-width:760px) {
  html,body { max-width:100%; overflow-x:hidden; }

  .hero { min-height:620px !important; }
  .hero-bg {
    background:
      linear-gradient(180deg,rgba(1,7,14,.04) 0%,rgba(1,7,14,.12) 45%,rgba(1,7,14,.72) 74%,#01070e 100%),
      linear-gradient(90deg,rgba(1,7,14,.25),rgba(1,7,14,.02) 74%,rgba(1,7,14,.08)),
      url("assets/inline-00-b3683d2dba.jpg") 46% 20% / auto 110% no-repeat !important;
    background-color:#01070e !important;
  }

  .hero-content { padding:72px 0 118px !important; }
  .hero h1 { font-size:clamp(43px,14vw,62px) !important; line-height:1 !important; }
  .hero-copy { font-size:12px !important; line-height:1.65 !important; }
  .producer-credit { right:12px !important; top:74px !important; font-size:9px !important; }

  .section { padding:34px 0 !important; }
  .section-head { margin-bottom:16px !important; }
  .section h2 { font-size:30px !important; line-height:1.08 !important; }
  .section-intro { margin-top:9px !important; font-size:11px !important; line-height:1.6 !important; }
  .glass,.panel,.archive-shell,.show-map-side,.ice-japan-copy { padding:12px !important; }

  /* Two columns give roughly four compact records per phone viewport. */
  .milestone-grid,
  .ice-universe-grid,
  #costumes .final-costume-grid,
  #costumes .stable-costume-grid,
  #costumes .costume-grid,
  #costumes .costume-grid-v2,
  #costumes .costume-grid-v3,
  .final-country-grid,
  .country-summary-grid {
    grid-template-columns:repeat(2,minmax(0,1fr)) !important;
    gap:8px !important;
  }

  .milestone-card {
    min-height:0 !important;
    height:226px !important;
    border-radius:11px !important;
  }
  .milestone-card img {
    width:100% !important;
    height:104px !important;
    object-fit:cover !important;
    object-position:center 18% !important;
  }
  .milestone-body { padding:9px !important; }
  .milestone-year { font-size:8px !important; letter-spacing:.05em !important; }
  .milestone-card h3 { margin:5px 0 !important; font-size:13px !important; line-height:1.2 !important; }
  .milestone-card p {
    margin:0 !important;
    font-size:9px !important;
    line-height:1.4 !important;
    display:-webkit-box;
    -webkit-box-orient:vertical;
    -webkit-line-clamp:3;
    overflow:hidden;
  }

  .milestone-controls { display:block !important; margin-bottom:12px !important; }
  .milestone-controls .filters { margin-top:10px !important; gap:6px !important; }
  .filter { padding:7px 10px !important; font-size:10px !important; }

  .portrait-panel { min-height:330px !important; }
  .profile-copy { padding:15px !important; }
  .profile-copy .lead { margin:10px 0 14px !important; font-size:14px !important; line-height:1.65 !important; }
  .life-line { margin:14px 0 !important; gap:7px 10px !important; }
  .countdown { margin-top:9px !important; padding:12px !important; }
  .countdown-clock { gap:5px !important; margin-top:9px !important; }
  .count-unit { padding:8px 4px !important; }
  .count-unit b { font-size:22px !important; }

  .archive-controls { grid-template-columns:1fr 1fr !important; gap:7px !important; }
  .archive-controls input { grid-column:1/-1 !important; }
  .archive-controls input,.archive-controls select { min-height:40px !important; padding:8px 9px !important; }
  .archive-summary { padding:10px 2px 8px !important; font-size:9px !important; }
  .competition-list { gap:5px !important; }
  .competition-row {
    grid-template-columns:38px minmax(0,1fr) 56px !important;
    gap:6px !important;
    min-height:0 !important;
    padding:8px !important;
    border-radius:9px !important;
  }
  .comp-year { font-size:11px !important; }
  .comp-name b { font-size:10px !important; line-height:1.22 !important; }
  .comp-name span { font-size:8px !important; line-height:1.3 !important; }
  .comp-type,.competition-row>.comp-location { display:none !important; }
  .comp-result { justify-self:end !important; text-align:right !important; font-size:9px !important; }
  .medal { padding:3px 5px !important; font-size:8px !important; }

  .world-map-stage,.japan-map-stage { height:220px !important; margin:10px 8px 0 !important; }
  .show-map-events,.ice-japan-events { max-height:220px !important; }
  .map-event-card,.show-map-event { padding:7px !important; }

  .ice-universe { padding:12px !important; border-radius:16px !important; }
  .ice-universe-head { display:block !important; margin-bottom:10px !important; }
  .ice-story-card,.ice-story-card.feature {
    display:block !important;
    min-height:0 !important;
    height:242px !important;
    border-radius:11px !important;
  }
  .ice-story-card img,.ice-story-card.feature img {
    width:100% !important;
    height:108px !important;
    min-height:0 !important;
    padding:8px !important;
    object-fit:contain !important;
  }
  .ice-story-card .story-body { padding:9px !important; }
  .ice-story-card .story-meta { font-size:8px !important; letter-spacing:.04em !important; }
  .ice-story-card h4 { margin:5px 0 !important; font-size:15px !important; line-height:1.2 !important; }
  .ice-story-card p {
    font-size:9px !important;
    line-height:1.38 !important;
    display:-webkit-box;
    -webkit-box-orient:vertical;
    -webkit-line-clamp:3;
    overflow:hidden;
  }

  #costumes .final-costume-controls,
  #costumes .stable-costume-controls {
    grid-template-columns:1fr !important;
    gap:6px !important;
    margin:12px 0 !important;
    padding:9px !important;
    border-radius:12px !important;
  }
  #costumes .final-costume-controls select,
  #costumes .stable-costume-controls select,
  #costumes .stable-costume-controls button { min-height:39px !important; padding:0 9px !important; font-size:11px !important; }
  #costumes .stable-costume-card,
  #costumes .costume-card-v2,
  #costumes .costume-card-v3 { min-height:0 !important; border-radius:11px !important; }
  #costumes .stable-costume-card img,
  #costumes .costume-card-v2 img,
  #costumes .costume-card-v3 .costume-image-shell,
  #costumes .costume-card-v3 .costume-image-shell img {
    width:100% !important;
    height:132px !important;
    min-height:0 !important;
    object-fit:cover !important;
    object-position:center 14% !important;
  }
  #costumes .costume-body,
  #costumes .stable-costume-card .costume-body,
  #costumes .costume-card-body { padding:8px !important; }
  #costumes .season { font-size:7px !important; line-height:1.3 !important; }
  #costumes h3 { margin:4px 0 !important; font-size:12px !important; line-height:1.2 !important; }
  #costumes p {
    font-size:8px !important;
    line-height:1.35 !important;
    display:-webkit-box;
    -webkit-box-orient:vertical;
    -webkit-line-clamp:2;
    overflow:hidden;
  }
  #costumes .costume-years,#costumes .costume-source-pill { margin-top:5px !important; font-size:8px !important; line-height:1.3 !important; }

  .simple-source-group { gap:7px !important; padding:9px 0 !important; }
  .simple-source-link { padding:2px 0 6px !important; font-size:11px !important; }

  .modal { padding:7px !important; align-items:center !important; overflow:hidden !important; }
  .modal-card { width:100% !important; height:auto !important; max-height:calc(100dvh - 14px) !important; overflow:auto !important; border-radius:12px !important; }
  .modal-hero { height:180px !important; min-height:130px !important; }
  .modal-title { left:14px !important; right:58px !important; bottom:11px !important; }
  .modal-title h2,#modalTitle { margin:4px 0 !important; font-size:clamp(25px,8vw,34px) !important; line-height:1.08 !important; }
  .modal-body { padding:0 14px 17px !important; }
  .modal-copy { gap:10px !important; }
  .modal-copy p { font-size:11px !important; line-height:1.58 !important; }
  .schedule { margin-top:12px !important; }
  .performance-list,.show-schedule-list { gap:5px !important; }
  .performance { grid-template-columns:58px minmax(0,1fr) !important; gap:7px !important; padding:5px !important; }
  .performance img { width:58px !important; height:42px !important; }
}

@media (min-width:761px) and (max-width:980px) {
  .hero-bg {
    background:
      linear-gradient(90deg,#01070e 0%,rgba(1,7,14,.94) 28%,rgba(1,7,14,.48) 56%,rgba(1,7,14,.04) 100%),
      url("assets/inline-00-b3683d2dba.jpg") left center / auto 110% no-repeat !important;
  }
}

@media (max-width:760px) {
  body.page-home #overview .overview-fusion {
    grid-template-columns:repeat(2,minmax(0,1fr)) !important;
    gap:8px !important;
  }
  body.page-home #overview .life-axis-panel,
  body.page-home #overview .fusion-stats {
    min-height:250px !important;
    padding:11px !important;
  }
  body.page-home #overview .life-axis-panel h3,
  body.page-home #overview .fusion-stats h3 {
    margin:7px 0 !important;
    font-size:15px !important;
    line-height:1.2 !important;
  }
  body.page-home #overview .life-axis-panel p,
  body.page-home #overview .fusion-stats p {
    font-size:9px !important;
    line-height:1.45 !important;
    display:-webkit-box;
    -webkit-box-orient:vertical;
    -webkit-line-clamp:5;
    overflow:hidden;
  }
  body.page-home #overview .axis-steps { gap:4px !important; }
  body.page-home #overview .axis-steps span { padding:5px 6px !important; font-size:7px !important; }
  body.page-home #overview .fusion-stats .big { font-size:40px !important; }
  body.page-home #overview .fusion-stats .mini { padding-top:6px !important; font-size:8px !important; }
  body.page-home #overview .compact-signal { grid-column:1/-1 !important; padding:11px !important; }
  body.page-home #overview .compact-signal .chart { height:210px !important; }

  body.page-home #overview #milestoneGrid.milestone-grid,
  body.page-costumes #costumes .final-costume-grid,
  body.page-costumes #costumes .stable-costume-grid,
  body.page-costumes #costumes .costume-grid,
  body.page-costumes #costumes .costume-grid-v2,
  body.page-costumes #costumes .costume-grid-v3 {
    grid-template-columns:repeat(2,minmax(0,1fr)) !important;
    gap:8px !important;
  }
}

</style>
</body>
</html>

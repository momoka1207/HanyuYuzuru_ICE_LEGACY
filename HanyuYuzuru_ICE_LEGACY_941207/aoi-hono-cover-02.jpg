    };
    const cityAliases = {
      "坦佩雷":"Tampere","Tampere":"Tampere","タンペレ":"Tampere",
      "香港":"Hong Kong","Hong Kong":"Hong Kong",
      "萨格勒布":"Zagreb","ザグレブ":"Zagreb","Zagreb":"Zagreb",
      "哥本哈根":"Copenhagen","コペンハーゲン":"Copenhagen","Copenhagen":"Copenhagen",
      "梅拉诺":"Merano","メラーノ":"Merano","Merano":"Merano",

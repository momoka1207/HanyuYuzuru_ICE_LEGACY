  const LANGUAGE_STORAGE_KEY = "hanyuLang";
  const validLang = v => ({ zh: "zh", en: "en", ja: "ja", jp: "ja", "zh-CN": "zh" }[v] || "zh");
  function getInitialLanguage() {
    let saved = "";
    try { saved = localStorage.getItem(LANGUAGE_STORAGE_KEY) || ""; } catch (e) {}
    return validLang(saved || $("#languageSelect")?.value || "zh");

      volumes: [
        { meta:"第1巻 · 2012年 · 扶桑社", title:"『蒼い炎』", alt:"『蒼い炎』第1巻 表紙", desc:"4歳でスケートを始めた頃から、2011年の東日本大震災を経て、世界選手権の表彰台へ進むまでの成長を写真とロングインタビューで振り返ります。" },
        { meta:"第2巻 · 2016年 · 扶桑社", title:"『蒼い炎Ⅱ－飛翔編－』", alt:"『蒼い炎Ⅱ－飛翔編－』表紙", desc:"2012年から2016年まで、トロントへの拠点移動、ソチ五輪優勝、けがや病気、そして世界記録を更新し続けた歩みを収録しています。" },
        { meta:"第3巻 · 2023年 · 扶桑社", title:"『蒼い炎Ⅲ－究竟編－』", alt:"『蒼い炎Ⅲ－究竟編－』表紙", desc:"2015–2016シーズンのオフから、2018年平昌五輪連覇、2020年のスーパースラム達成まで、理想のスケートを追い続ける姿を描きます。" },
        { meta:"第4巻 · 2023年 · 扶桑社", title:"『蒼い炎Ⅳ－無限編－』", alt:"『蒼い炎Ⅳ－無限編－』表紙", desc:"北京2022での4回転半への挑戦と競技生活の終章、さらにプロ転向後の PROLOGUE、GIFT など新たな創作へ進む姿を収録しています。" }
